[package]
name = "grapheme-sdk"
version = "0.6.1"
edition = "2021"
description = "Embedded SDK for compiling and executing Grapheme workflows"
license = "Apache-2.0"
repository = "https://github.com/entasislabs/grapheme"
homepage = "https://github.com/entasislabs/grapheme"

[features]
default = []
full = [
    "grapheme-stdlib/full",
    "grapheme-signatures/full",
    "grapheme-runtime/full",
    "grapheme-compiler/full",
    "wasix-runtime",
]
wasix-runtime = ["grapheme-runtime/wasix-runtime"]
data = ["grapheme-stdlib/data", "grapheme-signatures/data", "grapheme-runtime/data", "grapheme-compiler/data"]
pdf = ["grapheme-stdlib/pdf", "grapheme-signatures/pdf", "grapheme-runtime/pdf", "grapheme-compiler/pdf"]
image = ["grapheme-stdlib/image", "grapheme-signatures/image", "grapheme-runtime/image", "grapheme-compiler/image"]
plot = ["grapheme-stdlib/plot", "grapheme-signatures/plot", "grapheme-runtime/plot", "grapheme-compiler/plot"]
media = ["grapheme-stdlib/media", "grapheme-signatures/media", "grapheme-runtime/media", "grapheme-compiler/media"]

[dependencies]
thiserror = "1.0"
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
serde_yaml = "0.9"
grapheme-artifact = { path = "../grapheme-artifact", version = "0.2.0" }
grapheme-compiler = { path = "../grapheme-compiler", version = "0.6.1", default-features = false }
grapheme-runtime = { path = "../grapheme-runtime", version = "0.6.1", default-features = false }
grapheme-signatures = { path = "../grapheme-signatures", version = "0.6.1", default-features = false }
grapheme-stdlib = { path = "../grapheme-stdlib", version = "0.6.1", default-features = false }
