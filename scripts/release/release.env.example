# Copy to release.env and source before publishing (do not commit secrets).
# source scripts/release/release.env.example  # after filling in values

export MEDOUSA_RELEASE_BASE_URL="https://releases.entasislabs.com/medousa"
export MEDOUSA_RELEASE_CHANNEL="stable"

# Cloudflare R2 (S3-compatible) — API endpoint, NOT the public download URL
export MEDOUSA_R2_BUCKET="medousa"
export MEDOUSA_R2_ENDPOINT="https://3b2e3338687e8e0abd4c85280e87fd7a.r2.cloudflarestorage.com"
export AWS_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY"
export AWS_SECRET_ACCESS_KEY="YOUR_R2_SECRET_KEY"

# Optional: override object prefix (default: medousa/stable)
# export MEDOUSA_R2_PREFIX="medousa/stable"
