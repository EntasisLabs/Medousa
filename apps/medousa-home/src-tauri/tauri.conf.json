{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Medousa Home",
  "version": "0.1.0",
  "identifier": "com.entasislabs.medousa-home",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Medousa Home",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640
      },
      {
        "label": "chat-popout",
        "title": "Medousa Chat",
        "url": "/popout/chat",
        "width": 440,
        "height": 760,
        "minWidth": 360,
        "minHeight": 480,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "iOS": {
      "minimumSystemVersion": "15.0",
      "infoPlist": "Info.mobile.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": ["medousa"],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": ["medousa"]
      }
    }
  }
}
