{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "browser-tab-webviews",
  "description": "Remote browser tab webviews — IPC back to the shell for chrome hotkeys / new-window / metadata",
  "webviews": ["embed-tab-*", "popout-tab-*", "main-browser-content", "browser-content"],
  "remote": {
    "urls": ["https://*", "http://*"]
  },
  "permissions": ["core:default"]
}
