@import "./lib/styles/chat-mobile-tokens.postcss";
@import "./lib/styles/markdown-tokens.postcss";
@import "./lib/styles/chart-tokens.postcss";
@import "./lib/styles/workshop-shell.postcss";
@import "./lib/styles/peers.postcss";
@import "./lib/styles/browser.postcss";
@import "./lib/styles/theme-obsidian.postcss";
@import "./lib/styles/theme-black-lily.postcss";

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  html,
  body {
    height: 100%;
  }

  html {
    --mobile-keyboard-inset: 0px;
    --mobile-bottom-chrome-height: 5.5rem;
  }

  /* iOS WKWebView auto-zooms focused inputs below 16px — enforce minimum app-wide. */
  html[data-native-shell="ios"] :is(
      input:not([type="checkbox"]):not([type="radio"]):not([type="range"]):not([type="hidden"]):not(
          [type="file"]
        ),
      textarea,
      select
    ) {
    font-size: 16px;
  }

  html.dark body {
    @apply antialiased text-surface-50;
  }

  html:not(.dark) body {
    -webkit-font-smoothing: antialiased;
    color: rgb(var(--color-surface-50));
    background-color: rgb(var(--color-surface-950));
  }
}

@layer components {
  .workshop-list-row-active {
    background-color: rgb(var(--color-primary-500) / 0.1);
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.25);
  }

  .context-layer-toggle {
    @apply flex w-full items-center justify-between rounded-md border border-surface-500/35 bg-surface-900/50 px-3 py-2 text-left text-sm text-surface-200 transition hover:bg-surface-800/70;
  }

  .context-layer-body {
    @apply workshop-inset space-y-2 p-3;
  }

  .context-layer-raw {
    @apply workshop-inset max-h-64 overflow-auto p-3 font-mono text-[11px] leading-relaxed text-surface-300;
  }

  .context-witness-hero {
    @apply max-w-xl;
  }

  .context-witness-kicker {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
  }

  .context-witness-title {
    @apply text-lg font-semibold leading-snug tracking-tight text-surface-50;
  }

  .context-witness-meta {
    @apply mt-2 text-sm text-surface-400;
  }

  .context-witness-lead {
    @apply mt-4 text-[15px] leading-relaxed text-surface-200;
  }

  .context-story-chapter {
    @apply mt-6 max-w-xl;
  }

  .context-story-label {
    margin: 0;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
  }

  .context-story-copy {
    margin: 0.45rem 0 0;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgb(var(--shell-label, var(--color-surface-200)));
  }

  .context-story-tags {
    @apply mt-3 flex flex-wrap gap-1.5;
  }

  .context-story-tag {
    @apply rounded-md px-2 py-0.5 text-[10px] font-medium tracking-wide text-surface-400;
    background: rgb(var(--shell-pane-muted-bg, var(--color-surface-800)) / 0.55);
  }

  .context-pref-line {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgb(var(--shell-label, var(--color-surface-200)));
  }

  .context-pref-line + .context-pref-line {
    margin-top: 0.55rem;
  }

  .context-plumbing {
    @apply mt-8 max-w-xl border-t border-surface-500/30 pt-4;
  }

  .context-plumbing-toggle {
    display: flex;
    width: 100%;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
  }

  .context-plumbing-title {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgb(var(--shell-label, var(--color-surface-100)));
  }

  .context-plumbing-lead {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.75rem;
    line-height: 1.4;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
  }

  .context-plumbing-chevron {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
  }

  .context-plumbing-body {
    @apply mt-3 space-y-3;
  }

  .context-plumbing-meta {
    margin: 0;
    display: grid;
    gap: 0.45rem;
  }

  .context-plumbing-meta-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.75rem;
  }

  .context-plumbing-meta-row dt {
    flex-shrink: 0;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
  }

  .context-plumbing-meta-row dd {
    margin: 0;
    min-width: 0;
    text-align: right;
    overflow-wrap: anywhere;
    color: rgb(var(--shell-label, var(--color-surface-300)));
  }

  .context-cross-links {
    @apply mt-5 flex flex-wrap gap-2;
  }

  .context-nav-link {
    @apply inline-flex items-center rounded-full border border-surface-500/40 bg-surface-900/60 px-3 py-1.5 text-sm text-surface-200 transition hover:border-primary-500/35 hover:bg-primary-500/10 hover:text-surface-50;
  }

  .context-related-memory {
    @apply w-full rounded-lg border border-surface-500/35 bg-surface-900/45 px-3 py-2.5 text-left transition hover:border-primary-500/30 hover:bg-surface-800/70;
  }

  .context-related-memory-title {
    @apply line-clamp-2 text-sm leading-snug text-surface-100;
  }

  .context-related-memory-meta {
    @apply mt-1 truncate text-[11px] text-surface-500;
  }

  .context-list-whisper {
    @apply mb-2 px-2 text-[11px] text-surface-500;
  }

  .context-map-view {
    @apply flex h-full min-h-0 flex-1 flex-col;
    background-color: rgb(var(--color-surface-950) / 0.4);
  }

  .context-map-whisper {
    @apply shrink-0 border-b border-surface-500/35 px-4 py-2 text-[11px] leading-relaxed text-surface-400;
  }

  .context-map-stage {
    @apply relative min-h-0 flex-1 overflow-hidden;
  }

  .context-map-viewport {
    @apply relative h-full w-full touch-none select-none;
    cursor: grab;
  }

  .context-map-viewport-dragging {
    cursor: grabbing;
  }

  .context-map-viewport-pinching {
    cursor: zoom-in;
  }

  .context-map-controls {
    @apply absolute right-3 top-3 z-10 flex flex-col gap-1;
  }

  .context-map-control-btn {
    @apply flex h-7 w-7 items-center justify-center rounded-md border border-surface-500/45 bg-surface-900/85 text-sm text-surface-200 transition hover:bg-surface-800/90;
  }

  .context-map-control-clear {
    @apply border-primary-400/50 text-primary-200 hover:bg-primary-500/20;
  }

  .context-map-clear-link {
    @apply mt-2 text-left text-[10px] text-surface-500 underline-offset-2 hover:text-surface-300 hover:underline;
  }

  .context-map-hover-kind {
    @apply text-[10px] font-medium uppercase tracking-wide text-surface-500;
  }

  .context-map-hover-card-pinned {
    border-color: rgb(var(--color-primary-400) / 0.35);
  }

  .context-map-legend {
    @apply absolute bottom-3 left-3 z-10 flex flex-wrap gap-x-3 gap-y-1 rounded-lg border border-surface-500/40 px-3 py-2;
    background-color: rgb(var(--color-surface-900) / 0.88);
  }

  .context-map-legend-item {
    @apply flex items-center gap-1.5 text-[10px] text-surface-300;
  }

  .context-map-legend-item-planned {
    @apply text-surface-600;
  }

  .context-map-legend-swatch {
    @apply inline-block shrink-0;
  }

  .context-map-legend-swatch-session {
    @apply h-2.5 w-2.5 rounded-full;
    background: rgb(var(--color-primary-400) / 0.95);
    box-shadow: 0 0 0 1px rgb(var(--color-primary-300) / 0.75);
  }

  .context-map-legend-swatch-thread {
    @apply h-2 w-2 rounded-sm;
    background: rgb(var(--color-tertiary-400, var(--color-tertiary-500)) / 0.95);
    box-shadow: 0 0 0 1px rgb(var(--color-tertiary-300, var(--color-tertiary-500)) / 0.65);
  }

  .context-map-legend-swatch-claim {
    @apply h-2.5 w-2.5 rotate-45 rounded-[1px];
    background: rgb(var(--color-warning-400) / 0.72);
    box-shadow: 0 0 0 1px rgb(var(--color-warning-300) / 0.45);
  }

  .context-map-legend-swatch-note {
    @apply h-2 w-2 rounded-[2px];
    background: rgb(var(--color-secondary-400) / 0.72);
    box-shadow: 0 0 0 1px rgb(var(--color-secondary-300) / 0.45);
  }

  .context-map-svg {
    @apply block h-full w-full;
  }

  .context-map-backdrop {
    fill: rgb(var(--color-surface-900) / 0.32);
    pointer-events: none;
  }

  .context-map-edge {
    pointer-events: none;
  }

  .context-map-edge-session_chain {
    stroke: rgb(var(--color-surface-400) / 0.38);
    stroke-width: 1.15;
  }

  .context-map-edge-membership {
    stroke: rgb(var(--color-tertiary-400, var(--color-tertiary-500)) / 0.58);
    stroke-width: 1.35;
  }

  .context-map-edge-sequence {
    stroke: rgb(var(--color-primary-300) / 0.62);
    stroke-dasharray: 5 4;
    stroke-width: 1.25;
  }

  .context-map-edge-highlight {
    stroke: rgb(var(--color-primary-200) / 0.95) !important;
    stroke-width: 2.1 !important;
  }

  .context-map-edge-ghost {
    stroke-width: 1;
    opacity: 0.28;
  }

  .context-map-edge-dimmed {
    opacity: 0.12;
  }

  .context-map-edge-neighbor {
    opacity: 1;
  }

  .context-map-viewport-focused .context-map-edge-neighbor.context-map-edge-membership {
    stroke: rgb(var(--color-tertiary-300) / 0.82);
    stroke-width: 1.55;
  }

  .context-map-viewport-focused .context-map-edge-neighbor.context-map-edge-sequence {
    stroke: rgb(var(--color-primary-200) / 0.88);
    stroke-width: 1.5;
  }

  .context-map-viewport-focused .context-map-edge-neighbor.context-map-edge-session_chain {
    stroke: rgb(var(--color-surface-300) / 0.72);
    stroke-width: 1.35;
  }

  .context-map-hover-card {
    @apply pointer-events-none absolute left-3 top-3 z-10 max-w-[16rem] rounded-lg border border-surface-500/45 px-3 py-2;
    background-color: rgb(var(--color-surface-900) / 0.92);
  }

  .context-map-hover-title {
    @apply text-[12px] font-medium leading-snug text-surface-50;
  }

  .context-map-hover-meta {
    @apply mt-1 text-[10px] text-surface-400;
  }

  .context-map-hover-hint {
    @apply mt-1 text-[10px] text-surface-500;
  }

  .context-map-node {
    cursor: pointer;
    transition: opacity 160ms ease;
  }

  .context-map-node-dimmed .context-map-node-dot {
    opacity: 0.62;
  }

  .context-map-node-dimmed .context-map-node-glow {
    opacity: 0.4;
  }

  .context-map-node-neighbor .context-map-node-dot,
  .context-map-node-neighbor .context-map-node-glow {
    opacity: 1;
  }

  .context-map-node-ghost .context-map-node-dot-session {
    fill: rgb(var(--color-primary-400, var(--color-primary-500)) / 0.62);
    stroke: rgb(var(--color-primary-300, var(--color-primary-500)) / 0.55);
  }

  .context-map-node-ghost .context-map-node-dot-thread {
    fill: rgb(var(--color-tertiary-400, var(--color-tertiary-500)) / 0.58);
    stroke: rgb(var(--color-tertiary-300, var(--color-tertiary-500)) / 0.5);
  }

  .context-map-viewport-focused .context-map-node-neighbor.context-map-node-ghost .context-map-node-dot {
    opacity: 0.78;
  }

  .context-map-node-hovered .context-map-node-dot,
  .context-map-node-selected .context-map-node-dot,
  .context-map-node-hovered .context-map-node-glow,
  .context-map-node-selected .context-map-node-glow {
    opacity: 1;
  }

  .context-map-node-glow {
    stroke: transparent;
  }

  .context-map-node-glow-session {
    fill: rgb(var(--color-primary-400) / 0.22);
  }

  .context-map-node-glow-thread {
    fill: rgb(var(--color-tertiary-400) / 0.2);
  }

  .context-map-node-glow-selected {
    stroke: rgb(var(--color-primary-300) / 0.55);
    stroke-width: 1.5;
    fill: rgb(var(--color-primary-500) / 0.24);
  }

  .context-map-node-kind-thread .context-map-node-glow-selected {
    stroke: rgb(var(--color-tertiary-300) / 0.55);
    fill: rgb(var(--color-tertiary-500) / 0.22);
  }

  .context-map-node-glow-hover {
    stroke: rgb(var(--color-primary-300) / 0.42);
    stroke-width: 1;
    fill: rgb(var(--color-primary-500) / 0.18);
  }

  .context-map-node-kind-thread .context-map-node-glow-hover {
    stroke: rgb(var(--color-tertiary-300) / 0.42);
    fill: rgb(var(--color-tertiary-500) / 0.16);
  }

  .context-map-node-glow-expanded {
    stroke: rgb(var(--color-primary-300) / 0.38);
    stroke-width: 1;
    fill: rgb(var(--color-primary-500) / 0.14);
  }

  .context-map-node-dot {
    stroke-width: 1.75;
    transition: fill 160ms ease, stroke 160ms ease, opacity 160ms ease;
  }

  .context-map-node-dot-session {
    fill: rgb(var(--color-primary-400) / 0.96);
    stroke: rgb(var(--color-primary-300) / 0.92);
    stroke-width: 2.25;
  }

  .context-map-node-kind-session[data-accent="1"] .context-map-node-dot-session {
    fill: color-mix(
      in srgb,
      rgb(var(--color-primary-400, var(--color-primary-500))) 82%,
      rgb(var(--color-secondary-300, var(--color-secondary-500))) 18%
    );
    stroke: color-mix(
      in srgb,
      rgb(var(--color-primary-200, var(--color-primary-400))) 76%,
      rgb(var(--color-secondary-200, var(--color-secondary-500))) 24%
    );
  }

  .context-map-node-kind-session[data-accent="2"] .context-map-node-dot-session {
    fill: color-mix(
      in srgb,
      rgb(var(--color-primary-400, var(--color-primary-500))) 68%,
      rgb(var(--color-secondary-300, var(--color-secondary-500))) 32%
    );
    stroke: color-mix(
      in srgb,
      rgb(var(--color-primary-200, var(--color-primary-400))) 62%,
      rgb(var(--color-secondary-200, var(--color-secondary-500))) 38%
    );
  }

  .context-map-node-kind-session[data-accent="3"] .context-map-node-dot-session {
    fill: color-mix(
      in srgb,
      rgb(var(--color-primary-400, var(--color-primary-500))) 58%,
      rgb(var(--color-secondary-400, var(--color-secondary-500))) 42%
    );
    stroke: color-mix(
      in srgb,
      rgb(var(--color-primary-200, var(--color-primary-400))) 52%,
      rgb(var(--color-secondary-300, var(--color-secondary-500))) 48%
    );
  }

  .context-map-node-kind-session[data-accent="4"] .context-map-node-dot-session {
    fill: color-mix(
      in srgb,
      rgb(var(--color-primary-400, var(--color-primary-500))) 64%,
      rgb(var(--color-tertiary-300, var(--color-tertiary-500))) 36%
    );
    stroke: color-mix(
      in srgb,
      rgb(var(--color-primary-200, var(--color-primary-400))) 58%,
      rgb(var(--color-tertiary-200, var(--color-tertiary-500))) 42%
    );
  }

  .context-map-node-kind-session[data-accent="5"] .context-map-node-dot-session {
    fill: color-mix(
      in srgb,
      rgb(var(--color-primary-400, var(--color-primary-500))) 54%,
      rgb(var(--color-tertiary-400, var(--color-tertiary-500))) 46%
    );
    stroke: color-mix(
      in srgb,
      rgb(var(--color-primary-200, var(--color-primary-400))) 48%,
      rgb(var(--color-tertiary-300, var(--color-tertiary-500))) 52%
    );
  }

  .context-map-node-kind-session[data-accent="6"] .context-map-node-dot-session {
    fill: color-mix(
      in srgb,
      rgb(var(--color-primary-400, var(--color-primary-500))) 72%,
      rgb(var(--color-success-300, var(--color-success-500))) 28%
    );
    stroke: color-mix(
      in srgb,
      rgb(var(--color-primary-200, var(--color-primary-400))) 66%,
      rgb(var(--color-success-200, var(--color-success-500))) 34%
    );
  }

  .context-map-node-kind-session[data-accent="7"] .context-map-node-dot-session {
    fill: color-mix(
      in srgb,
      rgb(var(--color-primary-400, var(--color-primary-500))) 62%,
      rgb(var(--color-warning-300, var(--color-warning-500))) 38%
    );
    stroke: color-mix(
      in srgb,
      rgb(var(--color-primary-200, var(--color-primary-400))) 56%,
      rgb(var(--color-warning-200, var(--color-warning-500))) 44%
    );
  }

  .context-map-node-dot-thread {
    fill: color-mix(
      in srgb,
      rgb(var(--color-tertiary-400, var(--color-tertiary-500))) 76%,
      rgb(var(--color-surface-50)) 24%
    );
    stroke: rgb(var(--color-tertiary-200, var(--color-tertiary-500)) / 0.88);
    stroke-width: 1.5;
  }

  .context-map-node-dot-selected.context-map-node-dot-session {
    fill: rgb(var(--color-primary-300) / 0.98);
    stroke: rgb(var(--color-primary-100) / 0.95);
  }

  .context-map-node-dot-selected.context-map-node-dot-thread {
    fill: rgb(var(--color-tertiary-300) / 0.98);
    stroke: rgb(var(--color-tertiary-100) / 0.92);
  }

  .context-map-node-dot-hover {
    stroke-width: 2;
  }

  .context-map-node-dot-expanded {
    stroke-width: 2.5;
  }

  .context-map-node-label {
    @apply text-[10px];
    pointer-events: none;
    transition: opacity 140ms ease, fill 140ms ease;
  }

  .context-map-node-label-session {
    @apply text-[10px];
    font-family: inherit;
    font-weight: 500;
    paint-order: stroke fill;
    stroke: rgb(var(--color-surface-950) / 0.88);
    stroke-width: 2px;
  }

  .context-map-node-label-thread {
    @apply text-[10px] font-normal;
    font-family: inherit;
    paint-order: stroke fill;
    stroke: rgb(var(--color-surface-950) / 0.88);
    stroke-width: 2px;
  }

  .context-map-node-label-whisper {
    @apply fill-surface-300;
    opacity: 0.86;
  }

  .context-map-node-label-neighbor {
    @apply fill-surface-100;
    opacity: 0.94;
  }

  .context-map-node-label-hovered {
    @apply fill-surface-50 text-[11px];
    font-weight: 600;
    opacity: 1;
    stroke-width: 2.5px;
  }

  .context-map-node-label-selected {
    @apply fill-surface-50 text-[11px];
    font-weight: 600;
    opacity: 1;
    stroke-width: 3px;
  }

  .context-map-node-label-hidden {
    opacity: 0;
  }

  .context-posture-fingerprint {
    @apply workshop-inset p-4;
  }

  .context-posture-fingerprint-compact {
    @apply p-3;
  }

  .context-posture-psi-chip {
    @apply inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide;
    background-color: rgb(var(--color-primary-500) / 0.14);
    color: rgb(var(--color-primary-300));
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.24);
  }

  .context-posture-dim {
    @apply grid items-center gap-2;
    grid-template-columns: minmax(4.5rem, 5.5rem) 1fr 2.25rem;
  }

  .context-posture-dim-label {
    @apply text-[11px] text-surface-400;
  }

  .context-posture-dim-track {
    @apply h-1.5 overflow-hidden rounded-full bg-surface-800;
    box-shadow: inset 0 0 0 1px rgb(var(--color-surface-500) / 0.28);
  }

  .context-posture-dim-fill {
    @apply block h-full rounded-full;
    background: linear-gradient(
      90deg,
      rgb(var(--color-primary-500) / 0.55),
      rgb(var(--color-primary-300) / 0.95)
    );
  }

  .context-posture-dim-value {
    @apply text-right font-mono text-[11px] text-surface-300;
  }

  .workshop-status-whisper {
    @apply inline-flex min-w-0 items-center gap-1.5 truncate;
  }

  .workshop-status-dot {
    @apply h-1.5 w-1.5 shrink-0 rounded-full;
  }

  .workshop-status-dot-live {
    background-color: rgb(var(--color-primary-400) / 0.85);
    animation: workshop-status-pulse 3.2s ease-in-out infinite;
  }

  .workshop-status-dot-warning {
    background-color: rgb(var(--color-warning-400) / 0.85);
  }

  .workshop-status-dot-muted {
    @apply bg-surface-600;
  }

  @keyframes workshop-status-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgb(var(--color-primary-500) / 0.22);
    }
    50% {
      box-shadow: 0 0 0 3px rgb(var(--color-primary-500) / 0);
    }
  }

  .workshop-status--quiet {
    color: rgb(var(--color-surface-500));
  }

  .workshop-status--peek-open {
    z-index: 45;
  }

  .workshop-status-action {
    border: 0;
    background: transparent;
    padding: 0;
    color: rgb(var(--color-surface-500));
    font: inherit;
    transition: color 140ms ease;
  }

  .workshop-status-action:hover {
    color: rgb(var(--color-surface-200));
  }

  .workshop-status-spotlight {
    border: 1px solid rgb(var(--color-surface-700) / 0.45);
    border-radius: 0.3rem;
    background: transparent;
    padding: 0.1rem 0.35rem;
    color: rgb(var(--color-surface-500));
    font: inherit;
    transition: border-color 140ms ease, color 140ms ease;
  }

  .workshop-status-spotlight:hover {
    border-color: rgb(var(--color-surface-600) / 0.7);
    color: rgb(var(--color-surface-300));
  }

  .work-motion-control {
    position: relative;
    z-index: 45;
  }

  .work-motion-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 0;
    border-radius: 0.35rem;
    background: transparent;
    padding: 0.15rem 0.35rem;
    color: rgb(var(--color-surface-500));
    font: inherit;
    transition: color 160ms ease, background-color 160ms ease;
  }

  .work-motion-trigger:hover,
  .work-motion-trigger--open {
    background: rgb(var(--color-surface-800) / 0.55);
    color: rgb(var(--color-surface-200));
  }

  .work-motion-trigger--active {
    color: rgb(var(--color-surface-400));
  }

  .work-motion-icon--live {
    animation: work-motion-breath 2.8s ease-in-out infinite;
  }

  @keyframes work-motion-breath {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }

  .work-motion-attention {
    display: inline-flex;
    min-width: 1rem;
    height: 1rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgb(var(--color-warning-500) / 0.18);
    padding: 0 0.28rem;
    color: rgb(var(--color-warning-300) / 0.95);
    font-size: 0.62rem;
    font-weight: 650;
    font-variant-numeric: tabular-nums;
  }

  .work-motion-scrim {
    position: fixed;
    inset: 0;
    z-index: 44;
  }

  .work-motion-peek {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.45rem);
    z-index: 46;
    width: min(22rem, calc(100vw - 2rem));
    max-height: min(16rem, 40vh);
    overflow: auto;
    border: 1px solid rgb(var(--color-surface-500) / 0.28);
    border-radius: 0.65rem;
    background: rgb(var(--color-surface-900) / 0.97);
    padding: 0.45rem;
    box-shadow: 0 -8px 28px rgb(0 0 0 / 0.28);
  }

  .work-motion-peek-list {
    margin: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0;
  }

  .work-motion-peek-card {
    display: block;
    width: 100%;
    border: 0;
    border-radius: 0.5rem;
    background: rgb(var(--color-surface-800) / 0.45);
    padding: 0.45rem 0.55rem;
    text-align: left;
    transition: background-color 140ms ease;
  }

  .work-motion-peek-card:hover {
    background: rgb(var(--color-surface-800) / 0.75);
  }

  .work-motion-peek-card--selected {
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.35);
  }

  /* Library sidebar filter toggles — matches space chips */
  .vault-filter-chip {
    @apply inline-flex items-center rounded-full border border-surface-500/40 bg-surface-800/60 px-2.5 py-1 text-xs font-medium text-surface-300 transition-colors hover:bg-surface-700/80;
  }

  .vault-filter-chip-active {
    @apply border-primary-500/50 bg-primary-500/15 text-primary-200;
  }

  .vault-format-btn {
    @apply inline-flex h-8 w-8 items-center justify-center rounded-md text-surface-300 transition hover:bg-surface-700/80 hover:text-surface-50 disabled:opacity-40;
  }

  .vault-format-btn--active {
    @apply bg-primary-500/15 text-primary-200;
  }

  .vault-markdown-editor--write .vault-editor-textarea {
    @apply mx-auto max-w-3xl px-6 py-5 font-sans text-base leading-relaxed;
  }

  .vault-markdown-editor--source .vault-editor-textarea {
    @apply px-5 py-4 font-mono text-sm leading-7;
    tab-size: 2;
    -moz-tab-size: 2;
  }

  .vault-markdown-editor--write .vault-format-bar {
    @apply mx-auto w-full max-w-3xl border-b-0 bg-transparent px-6;
  }

  .vault-codemirror-host {
    @apply min-h-0 min-w-0 max-w-full flex-1 overflow-hidden;
    background-color: rgb(var(--color-surface-950));
  }

  .vault-codemirror-host .cm-editor {
    @apply h-full max-w-full outline-none;
    width: 100%;
  }

  .vault-codemirror-host .cm-scroller {
    max-width: 100%;
  }

  .vault-codemirror-host--write .cm-scroller {
    @apply font-sans text-base leading-relaxed;
  }

  .vault-codemirror-host--write .cm-content {
    @apply mx-auto max-w-3xl px-6 py-5;
  }

  .vault-codemirror-host--source .cm-scroller {
    @apply font-mono text-sm leading-7;
    tab-size: 2;
    -moz-tab-size: 2;
  }

  .vault-codemirror-host--source .cm-content {
    @apply px-5 py-4;
  }

  .vault-slash-menu {
    @apply z-[80] w-[min(100%-1rem,22rem)] overflow-hidden rounded-lg border border-primary-500/30 shadow-xl;
    background-color: rgb(var(--color-surface-900) / 0.97);
  }

  .vault-slash-menu--anchored {
    @apply absolute flex flex-col;
  }

  .vault-slash-menu:not(.vault-slash-menu--anchored) {
    @apply shrink-0 border-b border-primary-500/30 shadow-lg;
  }

  .vault-slash-menu-chrome {
    @apply flex shrink-0 items-center justify-between gap-2 px-3 py-1.5;
  }

  .vault-slash-menu-title {
    @apply text-[10px] font-medium uppercase tracking-wide text-primary-300;
  }

  .vault-slash-menu-hint {
    @apply text-[10px] text-surface-500;
  }

  .vault-slash-menu-list {
    @apply max-h-64 space-y-0.5 overflow-y-auto px-1.5 pb-2;
  }

  .vault-slash-menu--anchored .vault-slash-menu-list {
    @apply min-h-0 max-h-none flex-1;
  }

  .vault-slash-menu-section {
    @apply px-2.5 pb-0.5 pt-2 text-[10px] font-medium uppercase tracking-wide text-surface-500;
  }

  .vault-slash-menu-item {
    @apply flex w-full cursor-pointer items-center justify-between gap-2 rounded-md px-2.5 py-1.5 text-left text-sm text-surface-200 transition-colors hover:bg-surface-800;
  }

  .vault-slash-menu-item--active {
    @apply bg-primary-500/20 text-primary-100;
  }

  .vault-slash-menu-item-hint {
    @apply font-mono text-[10px] text-surface-500;
  }

  .vault-slash-menu-empty {
    @apply px-2.5 py-3 text-sm text-surface-500;
  }

  .vault-editor-textarea {
    @apply font-sans;
  }

  .vault-editor-textarea:focus {
    @apply outline-none ring-0;
  }

  .vault-browser-chrome {
    @apply shrink-0;
  }

  .vault-library-tabbar {
    @apply flex items-stretch gap-1 border-b border-surface-500/35 px-2;
  }

  .vault-library-tabbar-tabs {
    @apply flex min-w-0 flex-1;
  }

  .vault-library-toolbar {
    @apply flex items-center gap-1.5 px-3 py-2;
  }

  .vault-library-filter-menu {
    @apply min-w-[13rem] max-w-[min(16rem,calc(100vw-2rem))];
  }

  .vault-browse-mode-bar {
    @apply flex items-center gap-0.5 px-3 pb-2 pt-0;
  }

  .vault-browse-mode-bar--flush {
    @apply px-0 pb-0;
  }

  .vault-browse-mode-btn {
    @apply rounded-md px-2 py-0.5 text-[11px] font-medium tracking-wide text-surface-500 transition hover:bg-surface-700/50 hover:text-surface-200;
  }

  .vault-browse-mode-btn-active {
    @apply bg-surface-700/60 text-surface-100;
  }

  .vault-browse-mode-bar--quiet {
    @apply gap-2 px-3 pb-2 pt-0;
  }

  .vault-browse-mode-btn--quiet {
    @apply rounded-none bg-transparent px-0 py-0.5 text-[11px] font-normal tracking-normal hover:bg-transparent hover:text-surface-200;
  }

  .vault-browse-mode-btn-quiet-active {
    @apply bg-transparent text-surface-100;
  }

  .vault-dock-icon-btn {
    @apply inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md text-surface-400 transition hover:bg-surface-800/70 hover:text-surface-100;
  }

  .vault-dock-icon-btn-active {
    @apply text-primary-300;
  }

  .lme-dock-search-expand {
    @apply relative flex min-w-0 items-center;
    animation: lme-dock-search-in 160ms ease-out;
  }

  .lme-dock-search-glyph {
    @apply pointer-events-none absolute left-2 text-surface-500;
  }

  .lme-dock-search-input {
    @apply h-8 w-full rounded-md border border-surface-500/40 bg-surface-800/70 py-1 pl-7 pr-2 text-xs text-surface-100 outline-none transition placeholder:text-surface-500 focus:border-primary-500/40 focus:bg-surface-800;
  }

  @keyframes lme-dock-search-in {
    from {
      opacity: 0.55;
      transform: translateX(0.35rem);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .lme-scripts-popover {
    @apply flex flex-col overflow-hidden rounded-xl;
    border: 1px solid rgb(var(--color-surface-600) / 0.32);
    background: rgb(var(--color-surface-900) / 0.98);
    box-shadow:
      0 14px 36px rgb(0 0 0 / 0.36),
      0 0 0 1px rgb(0 0 0 / 0.12);
    backdrop-filter: blur(16px);
    animation: lme-scripts-popover-in 180ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes lme-scripts-popover-in {
    from {
      opacity: 0;
      transform: translateY(0.35rem) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .lme-scripts-popover-head {
    @apply flex items-start justify-between gap-2 border-b border-surface-700/35 px-3 py-2.5;
  }

  .lme-scripts-popover-title {
    @apply text-[11px] font-semibold tracking-[-0.01em] text-surface-100;
  }

  .lme-scripts-popover-blurb {
    @apply mt-0.5 text-[10px] leading-snug text-surface-500;
  }

  .lme-scripts-popover-head-icon {
    @apply mt-0.5 shrink-0 text-surface-500;
  }

  .lme-scripts-popover-wasm .lme-scripts-popover-title {
    @apply text-[13px] font-semibold tracking-[-0.02em] text-surface-50;
  }

  .lme-scripts-popover-search {
    @apply flex items-center gap-2 border-b border-surface-700/35 px-3 py-2.5;
  }

  .lme-scripts-popover-search-input {
    @apply min-w-0 flex-1 border-0 bg-transparent text-[12px] text-surface-100 placeholder:text-surface-500 focus:outline-none focus:ring-0;
  }

  .lme-scripts-popover-list {
    @apply max-h-64 overflow-y-auto py-1;
  }

  .lme-scripts-popover-item {
    animation: lme-scripts-popover-row-in 320ms cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--i, 0) * 28ms);
  }

  @keyframes lme-scripts-popover-row-in {
    from {
      opacity: 0;
      transform: translateY(0.25rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .lme-scripts-popover-row {
    @apply flex w-full items-start gap-2 px-3 py-2 text-left transition-colors;
  }

  .lme-scripts-popover-row:hover {
    background: rgb(var(--color-surface-800) / 0.55);
  }

  .lme-scripts-popover-row:hover .lme-scripts-popover-row-action {
    @apply opacity-100;
  }

  .lme-scripts-popover-row-title {
    @apply block truncate text-[12px] font-medium tracking-[-0.01em] text-surface-50;
  }

  .lme-scripts-popover-row-meta {
    @apply mt-0.5 block text-[10px] leading-snug text-surface-500;
  }

  .lme-scripts-popover-row-action {
    @apply shrink-0 rounded px-1.5 py-0.5 text-[10px] font-medium text-primary-300 opacity-0 transition;
    background: rgb(var(--color-primary-500) / 0.12);
  }

  .lme-scripts-popover-empty {
    @apply px-3 py-3 text-[11px] text-surface-500;
  }

  .lme-scripts-popover-fields {
    @apply flex flex-col gap-1.5 px-2.5 py-2.5;
  }

  .lme-scripts-popover-field,
  .lme-scripts-popover-field-btn {
    @apply flex w-full items-center gap-2.5 rounded-lg px-2.5 py-2 text-left transition;
    border: 1px solid rgb(var(--color-surface-600) / 0.28);
    background: rgb(var(--color-surface-800) / 0.42);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.03);
  }

  .lme-scripts-popover-field:hover,
  .lme-scripts-popover-field-btn:hover {
    border-color: rgb(var(--color-surface-600) / 0.42);
    background: rgb(var(--color-surface-800) / 0.62);
  }

  .lme-scripts-popover-field:focus-within {
    border-color: rgb(var(--color-primary-500) / 0.45);
    background: rgb(var(--color-surface-800) / 0.72);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.04),
      0 0 0 1px rgb(var(--color-primary-500) / 0.12);
  }

  .lme-scripts-popover-field-btn {
    @apply cursor-pointer;
  }

  .lme-scripts-popover-field-label {
    @apply w-[3.25rem] shrink-0 text-[10px] font-medium tracking-[-0.01em] text-surface-400;
  }

  .lme-scripts-popover-wasm .lme-scripts-popover-field-label {
    @apply normal-case text-surface-300;
  }

  .lme-scripts-popover-field-value,
  .lme-scripts-popover-field-input {
    @apply min-w-0 flex-1 border-0 bg-transparent text-[12px] tracking-[-0.01em] text-surface-100 placeholder:text-surface-500 focus:outline-none focus:ring-0;
  }

  .lme-scripts-popover-field-value.is-placeholder {
    @apply text-surface-500;
  }

  .lme-scripts-popover-wasm .lme-scripts-popover-field-value:not(.is-placeholder) {
    @apply font-medium text-surface-50;
  }

  .lme-scripts-popover-module-menu {
    @apply absolute left-1 right-1 top-full z-10 mt-0.5 max-h-36 overflow-y-auto rounded-lg py-1;
    border: 1px solid rgb(var(--color-surface-600) / 0.35);
    background: rgb(var(--color-surface-900) / 0.98);
    box-shadow: 0 10px 24px rgb(0 0 0 / 0.35);
  }

  .lme-scripts-popover-module-option {
    @apply w-full truncate px-2.5 py-1.5 text-left font-mono text-[11px] text-surface-200 transition-colors;
  }

  .lme-scripts-popover-module-option:hover,
  .lme-scripts-popover-module-option.is-active {
    background: rgb(var(--color-surface-800) / 0.65);
  }

  .lme-scripts-popover-module-option.is-active {
    @apply text-primary-200;
  }

  .lme-scripts-popover-status {
    @apply px-3 pb-1.5 text-[10px] text-surface-400;
  }

  .lme-scripts-popover-status.is-error {
    @apply text-error-400;
  }

  .lme-scripts-popover-footer {
    @apply flex items-center justify-between gap-2 border-t border-surface-700/35 px-2.5 py-2;
  }

  .lme-scripts-popover-footer-quiet {
    @apply inline-flex items-center gap-1 rounded px-1.5 py-1 text-[10px] text-surface-500 transition hover:bg-surface-800/55 hover:text-surface-300 disabled:opacity-40;
  }

  .lme-scripts-popover-load {
    @apply rounded-md px-3 py-1.5 text-[11px] font-semibold tracking-[-0.01em] text-primary-200 transition disabled:pointer-events-none disabled:opacity-40;
    border: 1px solid rgb(var(--color-primary-500) / 0.32);
    background: rgb(var(--color-primary-500) / 0.18);
  }

  .lme-scripts-popover-load:hover:not(:disabled) {
    border-color: rgb(var(--color-primary-500) / 0.45);
    background: rgb(var(--color-primary-500) / 0.28);
    color: rgb(var(--color-primary-100) / 1);
  }

  .lme-scripts-popover-load:disabled {
    border-color: rgb(var(--color-surface-600) / 0.28);
    background: rgb(var(--color-surface-800) / 0.5);
    color: rgb(var(--color-surface-500) / 1);
  }

  .lme-scripts-popover-lifecycle {
    @apply space-y-1.5 border-t border-surface-700/35 px-3 py-2;
  }

  .vault-notes-filter-menu {
    max-height: min(28rem, calc(100vh - 8rem));
    overflow-y: auto;
  }

  .vault-notes-filter-seg-btn {
    @apply rounded px-1 py-1.5 text-center text-[11px] font-medium text-surface-500 transition hover:text-surface-200;
  }

  .vault-notes-filter-seg-btn-active {
    @apply bg-surface-700/90 text-surface-100 shadow-sm;
  }

  .vault-sticky-shell {
    @apply overflow-hidden;
  }

  .vault-sticky-chrome {
    @apply flex shrink-0 items-center gap-2 border-b border-surface-500/30 bg-surface-900/70 px-2.5 py-1.5;
  }

  .vault-sticky-action {
    @apply rounded-md px-2 py-1 text-[11px] font-medium text-surface-400 transition hover:bg-surface-800/80 hover:text-surface-100;
  }

  .vault-sticky-icon {
    @apply inline-flex h-7 w-7 items-center justify-center rounded-md text-surface-400 transition hover:bg-surface-800/80 hover:text-surface-100;
  }

  .vault-sticky-action-active {
    @apply bg-primary-500/10 text-primary-200;
  }

  .vault-format-btn--float {
    @apply text-surface-500 opacity-70 hover:opacity-100;
  }

  .vault-toolbar-btn {
    @apply inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-surface-500/35 bg-surface-900/50 text-surface-400 transition hover:border-surface-500/55 hover:bg-surface-800/80 hover:text-surface-100 disabled:opacity-40;
  }

  .vault-toolbar-btn-active {
    @apply border-primary-500/40 bg-primary-500/10 text-primary-200;
  }

  .vault-toolbar-new {
    @apply inline-flex h-8 shrink-0 items-center gap-1 rounded-md px-2.5 text-xs font-medium;
  }

  .vault-space-chips-scroll {
    @apply flex flex-nowrap gap-1 overflow-x-auto pb-0.5;
    scrollbar-width: thin;
  }

  .vault-space-chips-scroll::-webkit-scrollbar {
    height: 4px;
  }

  .vault-space-chips-scroll::-webkit-scrollbar-thumb {
    @apply rounded-full bg-surface-600/60;
  }

  .vault-sidebar-tab {
    @apply -mb-px border-b-2 border-transparent px-3 py-2 text-xs font-medium text-surface-400 transition hover:text-surface-200;
  }

  .vault-sidebar-tab-active {
    @apply border-primary-400 text-primary-200;
  }

  .vault-search-trigger {
    @apply flex items-center gap-2 rounded-lg border border-surface-500/40 bg-surface-900/60 px-3 py-2 text-sm transition hover:border-surface-500/60 hover:bg-surface-800/80;
  }

  .vault-search-kbd {
    @apply rounded border border-surface-600/60 bg-surface-800/80 px-1.5 py-0.5 font-mono text-[10px] text-surface-500;
  }

  .vault-root-trigger {
    @apply inline-flex max-w-[10rem] items-center gap-1.5 rounded-md border border-surface-500/35 bg-surface-900/50 px-2 py-1 text-xs text-surface-200 transition hover:border-surface-500/55 hover:bg-surface-800/80;
  }

  .vault-root-trigger-fill {
    @apply h-8 w-full max-w-none py-0;
  }

  .vault-menu-item {
    @apply flex w-full items-center gap-2 px-3 py-2 text-left text-sm text-surface-100 transition hover:bg-surface-800/80;
  }

  .vault-interact-backdrop {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: rgb(var(--color-surface-950) / 0.78);
  }

  .vault-interact-sheet {
    width: 100%;
    max-width: 24rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.35);
    border-radius: 1rem;
    background: rgb(var(--color-surface-900) / 0.96);
    box-shadow: 0 18px 48px rgb(0 0 0 / 0.35);
    padding: 1rem 1rem 0.85rem;
  }

  .vault-interact-sheet--quiet {
    padding: 0.85rem 0.9rem 0.7rem;
    box-shadow: 0 12px 36px rgb(0 0 0 / 0.28);
  }

  .vault-interact-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
  }

  .vault-compose-header {
    margin-bottom: 0;
    min-height: 1.5rem;
  }

  .vault-interact-kicker {
    margin: 0;
    color: rgb(var(--color-surface-500));
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .vault-interact-title {
    margin: 0.1rem 0 0;
    color: rgb(var(--color-surface-50));
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .vault-interact-dismiss,
  .vault-interact-back {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: 0;
    border-radius: 0.45rem;
    background: transparent;
    padding: 0.28rem 0.45rem;
    color: rgb(var(--color-surface-450, var(--color-surface-500)));
    font-size: 0.72rem;
    font-weight: 500;
  }

  .vault-interact-dismiss:hover,
  .vault-interact-back:hover {
    background: rgb(var(--color-surface-800) / 0.55);
    color: rgb(var(--color-surface-100));
  }

  .vault-verb-list,
  .vault-verb-danger {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .vault-verb-danger {
    margin-top: 0.4rem;
    border-top: 1px solid rgb(var(--color-surface-500) / 0.22);
    padding-top: 0.35rem;
  }

  .vault-verb {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 0.55rem;
    border: 0;
    border-radius: 0.5rem;
    background: transparent;
    padding: 0.48rem 0.55rem;
    color: rgb(var(--color-surface-150, var(--color-surface-100)));
    text-align: left;
  }

  .vault-verb:hover:not(:disabled) {
    background: rgb(var(--color-surface-800) / 0.5);
  }

  .vault-verb:disabled {
    opacity: 0.4;
  }

  .vault-verb-icon {
    display: inline-flex;
    width: 1.1rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-surface-500));
  }

  .vault-verb:hover:not(:disabled) .vault-verb-icon {
    color: rgb(var(--color-surface-300));
  }

  .vault-verb-label {
    flex: 1;
    min-width: 0;
    font-size: 0.86rem;
    font-weight: 500;
  }

  .vault-verb--danger {
    color: rgb(var(--color-error-300, 252 165 165));
  }

  .vault-verb--danger .vault-verb-icon {
    color: inherit;
    opacity: 0.75;
  }

  .vault-verb--danger:hover:not(:disabled) {
    background: rgb(var(--color-error-500) / 0.1);
  }

  .vault-interact-editor {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 0.15rem 0.15rem 0.35rem;
  }

  .vault-interact-prompt {
    margin: 0;
    color: rgb(var(--color-surface-100));
    font-size: 0.95rem;
    font-weight: 600;
  }

  .vault-interact-field {
    width: 100%;
    border: 1px solid rgb(var(--color-surface-500) / 0.4);
    border-radius: 0.65rem;
    background: rgb(var(--color-surface-950) / 0.45);
    padding: 0.7rem 0.85rem;
    color: rgb(var(--color-surface-50));
    font-size: 0.95rem;
    outline: none;
  }

  .vault-interact-field:focus {
    border-color: rgb(var(--color-primary-400) / 0.45);
  }

  .vault-interact-field--mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
  }

  .vault-interact-note {
    margin: 0;
    color: rgb(var(--color-surface-500));
    font-size: 0.72rem;
    line-height: 1.4;
  }

  .vault-interact-commit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    border: 0;
    border-radius: 0.65rem;
    background: rgb(var(--color-primary-500) / 0.88);
    padding: 0.55rem 0.95rem;
    color: rgb(var(--color-surface-950));
    font-size: 0.85rem;
    font-weight: 650;
  }

  .vault-interact-commit:hover:not(:disabled) {
    background: rgb(var(--color-primary-400));
  }

  .vault-interact-commit:disabled {
    opacity: 0.45;
  }

  .vault-interact-commit--danger {
    background: rgb(var(--color-error-500) / 0.9);
    color: white;
  }

  .vault-compose-sheet {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 26rem;
    padding-top: 0.7rem;
  }

  .vault-compose-title {
    width: 100%;
    border: 0;
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.28);
    border-radius: 0;
    background: transparent;
    padding: 0.15rem 0.05rem 0.55rem;
    color: rgb(var(--color-surface-50));
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    outline: none;
    box-shadow: none;
  }

  .vault-compose-title::placeholder {
    color: rgb(var(--color-surface-550, var(--color-surface-500)) / 0.72);
    font-size: 0.95rem;
    font-weight: 450;
    letter-spacing: 0;
  }

  .vault-compose-title:focus {
    border-bottom-color: rgb(var(--color-surface-400) / 0.55);
    outline: none;
    box-shadow: none;
  }

  .vault-compose-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .vault-compose-sentence {
    margin: 0;
    color: rgb(var(--color-surface-450, var(--color-surface-500)));
    font-size: 0.8rem;
    line-height: 1.55;
  }

  .vault-compose-em {
    color: rgb(var(--color-surface-200));
    font-weight: 600;
  }

  .vault-compose-em-btn {
    display: inline;
    border: 0;
    border-radius: 0.25rem;
    background: transparent;
    padding: 0 0.1rem;
    color: rgb(var(--color-surface-150, var(--color-surface-100)));
    font: inherit;
    font-weight: 650;
    text-decoration: underline;
    text-decoration-color: rgb(var(--color-surface-500) / 0.45);
    text-underline-offset: 0.18em;
  }

  .vault-compose-em-btn:hover,
  .vault-compose-em-btn--open {
    color: rgb(var(--color-primary-200));
    text-decoration-color: rgb(var(--color-primary-400) / 0.55);
  }

  .vault-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    animation: vault-chip-in 140ms ease-out;
  }

  @keyframes vault-chip-in {
    from {
      opacity: 0;
      transform: translateY(-2px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .vault-chip {
    border: 1px solid rgb(var(--color-surface-500) / 0.3);
    border-radius: 999px;
    background: transparent;
    padding: 0.24rem 0.62rem;
    color: rgb(var(--color-surface-300));
    font-size: 0.7rem;
    font-weight: 550;
  }

  .vault-chip:hover {
    border-color: rgb(var(--color-surface-400) / 0.5);
    background: rgb(var(--color-surface-800) / 0.4);
    color: rgb(var(--color-surface-100));
  }

  .vault-chip--active {
    border-color: rgb(var(--color-primary-500) / 0.4);
    background: rgb(var(--color-primary-500) / 0.14);
    color: rgb(var(--color-primary-100));
  }

  .vault-chip--yours {
    border-style: dashed;
  }

  .vault-chip--more {
    border-style: dashed;
    color: rgb(var(--color-surface-450, var(--color-surface-500)));
  }

  .vault-compose-manage {
    align-self: flex-start;
    border: 0;
    background: transparent;
    padding: 0;
    color: rgb(var(--color-surface-500));
    font-size: 0.68rem;
    font-weight: 500;
  }

  .vault-compose-manage:hover {
    color: rgb(var(--color-surface-200));
  }

  .vault-compose-manage-list {
    margin: 0;
    list-style: none;
    border: 1px solid rgb(var(--color-surface-500) / 0.3);
    border-radius: 0.65rem;
    padding: 0.35rem 0.55rem;
  }

  .vault-compose-manage-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.3rem 0;
    color: rgb(var(--color-surface-200));
    font-size: 0.72rem;
  }

  .vault-compose-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-top: 0.15rem;
  }

  .vault-compose-footer .vault-interact-commit {
    align-self: auto;
  }

  .vault-bridge-sheet {
    max-width: 28rem;
  }

  .vault-bridge-section {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .vault-bridge-body {
    min-height: 4.5rem;
    resize: vertical;
    line-height: 1.45;
  }

  .ledger-col-meta-btn {
    display: inline-flex;
    width: 1.15rem;
    height: 1.15rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 0.3rem;
    background: transparent;
    color: rgb(var(--color-surface-500));
    opacity: 0;
    transition: opacity 120ms ease, background-color 120ms ease, color 120ms ease;
  }

  .ledger-header-edit:hover .ledger-col-meta-btn,
  .ledger-header-edit:focus-within .ledger-col-meta-btn,
  .ledger-col-meta-btn--open {
    opacity: 1;
  }

  .ledger-col-meta-btn:hover,
  .ledger-col-meta-btn--open {
    background: rgb(var(--color-surface-700) / 0.85);
    color: rgb(var(--color-surface-100));
  }

  .ledger-col-meta-panel {
    position: absolute;
    top: calc(100% + 0.25rem);
    left: 0;
    z-index: 8;
    display: flex;
    min-width: 14rem;
    max-width: min(18rem, 70vw);
    flex-direction: column;
    gap: 0.4rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.4);
    border-radius: 0.65rem;
    background: rgb(var(--color-surface-900) / 0.98);
    padding: 0.55rem 0.6rem;
    box-shadow: 0 10px 28px rgb(0 0 0 / 0.3);
  }

  .ledger-col-meta-label {
    margin: 0;
    color: rgb(var(--color-surface-500));
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ledger-col-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .ledger-col-swatch {
    width: 1.05rem;
    height: 1.05rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.35);
    border-radius: 999px;
    background: var(--swatch);
  }

  .ledger-col-swatch--active {
    box-shadow: 0 0 0 2px rgb(var(--color-surface-900)), 0 0 0 3px var(--swatch);
  }

  .vault-attachment-link {
    @apply inline-flex items-center gap-1.5 text-surface-400 transition hover:text-primary-200 disabled:opacity-40;
  }

  .vault-linked-files-menu {
    @apply min-w-[14rem] max-w-[min(18rem,calc(100vw-2rem))];
  }

  .vault-linked-file-row {
    @apply flex items-center gap-0.5 px-1;
  }

  .vault-linked-file-main {
    @apply flex min-w-0 flex-1 items-center gap-2 rounded-md px-2 py-1.5 text-left text-sm text-surface-100 transition hover:bg-surface-800/80;
  }

  .vault-external-pin-row {
    @apply flex items-center gap-1.5 rounded-container-token px-2 py-1.5 text-left transition hover:bg-surface-700/70;
  }

  .vault-external-file-row {
    @apply block px-2 py-1.5;
  }

  .vault-external-file-link {
    @apply inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-primary-300 hover:bg-surface-800/80 hover:text-primary-200;
  }

  .vault-linked-file-action {
    @apply inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-surface-500 transition hover:bg-surface-800/80 hover:text-surface-200 disabled:opacity-40;
  }

  .ledger-mode-toggle {
    @apply inline-flex rounded-md border border-surface-500/40 bg-surface-900/50 p-0.5;
  }

  .ledger-mode-btn {
    @apply rounded px-2 py-0.5 text-[11px] font-medium text-surface-400 transition hover:text-surface-200 disabled:opacity-40;
  }

  .ledger-mode-btn-active {
    @apply bg-primary-500/15 text-primary-200;
  }

  .ledger-toolbar-label {
    color: rgb(var(--color-surface-500));
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ledger-sheet-controls {
    display: flex;
    min-width: 12rem;
    flex-direction: column;
    gap: 0.35rem;
  }

  .ledger-filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
  }

  .ledger-filter-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid transparent;
    border-radius: 0.45rem;
    background: transparent;
    padding: 0.28rem 0.55rem;
    color: rgb(var(--color-surface-400));
    font-size: 0.72rem;
    font-weight: 550;
  }

  .ledger-filter-toggle:hover:not(:disabled) {
    background: rgb(var(--color-surface-800) / 0.55);
    color: rgb(var(--color-surface-100));
  }

  .ledger-filter-toggle--open,
  .ledger-filter-toggle--active {
    border-color: rgb(var(--color-primary-500) / 0.35);
    background: rgb(var(--color-primary-500) / 0.12);
    color: rgb(var(--color-primary-200));
  }

  .ledger-filter-badge {
    display: inline-flex;
    min-width: 1.1rem;
    height: 1.1rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgb(var(--color-primary-500) / 0.35);
    padding: 0 0.28rem;
    color: rgb(var(--color-primary-100));
    font-size: 0.62rem;
    font-weight: 650;
    font-variant-numeric: tabular-nums;
  }

  .ledger-filter-composer {
    display: inline-flex;
    max-width: 100%;
    align-items: stretch;
    overflow: hidden;
    border: 1px solid rgb(var(--color-surface-500) / 0.4);
    border-radius: 0.5rem;
    background: rgb(var(--color-surface-900) / 0.7);
  }

  .ledger-filter-composer .ledger-filter-select,
  .ledger-filter-composer .ledger-filter-input {
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .ledger-filter-composer .ledger-filter-select {
    border-right: 1px solid rgb(var(--color-surface-500) / 0.28);
    padding: 0.32rem 0.5rem;
    color: rgb(var(--color-surface-100));
    font-size: 0.72rem;
  }

  .ledger-filter-composer .ledger-filter-op {
    width: 2.75rem;
    flex-shrink: 0;
    text-align: center;
  }

  .ledger-filter-composer .ledger-filter-input {
    min-width: 5.5rem;
    width: 7.5rem;
    padding: 0.32rem 0.55rem;
    color: rgb(var(--color-surface-100));
    font-size: 0.72rem;
  }

  .ledger-filter-composer .ledger-filter-input::placeholder {
    color: rgb(var(--color-surface-500));
  }

  .ledger-filter-commit {
    display: inline-flex;
    width: 1.85rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border: 0;
    border-left: 1px solid rgb(var(--color-surface-500) / 0.28);
    background: rgb(var(--color-surface-800) / 0.45);
    color: rgb(var(--color-surface-200));
  }

  .ledger-filter-commit:hover:not(:disabled) {
    background: rgb(var(--color-primary-500) / 0.22);
    color: rgb(var(--color-primary-100));
  }

  .ledger-filter-commit:disabled {
    opacity: 0.35;
  }

  .ledger-filter-clear {
    border: 0;
    border-radius: 0.4rem;
    background: transparent;
    padding: 0.28rem 0.45rem;
    color: rgb(var(--color-surface-400));
    font-size: 0.7rem;
    font-weight: 500;
  }

  .ledger-filter-clear:hover:not(:disabled) {
    background: rgb(var(--color-surface-800) / 0.55);
    color: rgb(var(--color-surface-100));
  }

  .ledger-filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .ledger-filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    border: 0;
    border-radius: 999px;
    background: rgb(var(--color-primary-500) / 0.14);
    padding: 0.18rem 0.45rem;
    color: rgb(var(--color-primary-200));
    font-size: 0.65rem;
    font-weight: 500;
  }

  .ledger-filter-chip--sort {
    background: rgb(var(--color-surface-700) / 0.55);
    color: rgb(var(--color-surface-200));
  }

  .ledger-copy-csv {
    display: inline-flex;
    margin-left: auto;
    align-items: center;
    gap: 0.35rem;
    border: 0;
    border-radius: 0.4rem;
    background: transparent;
    padding: 0.28rem 0.5rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.68rem;
    font-weight: 500;
  }

  .ledger-copy-csv:hover:not(:disabled) {
    background: rgb(var(--color-surface-800) / 0.45);
    color: rgb(var(--color-surface-200));
  }

  .ledger-view-status {
    margin: 0;
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.25);
    padding: 0.35rem 1rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.68rem;
  }

  .ledger-empty-view {
    padding: 1.25rem 0.75rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.78rem;
    text-align: center;
  }

  .ledger-table {
    --ledger-gutter-width: 2.15rem;
  }

  .ledger-header-row {
    color: rgb(var(--color-surface-500));
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ledger-gutter-head,
  .ledger-gutter {
    position: sticky;
    left: 0;
    z-index: 2;
    width: var(--ledger-gutter-width);
    min-width: var(--ledger-gutter-width);
    background: rgb(var(--color-surface-900) / 0.92);
    text-align: center;
  }

  .ledger-gutter-head {
    z-index: 3;
    padding: 0.35rem 0.2rem;
    color: rgb(var(--color-surface-550, var(--color-surface-500)));
  }

  .ledger-gutter-btn {
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 0.3rem;
    background: transparent;
    padding: 0.45rem 0.15rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.68rem;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    cursor: pointer;
  }

  .ledger-gutter-btn:hover:not(:disabled) {
    background: rgb(var(--color-surface-800) / 0.7);
    color: rgb(var(--color-surface-200));
  }

  .ledger-gutter-btn[aria-pressed="true"] {
    background: rgb(var(--color-primary-500) / 0.18);
    color: rgb(var(--color-primary-200));
  }

  .ledger-header-cell {
    position: relative;
    padding: 0.15rem 0.15rem 0.35rem;
    vertical-align: bottom;
  }

  .ledger-header-cell--sorted {
    color: rgb(var(--color-primary-200));
  }

  .ledger-header-sort {
    display: inline-flex;
    width: 100%;
    min-width: 4.5rem;
    align-items: center;
    gap: 0.25rem;
    border: 0;
    border-radius: 0.3rem;
    background: transparent;
    padding: 0.25rem 0.45rem;
    color: inherit;
    font-size: 0.65rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: inherit;
  }

  .ledger-header-sort:hover:not(:disabled) {
    background: rgb(var(--color-surface-800) / 0.4);
    color: rgb(var(--color-surface-100));
  }

  .ledger-header-sort--active {
    color: rgb(var(--color-primary-200));
  }

  .ledger-header-sort-label {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ledger-header-sort.text-right {
    justify-content: flex-end;
  }

  .ledger-header-sort.text-center {
    justify-content: center;
  }

  .ledger-col-resize {
    position: absolute;
    top: 0;
    right: -3px;
    z-index: 2;
    width: 8px;
    height: 100%;
    border: 0;
    background: transparent;
    cursor: col-resize;
  }

  .ledger-col-resize:hover,
  .ledger-sheet--resizing .ledger-col-resize {
    background: linear-gradient(
      90deg,
      transparent 2px,
      rgb(var(--color-primary-400) / 0.55) 2px,
      rgb(var(--color-primary-400) / 0.55) 4px,
      transparent 4px
    );
  }

  .ledger-sheet--resizing {
    cursor: col-resize;
    user-select: none;
  }

  .ledger-col-gutter {
    width: var(--ledger-gutter-width);
  }

  .ledger-col-add,
  .ledger-col-actions {
    width: 2rem;
  }

  .ledger-header-date {
    width: 7.5rem;
    min-width: 6.5rem;
  }

  .ledger-header-edit {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .ledger-header-input {
    width: 100%;
    min-width: 4.5rem;
    border: 0;
    border-radius: 0.3rem;
    background: transparent;
    padding: 0.25rem 0.45rem;
    color: rgb(var(--color-surface-400));
    font-size: 0.65rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    outline: none;
  }

  .ledger-header-input:hover:not(:disabled):not(:focus) {
    background: rgb(var(--color-surface-800) / 0.35);
    color: rgb(var(--color-surface-200));
  }

  .ledger-header-input:focus {
    background: rgb(var(--color-surface-800) / 0.55);
    color: rgb(var(--color-surface-100));
    box-shadow: inset 0 -1px 0 rgb(var(--color-primary-400) / 0.55);
  }

  .ledger-col-remove {
    display: inline-flex;
    width: 1.15rem;
    height: 1.15rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 0.3rem;
    background: transparent;
    color: rgb(var(--color-surface-500));
    opacity: 0;
    transition: opacity 120ms ease, background-color 120ms ease, color 120ms ease;
  }

  .ledger-header-edit:hover .ledger-col-remove,
  .ledger-header-edit:focus-within .ledger-col-remove {
    opacity: 1;
  }

  .ledger-col-remove:hover {
    background: rgb(var(--color-surface-700) / 0.85);
    color: rgb(var(--color-surface-100));
  }

  .ledger-add-col-head,
  .ledger-add-col-spacer {
    width: 2rem;
    min-width: 2rem;
    padding: 0.2rem;
  }

  .ledger-add-col {
    display: inline-flex;
    width: 1.6rem;
    height: 1.6rem;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 0.35rem;
    background: transparent;
    color: rgb(var(--color-surface-500));
  }

  .ledger-add-col:hover:not(:disabled) {
    background: rgb(var(--color-primary-500) / 0.14);
    color: rgb(var(--color-primary-200));
  }

  .ledger-row-actions-head,
  .ledger-row-actions {
    width: 1.75rem;
    min-width: 1.75rem;
    padding: 0.15rem;
    text-align: right;
  }

  .ledger-table .ledger-row:hover {
    background: rgb(var(--color-surface-800) / 0.28);
  }

  .ledger-table .ledger-row:hover .ledger-gutter {
    background: rgb(var(--color-surface-850, var(--color-surface-800)) / 0.95);
  }

  .ledger-row--selected {
    background: rgb(var(--color-primary-500) / 0.1) !important;
  }

  .ledger-row--selected .ledger-gutter {
    background: rgb(var(--color-surface-900) / 0.98);
  }

  .ledger-cell {
    width: 100%;
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0.5rem 0.55rem;
    color: rgb(var(--color-surface-100));
    font-size: 0.8125rem;
    line-height: 1.35;
    outline: none;
    box-shadow: none;
  }

  .ledger-cell:hover:not(:disabled):not(:focus) {
    background: rgb(var(--color-surface-800) / 0.25);
  }

  .ledger-cell:focus {
    background: rgb(var(--color-surface-800) / 0.45);
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-400) / 0.45);
  }

  .ledger-row-remove {
    display: inline-flex;
    height: 1.4rem;
    width: 1.4rem;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 0.3rem;
    background: transparent;
    color: rgb(var(--color-surface-600));
    opacity: 0;
    transition: opacity 120ms ease, background-color 120ms ease, color 120ms ease;
  }

  .ledger-row:hover .ledger-row-remove,
  .ledger-row:focus-within .ledger-row-remove,
  .ledger-row--selected .ledger-row-remove {
    opacity: 1;
  }

  .ledger-row-remove:hover {
    background: rgb(var(--color-surface-700) / 0.85);
    color: rgb(var(--color-surface-200));
  }

  .ledger-add-row {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.65rem;
    border: 0;
    border-radius: 0.4rem;
    background: transparent;
    padding: 0.35rem 0.45rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.72rem;
    font-weight: 500;
  }

  .ledger-add-row:hover:not(:disabled) {
    background: rgb(var(--color-surface-800) / 0.4);
    color: rgb(var(--color-surface-200));
  }

  /* Inset cards and settings blocks */
  .workshop-inset {
    @apply rounded-md border border-surface-500/40 bg-surface-800/80;
  }

  /* Large display numbers (home, metrics) */
  .workshop-display {
    @apply text-4xl font-semibold tabular-nums tracking-tight text-surface-50;
  }

  /* Quiet text actions — color from workshop-shell (--shell-muted) */
  .workshop-text-action {
    @apply text-xs transition;
  }

  /* Native-style underline tabs — colors from workshop-shell */
  .workshop-tabs {
    @apply flex gap-0 border-b border-surface-500/40;
  }

  .workshop-tab {
    @apply -mb-px border-b-2 border-transparent px-2.5 py-1.5 text-xs transition;
  }

  .workshop-tab-active {
    @apply border-primary-400;
  }

  /* Instrument readout row */
  .workshop-telemetry {
    @apply flex flex-wrap items-baseline gap-x-5 gap-y-1 border-b border-surface-500/40 py-2.5 font-mono text-xs;
  }

  .workshop-telemetry dt {
    @apply text-[10px] uppercase tracking-wide text-surface-500;
  }

  .workshop-telemetry dd {
    @apply ml-1.5 tabular-nums text-surface-100;
  }

  /* Flat kanban rows */
  .workshop-kanban-card {
    @apply w-full border-l-2 bg-surface-800/60 px-2.5 py-2 text-left transition hover:bg-surface-700/50;
  }

  /* Skeleton card variant (legacy — prefer workshop-kanban-card) */
  .card {
    @apply border-surface-500/40 bg-surface-800/80;
  }

  .input,
  .textarea,
  .select {
    @apply border-surface-500/50 bg-surface-800 text-surface-50 placeholder:text-surface-400;
  }

  .checkbox {
    @apply border-surface-500/55;
  }

  /* Text hierarchy — colors from workshop-shell.postcss (--shell-whisper/label/muted) */
  .workshop-section-title {
    @apply text-xs font-semibold uppercase tracking-wide;
  }

  .workshop-label {
    @apply text-xs;
  }

  .workshop-muted {
    @apply text-sm;
  }

  .workshop-faint {
    @apply text-xs;
  }

  .session-sidebar-header {
    @apply flex items-center justify-between gap-2 border-b border-surface-500/40 px-3 py-2.5;
  }

  .session-sidebar-icon-btn {
    @apply inline-flex h-7 w-7 items-center justify-center rounded-md text-surface-400 transition hover:bg-surface-700/70 hover:text-surface-100;
  }

  .session-sidebar-toolbar {
    @apply flex items-center gap-1.5 border-b border-surface-500/35 px-2.5 py-2;
  }

  .session-sidebar-toolbar--sheet {
    @apply px-3;
  }

  .session-sidebar-search {
    @apply flex min-w-0 flex-1 items-center gap-2 rounded-md px-2 py-1.5 transition;
    background-color: rgb(var(--color-surface-900) / 0.45);
  }

  .session-sidebar-search:focus-within {
    background-color: rgb(var(--color-surface-800) / 0.65);
  }

  .session-sidebar-search-icon {
    @apply shrink-0 text-surface-500;
  }

  .session-sidebar-search-input {
    @apply min-w-0 flex-1 border-0 bg-transparent p-0 text-[13px] text-surface-100 placeholder:text-surface-500 focus:outline-none focus:ring-0;
  }

  .session-sidebar-search-input::-webkit-search-cancel-button,
  .session-sidebar-search-input::-webkit-search-decoration {
    -webkit-appearance: none;
  }

  .session-sidebar-new {
    @apply inline-flex h-8 shrink-0 items-center gap-1 rounded-md px-2 text-xs font-medium text-surface-400 transition hover:bg-surface-700/60 hover:text-surface-100;
  }

  .session-sidebar-new-label {
    @apply hidden sm:inline;
  }

  .session-sidebar-list {
    @apply flex min-h-0 flex-1 flex-col gap-3 overflow-y-auto p-2;
  }

  .session-sidebar-section-title {
    @apply px-2 pb-1 text-[10px] font-semibold uppercase tracking-wide text-surface-500;
  }

  .session-sidebar-section-list {
    @apply space-y-0.5;
  }

  .session-sidebar-empty {
    @apply px-3 py-8 text-center text-xs leading-relaxed text-surface-400;
  }

  .session-row {
    @apply flex items-stretch rounded-md transition;
  }

  .session-row:hover,
  .session-row:focus-within {
    @apply bg-surface-700/50;
  }

  .session-row-active {
    @apply bg-surface-700/70;
  }

  .session-row-active:hover,
  .session-row-active:focus-within {
    @apply bg-surface-700/80;
  }

  .session-row-main {
    @apply min-w-0 flex-1 px-2.5 py-1.5 text-left;
  }

  .session-row-title {
    @apply text-[13px] font-medium text-surface-100;
  }

  .session-row-when {
    @apply text-[10px] tabular-nums text-surface-500;
  }

  .session-row-meta {
    @apply mt-0.5 text-[10px] text-surface-500;
  }

  .session-row-actions {
    @apply flex shrink-0 items-center gap-0 opacity-0 transition-opacity;
  }

  .session-row:hover .session-row-actions,
  .session-row:focus-within .session-row-actions,
  .session-row--touch .session-row-actions {
    @apply opacity-100;
  }

  .session-row-action {
    @apply inline-flex h-7 w-7 items-center justify-center rounded-md text-surface-500 transition hover:bg-surface-800 hover:text-surface-200;
  }

  .session-row-action--danger:hover {
    @apply text-error-300;
  }

  .session-row-action--pinned {
    @apply text-amber-400;
  }

  .session-row-action--pinned:hover {
    @apply text-amber-300;
  }

  /* Side drawers (sessions, identity) */
  .workshop-drawer {
    @apply border-surface-500/50 bg-surface-800 shadow-xl;
  }

  .workshop-composer {
    @apply shrink-0 border-t border-surface-500/25 px-4 py-3 backdrop-blur-md;
    background-color: rgb(var(--color-surface-950) / 0.5);
  }

  .duet-stage-whisper {
    @apply text-[11px] italic leading-snug text-surface-600/90;
  }

  .chat-pane {
    @apply relative flex min-h-0 min-w-0 flex-1 flex-col bg-surface-900;
  }

  .chat-body {
    @apply relative min-h-0 flex-1;
  }

  .chat-scroll {
    @apply h-full overflow-y-auto px-8 py-5;
    scrollbar-gutter: stable;
  }

  .chat-scroll-fade {
    @apply pointer-events-none absolute inset-x-0 bottom-0 z-[1] h-12;
    background: linear-gradient(
      to top,
      rgb(var(--color-surface-900)),
      rgb(var(--color-surface-900) / 0)
    );
  }

  .chat-turn-break {
    @apply mt-7;
  }

  .chat-turn-beat {
    @apply w-full min-w-0;
  }

  .chat-voice {
    @apply max-w-[min(100%,44rem)] text-[15px] leading-[1.65] text-surface-100;
  }

  .chat-voice-full {
    @apply max-w-full w-full;
  }

  .chat-voice .markdown-content {
    @apply text-[15px] leading-[1.65];
  }

  /* Timeline shell: prose keeps a soft measure; embeds use the full column */
  .chat-voice-full .markdown-content > p,
  .chat-voice-full .markdown-content > ul,
  .chat-voice-full .markdown-content > ol {
    max-width: min(100%, 44rem);
  }

  .chat-user-bubble {
    @apply ml-auto max-w-[min(100%,30rem)] rounded-2xl rounded-br-md border border-surface-600/20 bg-surface-800/50 px-4 py-2.5 text-sm leading-relaxed text-surface-100;
  }

  .chat-user-bubble-compact {
    @apply max-w-[min(100%,26rem)] px-3 py-2 text-[13px];
  }

  .chat-voice-compact {
    @apply max-w-[min(100%,36rem)] text-sm leading-relaxed;
  }

  .chat-voice-full.chat-voice-compact {
    @apply max-w-full;
  }

  /* Quiet promote — visible on hover/focus within the assistant beat */
  .chat-save-to-library {
    @apply absolute right-0 top-0 z-[1] text-[10px] opacity-0 transition-opacity duration-200;
  }

  .group:hover .chat-save-to-library,
  .group:focus-within .chat-save-to-library {
    @apply opacity-100;
  }

  .chat-save-to-library:focus-visible {
    @apply opacity-100 outline-none;
  }

  .chat-ask-rail {
    @apply mb-8 border-b pb-8;
    border-color: rgb(var(--color-surface-700) / 0.4);
  }

  .chat-ask-rail-header {
    @apply mb-4;
  }

  .chat-ask-thread {
    @apply rounded-2xl border p-4;
    border-color: rgb(var(--color-surface-700) / 0.35);
    background-color: rgb(var(--color-surface-950) / 0.4);
  }

  .chat-ask-thread-header {
    @apply mb-4 flex items-start justify-between gap-3 border-b pb-3;
    border-color: rgb(var(--color-surface-800) / 0.8);
  }

  .chat-ask-thread-body {
    @apply pt-1;
  }

  .chat-composer {
    @apply relative z-10 shrink-0 px-8 pb-6 pt-2;
  }

  .chat-composer-bar {
    @apply rounded-2xl px-3 py-1.5;
    border: 1px solid rgb(var(--color-surface-600) / 0.22);
    background-color: rgb(var(--color-surface-800) / 0.35);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.03);
  }

  .chat-composer-bar:focus-within {
    border-color: rgb(var(--color-surface-500) / 0.35);
    background-color: rgb(var(--color-surface-800) / 0.5);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.04),
      0 0 0 3px rgb(var(--color-primary-500) / 0.08);
  }

  .chat-composer-shell {
    @apply items-center gap-1 px-1.5 py-1;
  }

  .chat-composer-bar.chat-composer-shell {
    @apply px-1.5 py-1;
  }

  .composer-bar-icon-btn {
    @apply flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-surface-400 transition hover:bg-surface-700/60 hover:text-surface-200 disabled:pointer-events-none disabled:opacity-40;
  }

  .composer-model-trigger--quiet {
    @apply max-w-[11rem] border-transparent bg-transparent px-1.5 py-1;
  }

  .composer-model-trigger--quiet:hover:not(:disabled) {
    border-color: transparent;
    background: rgb(var(--color-surface-800) / 0.35);
  }

  .composer-model-trigger--quiet .composer-model-trigger-name {
    @apply text-[12px] font-normal text-surface-400;
  }

  .composer-model-trigger--quiet.composer-model-trigger-open .composer-model-trigger-name {
    @apply text-surface-200;
  }

  .composer-footer-chip-wrap {
    @apply inline-flex max-w-[9rem] shrink-0 items-center gap-0.5;
  }

  .composer-footer-chip {
    @apply inline-flex min-w-0 max-w-[8rem] items-center gap-1 rounded-full border border-surface-500/35 bg-surface-900/55 px-2 py-0.5 text-[11px] text-surface-300 transition hover:border-primary-500/35 hover:text-surface-100;
  }

  .composer-footer-chip-mono {
    @apply flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-surface-700 text-[9px] font-semibold text-surface-200;
  }

  .composer-footer-chip-dismiss {
    @apply flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-surface-500 transition hover:bg-surface-700/70 hover:text-surface-200;
  }

  .composer-anchored-menu {
    @apply z-[60] flex min-w-[16rem] max-w-[20rem] flex-col overflow-hidden rounded-xl;
    position: fixed;
    top: 0;
    left: 0;
    border: 1px solid rgb(var(--color-surface-600) / 0.35);
    background: rgb(var(--color-surface-900) / 0.98);
    box-shadow:
      0 12px 32px rgb(0 0 0 / 0.35),
      0 0 0 1px rgb(0 0 0 / 0.12);
    backdrop-filter: blur(16px);
  }

  .composer-anchored-menu-header {
    @apply shrink-0 border-b border-surface-700/40 px-3 py-2.5;
  }

  .composer-anchored-menu-body {
    @apply min-h-0 flex-1 overflow-y-auto px-2 py-2;
  }

  .composer-plus-menu-panel {
    @apply min-w-[12.5rem] py-1;
  }

  .composer-plus-menu-item {
    @apply flex w-full items-center gap-2.5 px-3 py-2 text-left text-[13px] text-surface-200 transition hover:bg-surface-800/70;
  }

  .composer-plus-menu-dot {
    @apply h-2 w-2 shrink-0 rounded-full bg-primary-400;
  }

  .composer-bar-voice-btn {
    @apply opacity-80;
  }

  .composer-bar-voice-btn-active {
    @apply text-error-300 opacity-100;
    background-color: rgb(var(--color-error-500) / 0.18);
    box-shadow: 0 0 0 2px rgb(var(--color-error-500) / 0.25);
    animation: composer-voice-pulse 1.4s ease-in-out infinite;
  }

  @keyframes composer-voice-pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.06);
    }
  }

  .composer-attachment-chips {
    @apply mx-8 mb-1.5 flex flex-wrap gap-1.5;
  }

  .composer-voice-status {
    @apply mx-8 mb-1.5 text-xs text-surface-400;
  }

  .composer-voice-status-error {
    @apply text-error-300/90;
  }

  .composer-voice-recorder {
    @apply flex min-h-[40px] w-full min-w-0 flex-1 items-center gap-2 py-0.5;
  }

  .composer-voice-attach {
    @apply opacity-70;
  }

  .composer-voice-stage {
    @apply flex min-w-0 flex-1 items-center gap-2.5 px-1;
  }

  .composer-voice-live {
    @apply relative flex h-3 w-3 shrink-0 items-center justify-center;
  }

  .composer-voice-live-core {
    @apply relative z-[1] h-[7px] w-[7px] rounded-full;
    background: rgb(var(--color-error-400));
    box-shadow: 0 0 10px rgb(var(--color-error-500) / 0.55);
  }

  .composer-voice-live-ring {
    @apply absolute inset-0 rounded-full;
    background: rgb(var(--color-error-500) / 0.22);
    animation: composer-voice-live-ring 1.6s ease-out infinite;
  }

  @keyframes composer-voice-live-ring {
    0% {
      transform: scale(0.72);
      opacity: 0.85;
    }
    100% {
      transform: scale(2.1);
      opacity: 0;
    }
  }

  .composer-voice-wave-wrap {
    @apply flex h-7 min-w-0 flex-1 items-center justify-center overflow-hidden;
  }

  .composer-voice-wave {
    @apply flex h-full min-w-0 flex-1 items-center justify-center gap-[3px];
  }

  .composer-voice-wave-bar {
    @apply w-[3px] shrink-0 rounded-full;
    background: linear-gradient(
      to top,
      rgb(var(--color-error-500) / 0.35),
      rgb(var(--color-error-300) / 0.92)
    );
    transition:
      height 90ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 90ms ease;
  }

  .composer-voice-meta {
    @apply flex shrink-0 items-center gap-1.5 pl-0.5;
  }

  .composer-voice-phase {
    @apply text-[11px] font-medium uppercase tracking-[0.14em] text-surface-400;
  }

  .composer-voice-meta-dot {
    @apply text-[10px] text-surface-600;
  }

  .composer-voice-timer {
    @apply tabular-nums text-xs font-medium text-surface-300;
  }

  .composer-voice-actions {
    @apply flex shrink-0 items-center gap-1;
  }

  .composer-voice-cancel {
    @apply flex h-8 w-8 items-center justify-center rounded-full text-surface-500 transition hover:bg-surface-700/55 hover:text-surface-100 disabled:pointer-events-none disabled:opacity-40;
  }

  .composer-voice-done {
    @apply flex h-8 w-8 items-center justify-center rounded-full text-surface-50 transition-all duration-200 ease-out disabled:pointer-events-none disabled:opacity-45;
    background-color: rgb(var(--color-primary-500));
    box-shadow:
      0 1px 2px rgb(0 0 0 / 0.22),
      0 0 12px rgb(var(--color-primary-500) / 0.28);
  }

  .composer-voice-done:not(:disabled):active {
    transform: scale(0.92);
  }

  .composer-voice-recorder-starting .composer-voice-live-core,
  .composer-voice-recorder-starting .composer-voice-live-ring {
    @apply opacity-60;
    animation: none;
  }

  .composer-voice-recorder-finishing .composer-voice-wave-bar {
    opacity: 0.35;
  }

  .composer-voice-recorder-transcribing .composer-voice-live-core {
    background: rgb(var(--color-primary-400));
    box-shadow: 0 0 10px rgb(var(--color-primary-500) / 0.5);
    animation: composer-voice-live-breathe 1.4s ease-in-out infinite;
  }

  .composer-voice-recorder-transcribing .composer-voice-live-ring {
    background: rgb(var(--color-primary-500) / 0.2);
    animation: composer-voice-live-ring 1.8s ease-out infinite;
  }

  .composer-voice-recorder-transcribing .composer-voice-wave-bar {
    background: linear-gradient(
      to top,
      rgb(var(--color-primary-500) / 0.25),
      rgb(var(--color-primary-300) / 0.55)
    );
    animation: composer-voice-bar-shimmer 1.6s ease-in-out infinite;
  }

  .composer-voice-recorder-transcribing .composer-voice-phase {
    @apply text-primary-300/90;
  }

  @keyframes composer-voice-live-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.12);
    }
  }

  @keyframes composer-voice-bar-shimmer {
    0%,
    100% {
      opacity: 0.28;
    }
    50% {
      opacity: 0.55;
    }
  }

  .composer-bar-voice-mode {
    border-color: rgb(var(--color-error-500) / 0.28);
    background-color: rgb(var(--color-surface-800) / 0.78);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.05),
      0 0 0 1px rgb(var(--color-error-500) / 0.08),
      0 0 22px rgb(var(--color-error-500) / 0.07);
  }

  .composer-bar-voice-mode.composer-bar-voice-transcribing {
    border-color: rgb(var(--color-primary-500) / 0.32);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.05),
      0 0 0 1px rgb(var(--color-primary-500) / 0.1),
      0 0 24px rgb(var(--color-primary-500) / 0.1);
  }

  .composer-voice-recorder-mobile .composer-voice-phase {
    @apply text-[10px];
  }

  .composer-voice-recorder-mobile .composer-voice-timer {
    @apply text-[11px];
  }

  @media (prefers-reduced-motion: reduce) {
    .composer-voice-live-ring,
    .composer-voice-live-core,
    .composer-voice-wave-bar {
      animation: none !important;
    }
  }

  .mobile-chat-composer .composer-voice-status {
    @apply mx-3;
  }

  .mobile-chat-composer .composer-attachment-chips {
    @apply mx-3 mb-1;
  }

  .composer-attachment-chip {
    @apply inline-flex max-w-[min(100%,220px)] items-center gap-0.5 rounded-full border border-surface-500/40 bg-surface-800/70 py-0.5 pl-2.5 pr-1 text-xs text-primary-200;
  }

  .composer-attachment-chip-remove {
    @apply inline-flex h-5 w-5 items-center justify-center rounded-full text-surface-500 hover:bg-surface-700 hover:text-surface-200 disabled:opacity-40;
  }

  .composer-model-picker {
    @apply relative shrink-0;
  }

  .composer-model-trigger {
    @apply inline-flex max-w-[12rem] items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-left transition-colors duration-150 disabled:pointer-events-none disabled:opacity-45;
    border: 1px solid rgb(var(--color-surface-600) / 0.22);
    background: rgb(var(--color-surface-900) / 0.35);
  }

  .composer-model-trigger:hover:not(:disabled) {
    border-color: rgb(var(--color-surface-600) / 0.38);
    background: rgb(var(--color-surface-800) / 0.45);
  }

  .composer-model-trigger-open {
    border-color: rgb(var(--color-surface-600) / 0.45);
    background: rgb(var(--color-surface-800) / 0.55);
  }

  .composer-model-trigger-readonly {
    @apply cursor-default;
  }

  .composer-model-trigger-copy {
    @apply min-w-0 flex-1 leading-none;
  }

  .composer-model-trigger-name {
    @apply block truncate text-[13px] font-medium text-surface-200;
    letter-spacing: -0.01em;
  }

  .composer-model-trigger-meta {
    @apply mt-0.5 block truncate text-[10px] text-surface-500;
  }

  .composer-model-trigger-chevron {
    @apply shrink-0 text-surface-500 transition-transform duration-150;
  }

  .composer-model-trigger-open .composer-model-trigger-chevron {
    transform: rotate(180deg);
  }

  .composer-model-trigger-spinner {
    @apply shrink-0 text-surface-400;
  }

  .composer-model-panel {
    @apply absolute bottom-full left-0 z-50 mb-2 w-[18.5rem] overflow-hidden rounded-xl;
    border: 1px solid rgb(var(--color-surface-600) / 0.32);
    background: rgb(var(--color-surface-900) / 0.98);
    box-shadow:
      0 12px 32px rgb(0 0 0 / 0.32),
      0 0 0 1px rgb(0 0 0 / 0.12);
    backdrop-filter: blur(16px);
  }

  .composer-model-panel-search {
    @apply border-b border-surface-700/35 px-3 py-2.5;
  }

  .composer-model-search {
    @apply flex items-center gap-2;
  }

  .composer-model-search-icon {
    @apply shrink-0 text-surface-500;
  }

  .composer-model-search-input {
    @apply min-w-0 flex-1 border-0 bg-transparent text-[13px] text-surface-100 placeholder:text-surface-500 focus:outline-none;
  }

  .composer-model-list {
    @apply max-h-52 overflow-y-auto py-1;
  }

  .composer-model-list-item {
    @apply flex w-full items-center gap-3 px-3 py-2 text-left transition-colors;
  }

  .composer-model-list-item:hover {
    background: rgb(var(--color-surface-800) / 0.55);
  }

  .composer-model-list-item-active {
    background: rgb(var(--color-surface-800) / 0.35);
  }

  .composer-model-list-name {
    @apply min-w-0 flex-1 truncate text-[13px] text-surface-100;
  }

  .model-cap-badges {
    @apply mt-1 flex flex-wrap gap-1;
  }

  .model-cap-badges-compact {
    @apply mt-0.5;
  }

  .model-cap-badge {
    @apply inline-flex rounded-full border border-surface-600/50 bg-surface-800/70 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-surface-400;
  }

  .provider-model-list-item {
    @apply flex w-full items-center justify-between gap-2 rounded-lg px-2.5 py-2 text-left font-mono text-xs text-surface-200 transition-colors;
  }

  .provider-model-list-item:hover {
    background: rgb(var(--color-surface-800) / 0.55);
  }

  .provider-model-list-item-active {
    @apply border border-surface-500/40 bg-surface-800/60;
  }

  .provider-model-list-name {
    @apply min-w-0 flex-1 truncate;
  }

  .composer-model-list-tier {
    @apply ml-1.5 text-[12px] text-surface-500;
  }

  .composer-model-list-check {
    @apply shrink-0 text-surface-300;
  }

  .composer-model-list-empty {
    @apply flex flex-col items-center justify-center gap-2 px-4 py-8 text-center text-xs text-surface-500;
  }

  .composer-model-turn-settings {
    @apply space-y-2 border-t border-surface-700/35 px-3 py-2.5;
  }

  .composer-model-turn-row {
    @apply flex items-center gap-2;
  }

  .composer-model-turn-label {
    @apply w-16 shrink-0 text-[11px] text-surface-500;
  }

  .composer-model-turn-pills {
    @apply flex min-w-0 flex-1 flex-wrap gap-1;
  }

  .composer-model-turn-pill {
    @apply rounded-md px-2 py-1 text-[11px] text-surface-400 transition hover:text-surface-200 disabled:opacity-45;
    background: rgb(var(--color-surface-800) / 0.45);
  }

  .composer-model-turn-pill-active {
    @apply text-surface-100;
    background: rgb(var(--color-surface-700) / 0.75);
  }

  .composer-model-turn-select {
    @apply min-w-0 flex-1 rounded-md border-0 px-2 py-1 text-[11px] text-surface-200 focus:outline-none focus:ring-1 focus:ring-surface-600 disabled:opacity-45;
    background: rgb(var(--color-surface-800) / 0.55);
  }

  .composer-model-mobile-note {
    @apply border-b border-surface-700/40 px-3.5 py-3.5;
  }

  .composer-model-mobile-title {
    @apply text-sm font-medium text-surface-200;
  }

  .composer-model-mobile-copy {
    @apply mt-1 text-xs text-surface-500;
  }

  .composer-model-panel-footer {
    @apply flex w-full items-center justify-between gap-2 border-t border-surface-700/35 px-3 py-2.5 text-left text-[12px] text-surface-500 transition hover:bg-surface-800/45 hover:text-surface-300;
  }

  .chat-tool-footnote > summary {
    @apply list-none;
  }

  .chat-tool-footnote {
    @apply mt-4 border-0 bg-transparent p-0;
  }

  .chat-tool-footnote > summary::-webkit-details-marker {
    display: none;
  }

  .work-hub {
    @apply min-h-0 bg-surface-900;
  }

  .work-hub-stage {
    @apply flex min-h-0 flex-1 flex-col overflow-hidden;
  }

  .work-hub-stage-header {
    @apply flex shrink-0 items-end justify-between gap-3 border-b px-6 py-3;
    border-color: rgb(var(--color-surface-700) / 0.3);
  }

  .work-hub-grid-wrap {
    @apply relative min-h-0 flex-1 overflow-hidden;
  }

  .work-hub-empty {
    @apply flex h-full items-center justify-center px-6 py-8;
  }

  .work-hub-grid {
    @apply grid h-full auto-rows-min grid-flow-col grid-rows-1 gap-3 overflow-x-auto overflow-y-hidden px-6 py-4;
    grid-auto-columns: minmax(15rem, 18rem);
  }

  .work-hub-card {
    @apply flex min-h-[7.5rem] cursor-pointer flex-col rounded-xl border p-3.5 transition;
    border-color: rgb(var(--color-surface-600) / 0.25);
    background-color: rgb(var(--color-surface-800) / 0.35);
  }

  .work-hub-card:hover {
    border-color: rgb(var(--color-surface-500) / 0.4);
    background-color: rgb(var(--color-surface-800) / 0.55);
  }

  .work-hub-card-selected {
    @apply ring-1 ring-inset;
    border-color: rgb(var(--color-primary-500) / 0.35);
    background-color: rgb(var(--color-surface-800) / 0.7);
    --tw-ring-color: rgb(var(--color-primary-500) / 0.25);
  }

  .work-hub-card-compact {
    @apply min-h-[6.5rem] p-3;
  }

  .work-hub-card-pulse {
    @apply animate-pulse;
  }

  .work-hub-chip {
    @apply rounded-full px-2 py-0.5 text-[10px] font-medium;
  }

  .work-hub-chip-muted {
    @apply bg-surface-700/60 text-surface-400;
  }

  .work-hub-chip-primary {
    background-color: rgb(var(--color-primary-500) / 0.15);
    @apply text-primary-200;
  }

  .work-hub-chip-warning {
    background-color: rgb(var(--color-warning-500) / 0.15);
    @apply text-warning-200;
  }

  .work-hub-chip-danger {
    background-color: rgb(var(--color-error-500) / 0.1);
    @apply text-error-300;
  }

  .work-hub-chip-success {
    background-color: rgb(var(--color-success-500) / 0.1);
    @apply text-success-300;
  }

  .work-hub-provenance {
    @apply truncate rounded-md px-2 py-0.5 text-[10px] text-surface-400 transition hover:text-surface-200;
    background-color: rgb(var(--color-surface-900) / 0.5);
  }

  .work-hub-provenance:hover {
    background-color: rgb(var(--color-surface-900) / 0.8);
  }

  .work-hub-trays {
    @apply shrink-0 border-t px-6 py-2;
    border-color: rgb(var(--color-surface-700) / 0.25);
  }

  .work-hub-tray-tabs {
    @apply flex flex-wrap gap-2;
  }

  .work-hub-tray-tab {
    @apply rounded-md px-2.5 py-1 text-[11px] text-surface-400 transition hover:text-surface-200;
  }

  .work-hub-tray-tab:hover {
    background-color: rgb(var(--color-surface-800) / 0.6);
  }

  .work-hub-tray-tab-open {
    @apply text-surface-100;
    background-color: rgb(var(--color-surface-800) / 0.7);
  }

  .work-hub-tray-panel {
    @apply mt-2 rounded-lg border p-2;
    border-color: rgb(var(--color-surface-700) / 0.3);
    background-color: rgb(var(--color-surface-900) / 0.4);
  }

  .work-hub-tray-grid {
    @apply grid grid-flow-col auto-cols-[minmax(12rem,14rem)] gap-2 overflow-x-auto;
  }

  .work-hub-tray-more {
    @apply mt-2 px-1 text-[10px] text-surface-500;
  }

  .work-hub-composer {
    @apply border-t;
    border-color: rgb(var(--color-surface-700) / 0.2);
  }

  .work-manifest-backdrop {
    @apply absolute inset-0 z-40 backdrop-blur-[2px];
    background-color: rgb(var(--color-surface-950) / 0.55);
  }

  .work-manifest-popover {
    @apply absolute inset-x-4 top-[8%] bottom-[8%] z-50 mx-auto flex max-w-3xl flex-col overflow-hidden rounded-2xl border bg-surface-900 shadow-2xl;
    border-color: rgb(var(--color-surface-600) / 0.4);
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.4);
  }

  .work-manifest-close {
    @apply absolute right-3 top-3 z-10 flex h-8 w-8 items-center justify-center rounded-md text-surface-400 transition hover:bg-surface-800 hover:text-surface-100;
  }

  .manifest-result {
    @apply text-[15px] leading-relaxed text-surface-100;
  }

  .manifest-result .markdown-content {
    @apply text-[15px] leading-relaxed;
  }

  .manifest-timeline-list {
    @apply relative m-0 list-none p-0;
  }

  .manifest-timeline-item {
    @apply relative flex gap-3 pl-1;
  }

  .manifest-timeline-item::before {
    content: "";
    @apply absolute bottom-0 left-[5px] top-3 w-px;
    background: linear-gradient(
      to bottom,
      rgb(var(--color-primary-500) / 0.35),
      rgb(var(--color-surface-700) / 0.4)
    );
  }

  .manifest-timeline-item-last::before {
    display: none;
  }

  .manifest-timeline-dot {
    @apply relative z-[1] mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full;
    background-color: rgb(var(--color-primary-500) / 0.55);
    box-shadow: 0 0 0 3px rgb(var(--color-surface-900) / 0.9);
  }

  .manifest-details summary {
    list-style: none;
  }

  .manifest-details summary::-webkit-details-marker {
    display: none;
  }

  /* Markdown body in chat and vault */
  .markdown-content {
    @apply min-w-0 max-w-full text-surface-100;
    overflow-wrap: anywhere;
  }

  .markdown-content h1,
  .markdown-content h2,
  .markdown-content h3,
  .markdown-content h4,
  .markdown-content h5,
  .markdown-content h6 {
    @apply mt-5 mb-2 font-semibold text-surface-50 first:mt-0 tracking-tight;
  }

  .markdown-content h1 {
    @apply text-xl;
  }

  .markdown-content h2 {
    @apply text-lg;
  }

  .markdown-content h3 {
    @apply text-[0.95rem];
  }

  /* Chat voice: section titles read like presentation labels */
  .chat-voice .markdown-content h2 {
    @apply mt-7 mb-3 text-[0.8rem] font-semibold uppercase tracking-[0.06em] text-surface-400;
  }

  .chat-voice .markdown-content h3 {
    @apply mt-5 mb-2 text-[0.95rem] font-medium normal-case tracking-tight text-surface-200;
  }

  .chat-voice .markdown-content h2 + .liquid-md-embed,
  .chat-voice .markdown-content h3 + .liquid-md-embed,
  .chat-voice .markdown-content p + .liquid-md-embed {
    margin-top: 0.35rem;
  }

  .markdown-content p {
    @apply my-2 first:mt-0 last:mb-0 text-surface-200;
  }

  .markdown-content ul,
  .markdown-content ol {
    @apply my-2 list-outside pl-5;
  }

  .markdown-content ul {
    @apply list-disc;
  }

  .markdown-content ol {
    @apply list-decimal;
  }

  .markdown-content li {
    @apply my-0.5 text-surface-200;
  }

  .markdown-content li > ul,
  .markdown-content li > ol {
    @apply my-1;
  }

  .markdown-content blockquote {
    @apply my-3 border-l-2 border-surface-500/50 pl-3 text-surface-300 italic;
  }

  .markdown-content hr {
    @apply my-4 border-surface-500/40;
  }

  /* Presentation-feel tables: soft card + one shared column grid.
     (Old display:block-on-table / display:table-per-row broke multi-col alignment.) */
  .markdown-content .markdown-table-scroll {
    @apply my-3 w-full max-w-full;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-surface-500) 35%, transparent);
    background: color-mix(in srgb, var(--color-surface-900) 55%, transparent);
    box-shadow: 0 1px 0 color-mix(in srgb, var(--color-surface-50) 4%, transparent);
  }

  .markdown-content table {
    @apply w-full border-collapse text-left text-xs;
    margin: 0;
    width: 100%;
    table-layout: auto;
    border: none;
    background: transparent;
  }

  .markdown-content th,
  .markdown-content td {
    @apply px-3.5 py-2.5 align-top;
    border: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-surface-500) 28%, transparent);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .markdown-content tr:last-child td {
    border-bottom: none;
  }

  .markdown-content th {
    @apply font-semibold;
    background: color-mix(in srgb, var(--color-surface-800) 70%, transparent);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    /* color from workshop-shell --shell-label */
  }

  .markdown-content td {
    @apply text-surface-100;
  }

  .markdown-content td:first-child {
    @apply font-medium;
    /* color from workshop-shell --shell-muted */
  }

  /* 2-col key/value: tidy label column. 3+ cols stay content-shared. */
  .markdown-content table:has(tr > :nth-child(2):last-child) :is(th, td):first-child {
    width: 28%;
    max-width: 12rem;
    white-space: nowrap;
    overflow-wrap: normal;
    word-break: normal;
  }

  .markdown-content table:not(:has(tr > :nth-child(2):last-child)) td:first-child {
    max-width: 11rem;
  }

  .markdown-content tr:nth-child(even) td {
    background: transparent;
  }

  .chat-voice .markdown-content .markdown-table-scroll {
    margin-block: 1.1rem;
  }

  /* Resume kind — ATS-safe single column with tighter section rhythm. */
  [data-note-kind="resume"] .markdown-content {
    max-width: 46rem;
  }

  [data-note-kind="resume"] .markdown-content h1 {
    @apply mt-0 mb-1 text-2xl tracking-tight;
  }

  [data-note-kind="resume"] .markdown-content h1 + p {
    @apply mt-0 mb-4 text-sm text-surface-400;
  }

  [data-note-kind="resume"] .markdown-content h2 {
    @apply mt-7 mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-surface-400;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-surface-500) 40%, transparent);
  }

  [data-note-kind="resume"] .markdown-content h3 {
    @apply mt-4 mb-0.5 text-[1rem] font-semibold tracking-tight text-surface-50;
  }

  [data-note-kind="resume"] .markdown-content h3 + p {
    @apply mt-0 mb-1.5 text-sm text-surface-400;
  }

  /* Role timeline: `Company | Dates` → org left / dates right (preview + export). */
  .markdown-content .resume-role-meta,
  [data-note-kind="resume"] .markdown-content .resume-role-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 1rem;
    margin: 0 0 0.55rem;
    font-size: 0.875rem;
    line-height: 1.35;
    color: rgb(var(--color-surface-400));
  }

  .markdown-content .resume-role-org {
    font-weight: 550;
    color: rgb(var(--color-surface-300));
  }

  .markdown-content .resume-role-dates {
    font-variant-numeric: tabular-nums;
    color: rgb(var(--color-surface-500));
    white-space: nowrap;
  }

  [data-note-kind="resume"] .markdown-content p {
    @apply my-2 text-[0.95rem] leading-relaxed text-surface-200;
  }

  [data-note-kind="resume"] .markdown-content ul,
  [data-note-kind="resume"] .markdown-content ol {
    @apply my-2;
  }

  [data-note-kind="resume"] .markdown-content li {
    @apply my-1.5 leading-relaxed;
  }

  /* Experience bullets: bold lead-in reads as a label, not shouty weight. */
  [data-note-kind="resume"] .markdown-content li > strong:first-child {
    color: rgb(var(--color-surface-100));
    font-weight: 650;
  }

  /*
   * Skills / tools: a list directly under an H2 becomes a chip cloud.
   * Job bullets stay normal lists (they sit under H3, not H2).
   */
  [data-note-kind="resume"] .markdown-content h2 + ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.55rem 0 0.85rem;
    padding: 0;
    list-style: none;
  }

  [data-note-kind="resume"] .markdown-content h2 + ul > li {
    margin: 0;
    padding: 0.28rem 0.65rem;
    border: 1px solid color-mix(in srgb, var(--color-surface-500) 34%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface-800) 48%, transparent);
    font-size: 0.8rem;
    font-weight: 550;
    line-height: 1.3;
    color: rgb(var(--color-surface-100));
  }

  /* Skills / expertise matrix — chip grid instead of data table. */
  [data-note-kind="resume"] .markdown-content .markdown-table--matrix,
  .markdown-content .markdown-table--matrix {
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    overflow: visible;
  }

  [data-note-kind="resume"] .markdown-content .markdown-table--matrix table,
  .markdown-content .markdown-table--matrix table {
    table-layout: fixed;
    border-collapse: separate;
    border-spacing: 0.4rem 0.4rem;
  }

  [data-note-kind="resume"] .markdown-content .markdown-table--matrix th,
  [data-note-kind="resume"] .markdown-content .markdown-table--matrix td,
  .markdown-content .markdown-table--matrix th,
  .markdown-content .markdown-table--matrix td {
    @apply px-2.5 py-2 text-center text-[0.8rem] font-medium text-surface-100;
    border: 1px solid color-mix(in srgb, var(--color-surface-500) 32%, transparent);
    border-radius: 0.55rem;
    background: color-mix(in srgb, var(--color-surface-800) 45%, transparent);
    max-width: none;
    white-space: normal;
    overflow-wrap: anywhere;
  }

  [data-note-kind="resume"] .markdown-content .markdown-table--matrix th,
  .markdown-content .markdown-table--matrix th {
    @apply font-semibold normal-case tracking-normal text-surface-200;
    background: color-mix(in srgb, var(--color-surface-700) 55%, transparent);
    font-size: 0.75rem;
    letter-spacing: 0.01em;
    text-transform: none;
  }

  [data-note-kind="resume"] .markdown-content .markdown-table--matrix tr:last-child td,
  .markdown-content .markdown-table--matrix tr:last-child td {
    border-bottom: 1px solid color-mix(in srgb, var(--color-surface-500) 32%, transparent);
  }

  [data-note-kind="resume"] .markdown-content .markdown-table--matrix td:first-child,
  .markdown-content .markdown-table--matrix td:first-child {
    @apply font-medium;
    max-width: none;
  }

  .markdown-content .liquid-md-embed {
    margin: 1.15rem 0;
  }

  .markdown-content .liquid-md-icon {
    display: inline-flex;
  }

  .markdown-content del {
    @apply text-surface-500;
  }

  /* Task list checkboxes — theme-native, not naked browser controls */
  .markdown-content input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    display: inline-grid;
    place-content: center;
    width: 0.95rem;
    height: 0.95rem;
    margin: 0.2em 0.55rem 0 0;
    flex-shrink: 0;
    vertical-align: text-top;
    border-radius: 0.28rem;
    border: 1.5px solid rgb(var(--color-surface-400) / 0.42);
    background-color: rgb(var(--color-surface-800) / 0.55);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.04);
    transition:
      border-color 140ms ease,
      background-color 140ms ease,
      box-shadow 140ms ease,
      transform 140ms ease;
  }

  .markdown-content input[type="checkbox"]::before {
    content: "";
    width: 0.55rem;
    height: 0.55rem;
    transform: scale(0);
    transition: transform 120ms ease;
    background-color: rgb(var(--on-primary));
    clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0, 43% 62%);
  }

  .markdown-content input[type="checkbox"]:checked {
    border-color: rgb(var(--color-primary-400) / 0.9);
    background-color: rgb(var(--color-primary-500));
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.12),
      0 0 0 1px rgb(var(--color-primary-500) / 0.2);
  }

  .markdown-content input[type="checkbox"]:checked::before {
    transform: scale(1);
  }

  .markdown-content input.vault-preview-task {
    cursor: pointer;
  }

  .markdown-content input.vault-preview-task:hover:not(:checked) {
    border-color: rgb(var(--color-primary-400) / 0.55);
    background-color: rgb(var(--color-surface-700) / 0.75);
  }

  .markdown-content input.vault-preview-task:hover:checked {
    background-color: rgb(var(--color-primary-400));
  }

  .markdown-content input.vault-preview-task:active {
    transform: scale(0.94);
  }

  .markdown-content input.vault-preview-task:focus-visible {
    outline: 2px solid rgb(var(--color-primary-400) / 0.55);
    outline-offset: 2px;
  }

  .markdown-content input[type="checkbox"]:disabled {
    cursor: default;
    opacity: 0.92;
  }

  .markdown-content li:has(> input[type="checkbox"]) {
    list-style: none;
    margin-left: -1.25rem;
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .markdown-content li:has(> input[type="checkbox"]:checked) {
    color: rgb(var(--shell-muted, var(--color-surface-400)));
  }

  html:not(.dark) .markdown-content input[type="checkbox"] {
    border-color: rgb(var(--color-surface-400) / 0.55);
    background-color: rgb(var(--color-surface-900) / 0.9);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.65);
  }

  html:not(.dark) .markdown-content input[type="checkbox"]:checked {
    border-color: rgb(var(--color-primary-600) / 0.85);
    background-color: rgb(var(--color-primary-600));
  }

  .markdown-wikilink {
    @apply cursor-pointer rounded bg-primary-500/15 px-1 text-primary-200 transition-colors;
  }

  .markdown-wikilink:hover {
    @apply bg-primary-500/25 text-primary-100 underline decoration-primary-400/60;
  }

  .markdown-wikilink-unresolved {
    @apply bg-warning-500/15 text-warning-200;
  }

  .markdown-wikilink-unresolved:hover {
    @apply bg-warning-500/25 text-warning-100 decoration-warning-400/60;
  }

  .markdown-wikilink:active {
    @apply scale-[0.98];
  }

  .markdown-heading {
    scroll-margin-top: 4.5rem;
  }

  .markdown-heading-flash {
    @apply rounded-md ring-2 ring-primary-400/50 transition-shadow duration-700;
    --tw-ring-offset-color: rgb(var(--color-surface-950));
  }

  .markdown-toc {
    @apply mb-4 rounded-lg border border-surface-500/40 bg-surface-900/40 px-4 py-3;
  }

  .markdown-toc-title {
    @apply mb-2 text-xs font-semibold uppercase tracking-wide text-surface-400;
  }

  .markdown-toc-list {
    @apply space-y-1 text-sm;
  }

  .markdown-toc-link {
    @apply text-primary-200 underline decoration-primary-500/40 underline-offset-2 hover:text-primary-100;
  }

  .medousa-view {
    @apply my-4 rounded-lg border border-surface-500/40 bg-surface-900/40;
  }

  .medousa-view-header {
    @apply flex flex-wrap items-center justify-between gap-2 border-b border-surface-500/35 px-4 py-2;
  }

  .medousa-view-actions {
    @apply flex items-center gap-3;
  }

  .medousa-view-copy-csv,
  .medousa-view-edit-source,
  .medousa-view-configure {
    @apply text-xs text-primary-200 underline decoration-primary-500/40 underline-offset-2 hover:text-primary-100;
  }

  .liquid-chart-shell {
    position: relative;
    margin: 0.75rem 0;
  }

  .liquid-chart-toolbar {
    display: none;
    justify-content: flex-end;
    margin-bottom: 0.35rem;
  }

  /* Preview: Configure always available. Live: focus = permission. */
  .vault-markdown-preview .liquid-chart-toolbar {
    display: flex;
  }

  .vault-live-editor .liquid-chart-toolbar {
    display: none;
  }

  .vault-live-organism-host:hover .liquid-chart-toolbar,
  .vault-live-organism-host:focus-within .liquid-chart-toolbar,
  .ProseMirror-selectednode .liquid-chart-toolbar {
    display: flex;
  }

  .liquid-chart-configure {
    appearance: none;
    border: 1px solid rgb(var(--color-surface-500) / 0.35);
    border-radius: 999px;
    background: rgb(var(--color-surface-800) / 0.55);
    padding: 0.15rem 0.55rem;
    color: rgb(var(--color-surface-200));
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.4;
    text-decoration: none;
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease,
      background-color 120ms ease;
  }

  .liquid-chart-configure:hover {
    border-color: rgb(var(--color-primary-500) / 0.45);
    background: rgb(var(--color-primary-500) / 0.12);
    color: rgb(var(--color-primary-200));
  }

  html:not(.dark) .liquid-chart-configure {
    background: rgb(var(--color-surface-900) / 0.72);
    border-color: rgb(var(--color-surface-500) / 0.4);
    color: rgb(var(--color-surface-200));
  }

  .vault-format-btn--surface {
    @apply h-8 w-auto min-w-0 px-2;
  }

  /* Chart depth sheet — companion to the Live figure, not a settings form */
  .vault-chart-builder-sheet {
    width: min(22.5rem, calc(100vw - 2rem));
    max-width: min(22.5rem, calc(100vw - 2rem));
    max-height: calc(100vh - 2rem);
    overflow: auto;
    padding: 1rem 1.05rem 0.9rem;
    border-radius: 0.95rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.22);
    background: rgb(var(--color-surface-950) / 0.92);
    box-shadow:
      0 1px 0 rgb(var(--color-surface-50) / 0.04) inset,
      0 18px 48px rgb(0 0 0 / 0.35);
  }

  .vault-chart-builder-sheet--data {
    width: min(40rem, calc(100vw - 2rem));
    max-width: min(40rem, calc(100vw - 2rem));
  }

  .vault-chart-data-title {
    margin: 0;
    color: rgb(var(--color-surface-50));
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .vault-chart-data-body {
    min-width: 0;
  }

  .vault-chart-data-sheet-table {
    margin-bottom: 0.35rem;
  }

  .vault-chart-builder-sheet--data .vault-chart-builder-footer {
    justify-content: flex-end;
  }

  .vault-chart-builder-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.16);
  }

  .vault-chart-builder-identity {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .vault-chart-builder-title-input {
    width: 100%;
    border: none;
    background: transparent;
    padding: 0;
    color: rgb(var(--color-surface-50));
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .vault-chart-builder-title-input::placeholder {
    color: rgb(var(--color-surface-500));
    font-weight: 500;
  }

  .vault-chart-builder-title-input:focus,
  .vault-chart-builder-title-input:focus-visible {
    outline: none;
    border: none;
    box-shadow: none;
  }

  .vault-chart-builder-desc-input {
    width: 100%;
    border: none;
    background: transparent;
    padding: 0;
    color: rgb(var(--color-surface-400));
    font-size: 0.8125rem;
    line-height: 1.35;
    box-shadow: none;
    appearance: none;
    -webkit-appearance: none;
  }

  .vault-chart-builder-desc-input::placeholder {
    color: rgb(var(--color-surface-600));
  }

  .vault-chart-builder-desc-input:focus,
  .vault-chart-builder-desc-input:focus-visible {
    outline: none;
    border: none;
    box-shadow: none;
    background: transparent;
    color: rgb(var(--color-surface-300));
  }

  .vault-chart-builder-block {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-bottom: 0.95rem;
  }

  .vault-chart-builder-add-desc {
    appearance: none;
    border: none;
    background: transparent;
    padding: 0;
    margin: 0;
    color: rgb(var(--color-surface-600));
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    text-align: left;
  }

  .vault-chart-builder-add-desc:hover {
    color: rgb(var(--color-surface-400));
  }

  /* Fact rows — current value only; expand one property at a time */
  .vault-chart-facts {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin: 0 0 1rem;
  }

  .vault-chart-fact {
    border-radius: 0.45rem;
    transition: background-color 140ms ease;
  }

  .vault-chart-fact--open {
    background: rgb(var(--color-surface-900) / 0.45);
    padding: 0.35rem 0.45rem 0.5rem;
    margin: 0.1rem -0.45rem;
  }

  .vault-chart-fact__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem;
    min-height: 1.75rem;
  }

  .vault-chart-fact__row--marks {
    align-items: center;
  }

  .vault-chart-fact__label {
    flex: 0 0 3.5rem;
    margin: 0;
    color: rgb(var(--color-surface-500));
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .vault-chart-fact__value {
    appearance: none;
    border: none;
    background: transparent;
    padding: 0.2rem 0.35rem;
    margin: 0;
    border-radius: 0.3rem;
    color: rgb(var(--color-surface-200));
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    text-align: right;
  }

  .vault-chart-fact__value:hover {
    background: rgb(var(--color-surface-800) / 0.55);
    color: rgb(var(--color-surface-50));
  }

  .vault-chart-fact__value--swash {
    display: inline-flex;
    align-items: center;
    min-height: 1.35rem;
  }

  .vault-chart-fact__muted {
    color: rgb(var(--color-surface-500));
    font-weight: 500;
  }

  .vault-chart-fact__swash {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
  }

  .vault-chart-fact__dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    box-shadow: inset 0 0 0 1px rgb(var(--color-surface-50) / 0.12);
  }

  .vault-chart-fact__editor {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    margin-top: 0.35rem;
    animation: vault-chart-fact-open 140ms ease;
  }

  .vault-chart-fact__editor--color {
    align-items: stretch;
  }

  @keyframes vault-chart-fact-open {
    from {
      opacity: 0;
      transform: translateY(-0.15rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .vault-chart-fact__free {
    width: 100%;
    max-width: 14rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.28);
    border-radius: 0.4rem;
    background: rgb(var(--color-surface-950) / 0.4);
    padding: 0.35rem 0.5rem;
    color: rgb(var(--color-surface-100));
    font-size: 0.75rem;
  }

  .vault-chart-fact__free:focus {
    outline: none;
    border-color: rgb(var(--color-surface-400) / 0.45);
  }

  .vault-chart-fact__free::placeholder {
    color: rgb(var(--color-surface-600));
  }

  .vault-chart-builder-kinds {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.2rem;
    max-width: 100%;
  }

  .vault-chart-builder-kind {
    appearance: none;
    border: none;
    border-radius: 0.3rem;
    background: transparent;
    padding: 0.22rem 0.45rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: lowercase;
    cursor: pointer;
  }

  .vault-chart-builder-kind:hover {
    color: rgb(var(--color-surface-300));
  }

  .vault-chart-builder-kind--on {
    color: rgb(var(--color-surface-50));
    background: rgb(var(--color-surface-800) / 0.7);
  }

  .vault-chart-builder-seg {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.15rem;
  }

  .vault-chart-builder-seg__btn {
    appearance: none;
    border: none;
    border-radius: 0.3rem;
    background: transparent;
    padding: 0.22rem 0.45rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition:
      color 120ms ease,
      background-color 120ms ease;
  }

  .vault-chart-builder-seg__btn:hover {
    color: rgb(var(--color-surface-300));
  }

  .vault-chart-builder-seg__btn--on {
    color: rgb(var(--color-surface-50));
    background: rgb(var(--color-surface-800) / 0.7);
  }

  .vault-chart-builder-marks {
    flex: 1;
    min-width: 0;
    max-width: 12rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.28);
    border-radius: 0.45rem;
    background: rgb(var(--color-surface-900) / 0.4);
    padding: 0.35rem 0.5rem;
    color: rgb(var(--color-surface-100));
    font-size: 0.75rem;
  }

  .vault-chart-builder-marks:focus {
    outline: none;
    border-color: rgb(var(--color-surface-400) / 0.45);
  }

  .vault-chart-builder-swatches {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
  }

  .vault-chart-builder-swatch--on {
    box-shadow:
      0 0 0 2px rgb(var(--color-surface-950)),
      0 0 0 3.5px rgb(var(--color-surface-300) / 0.55);
  }

  .vault-chart-builder-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.35rem;
    padding-top: 0.15rem;
  }

  .vault-chart-builder-cancel {
    border: 0;
    border-radius: 0.4rem;
    background: transparent;
    padding: 0.4rem 0.7rem;
    color: rgb(var(--color-surface-450, var(--color-surface-400)));
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
  }

  .vault-chart-builder-cancel:hover {
    color: rgb(var(--color-surface-200));
  }

  .vault-chart-builder-done {
    appearance: none;
    border: none;
    border-radius: 0.45rem;
    background: rgb(var(--color-surface-100) / 0.12);
    padding: 0.4rem 0.85rem;
    color: rgb(var(--color-surface-50));
    font-size: 0.75rem;
    font-weight: 550;
    cursor: pointer;
    transition: background-color 120ms ease;
  }

  .vault-chart-builder-done:hover {
    background: rgb(var(--color-surface-100) / 0.18);
  }

  .medousa-view-label {
    @apply text-xs font-semibold uppercase tracking-wide text-surface-400;
  }

  .medousa-view-table-wrap {
    @apply overflow-x-auto px-2 py-2;
  }

  .medousa-view-table {
    @apply w-full min-w-[320px] border-collapse text-sm;
  }

  .medousa-view-table th {
    @apply border-b border-surface-500/40 px-3 py-2 text-left text-xs font-medium uppercase tracking-wide text-surface-400;
  }

  .medousa-view-table td {
    @apply border-b border-surface-500/25 px-3 py-2 text-surface-100;
  }

  .medousa-view-empty {
    @apply py-4 text-center text-surface-500;
  }

  .medousa-view-meta {
    @apply border-t border-surface-500/30 px-4 py-2 text-xs text-surface-500;
  }

  .medousa-view-error {
    @apply border-error-500/35 bg-error-500/10 px-4 py-3;
  }

  .medousa-view-error-text {
    @apply text-sm text-error-200;
  }

  .markdown-heading-link {
    @apply text-primary-200 underline decoration-primary-500/40 underline-offset-2;
  }

  .vault-editor-textarea {
    @apply focus:ring-0;
  }

  .vault-kbd {
    @apply rounded border border-surface-500/50 bg-surface-800/80 px-1.5 py-0.5 font-mono text-[10px] text-surface-300;
  }

  .grapheme-script-editor {
    @apply bg-surface-900/20;
  }

  .grapheme-codemirror-host {
    @apply min-h-0 flex-1 overflow-hidden;
    background-color: rgb(var(--color-surface-950) / 0.4);
  }

  .grapheme-codemirror-host .cm-editor {
    @apply h-full outline-none;
  }

  .grapheme-codemirror-host .cm-scroller {
    @apply min-h-0 flex-1 overflow-auto font-mono text-[13px] leading-relaxed;
  }

  .grapheme-script-side-pane {
    @apply bg-surface-900/30;
  }

  .grapheme-run-output {
    background-color: rgb(var(--color-surface-950) / 0.6);
  }

  .grapheme-run-console {
    @apply min-w-0;
  }

  .grapheme-run-console-status {
    @apply flex flex-wrap items-baseline gap-x-2 gap-y-0.5;
  }

  .grapheme-run-console-outcome {
    @apply text-[11px] font-semibold tracking-[-0.01em];
  }

  .grapheme-run-console-outcome.is-ok {
    @apply text-success-300;
  }

  .grapheme-run-console-outcome.is-error {
    @apply text-error-300;
  }

  .grapheme-run-console-meta {
    @apply font-mono text-[10px] text-surface-500;
  }

  .grapheme-run-console-body {
    @apply mt-1.5 m-0 max-w-full overflow-x-auto whitespace-pre-wrap break-words font-mono text-[11px] leading-[1.45] text-surface-200;
  }

  .grapheme-run-console-error .grapheme-run-console-body {
    @apply text-error-300/90;
  }

  .grapheme-run-console-raw {
    @apply mt-2;
  }

  .grapheme-run-console-raw > summary {
    @apply cursor-pointer select-none text-[10px] font-medium text-surface-500 transition hover:text-surface-300;
    list-style: none;
  }

  .grapheme-run-console-raw > summary::-webkit-details-marker {
    display: none;
  }

  .grapheme-run-console-raw[open] > summary {
    @apply text-surface-400;
  }

  .grapheme-run-console-raw .grapheme-run-console-body {
    @apply mt-1 text-surface-400;
  }

  .grapheme-run-console-empty {
    @apply text-[11px] text-surface-500;
  }

  .workshop-recipe-card {
    @apply rounded-lg border border-surface-500/40 bg-surface-900/50 p-3 transition;
  }

  .workshop-recipe-card:hover {
    @apply border-primary-500/35 bg-primary-500/5;
  }

  .workshop-journey-details {
    @apply rounded-lg border border-surface-500/30 bg-surface-900/30;
  }

  .workshop-journey-details-compact {
    @apply border-0 bg-transparent;
  }

  .workshop-journey-summary {
    @apply cursor-pointer select-none px-3 py-2 text-xs text-surface-300;
    list-style: none;
  }

  .workshop-journey-summary::-webkit-details-marker {
    display: none;
  }

  .workshop-journey-details[open] .workshop-journey-summary {
    @apply border-b border-surface-500/30 text-surface-200;
  }

  .workshop-journey-details .workshop-journey {
    @apply border-0 bg-transparent px-3 pb-3 pt-2;
  }

  .workshop-journey {
    @apply rounded-lg border border-surface-500/35 bg-surface-900/40 px-3 py-3;
  }

  .workshop-journey-compact {
    @apply border-0 bg-transparent px-0 py-0;
  }

  .workshop-journey-title {
    @apply text-xs font-medium text-surface-200;
  }

  .workshop-journey-steps {
    @apply mt-2 flex flex-wrap gap-2;
  }

  .workshop-journey-step {
    @apply flex min-w-0 items-center gap-2 rounded-md border border-surface-500/35 px-2 py-1.5;
  }

  .workshop-journey-step-active {
    @apply border-primary-500/40 bg-primary-500/10;
  }

  .workshop-journey-step-done {
    @apply border-surface-500/25 opacity-80;
  }

  .workshop-journey-badge {
    @apply flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-surface-800 text-[10px] font-semibold text-surface-300;
  }

  .workshop-journey-step-active .workshop-journey-badge {
    @apply bg-primary-500/25 text-primary-200;
  }

  .grapheme-run-card {
    @apply rounded-lg border px-3 py-3;
  }

  .grapheme-run-card-success {
    @apply border-success-500/30 bg-success-500/5;
  }

  .grapheme-run-card-error {
    @apply border-error-500/30 bg-error-500/5;
  }

  .workshop-flow-step {
    @apply rounded-lg border border-surface-500/35 bg-surface-900/45 p-3;
  }

  .workshop-advanced summary {
    @apply list-none;
  }

  .workshop-advanced summary::-webkit-details-marker {
    display: none;
  }

  .scripts-workbench-rail {
    @apply flex w-11 shrink-0 flex-col items-center gap-1 border-r border-surface-500/40 py-2;
    background-color: rgb(var(--color-surface-950) / 0.5);
  }

  .scripts-workbench-rail-btn {
    @apply rounded-md p-2 text-surface-400 transition hover:bg-surface-800 hover:text-surface-100;
  }

  .scripts-workbench-rail-btn-active {
    @apply bg-primary-500/15 text-primary-300;
  }

  .scripts-workbench-sidebar {
    background-color: rgb(var(--color-surface-950) / 0.3);
  }

  .scripts-workbench-doc-name {
    @apply rounded px-1 py-0.5;
  }

  .scripts-workbench-doc-name:focus {
    background-color: rgb(var(--color-surface-800) / 0.6);
  }

  .scripts-workbench-titlebar {
    background-color: rgb(var(--color-surface-900) / 0.92);
    border-bottom-color: rgb(var(--color-surface-500) / 0.4);
  }

  .scripts-workbench-titlebar-actions {
    @apply border-l border-surface-500/30 pl-1;
  }

  .scripts-workbench-toolbar-btn {
    @apply rounded-md p-1.5 text-surface-400 transition hover:bg-surface-800 hover:text-surface-100 disabled:pointer-events-none disabled:opacity-35;
  }

  .scripts-workbench-toolbar-btn-active {
    @apply bg-surface-800 text-primary-300;
  }

  .scripts-workbench-toolbar-btn-primary {
    @apply text-primary-300 hover:bg-primary-500/15 hover:text-primary-200;
  }

  .scripts-workbench-toolbar-btn-run {
    @apply text-success-400 hover:bg-success-500/10 hover:text-success-300;
  }

  .grapheme-module-library {
    @apply relative shrink-0;
  }

  .grapheme-module-library-panel {
    @apply fixed z-[80] flex max-h-[min(26rem,70vh)] flex-col overflow-hidden rounded-xl;
    border: 1px solid rgb(var(--color-surface-600) / 0.32);
    background: rgb(var(--color-surface-900) / 0.98);
    box-shadow:
      0 12px 32px rgb(0 0 0 / 0.32),
      0 0 0 1px rgb(0 0 0 / 0.12);
    backdrop-filter: blur(16px);
  }

  .grapheme-module-library-head {
    @apply flex items-center justify-between gap-2 border-b border-surface-700/35 px-3 py-2;
  }

  .grapheme-module-library-body {
    @apply grid min-h-0 grid-cols-[8.5rem_minmax(0,1fr)] max-h-[min(22rem,55vh)];
  }

  .grapheme-module-library-modules {
    @apply min-h-0 overflow-y-auto border-r border-surface-700/35 py-1;
  }

  .grapheme-module-library-module {
    @apply flex w-full items-center gap-1.5 px-2 py-1.5 text-left transition-colors;
  }

  .grapheme-module-library-module:hover {
    background: rgb(var(--color-surface-800) / 0.55);
  }

  .grapheme-module-library-module-active {
    background: rgb(var(--color-surface-800) / 0.75);
  }

  .grapheme-module-library-more {
    @apply w-full px-2 py-1.5 text-left text-[10px] text-surface-500 transition hover:bg-surface-800/55 hover:text-surface-300;
  }

  .grapheme-module-library-ops {
    @apply flex min-h-0 min-w-0 flex-col;
  }

  .grapheme-module-library-search {
    @apply flex shrink-0 items-center gap-2 border-b border-surface-700/35 px-2.5 py-2;
  }

  .grapheme-module-library-search-input {
    @apply min-w-0 flex-1 border-0 bg-transparent text-[12px] text-surface-100 placeholder:text-surface-500 focus:outline-none;
  }

  .grapheme-module-library-blurb {
    @apply shrink-0 truncate px-2.5 pt-1.5 text-[10px] text-surface-500;
  }

  .grapheme-module-library-op-list {
    @apply min-h-0 flex-1 overflow-y-auto py-1;
  }

  .grapheme-module-library-op {
    @apply flex w-full items-start gap-2 px-2.5 py-1.5 text-left transition-colors;
  }

  .grapheme-module-library-op:hover {
    background: rgb(var(--color-surface-800) / 0.55);
  }

  .grapheme-module-library-op:hover .grapheme-module-library-insert {
    @apply opacity-100;
  }

  .grapheme-module-library-insert {
    @apply shrink-0 rounded px-1.5 py-0.5 text-[10px] font-medium text-primary-300 opacity-0 transition;
    background: rgb(var(--color-primary-500) / 0.12);
  }

  .grapheme-module-library-footer {
    @apply flex items-center border-t border-surface-700/35 px-2 py-1.5;
  }

  .grapheme-module-library-footer-btn {
    @apply inline-flex items-center gap-1 rounded px-1.5 py-1 text-[10px] text-surface-500 transition hover:bg-surface-800/55 hover:text-surface-300;
  }

  .grapheme-module-library-allowlist {
    @apply border-t border-surface-700/35 pt-1.5;
  }

  .scripts-workbench-status-bar {
    @apply grid shrink-0 grid-cols-[1fr_auto_1fr] items-center gap-3 border-t border-surface-500/45 px-3 py-1 text-[10px];
    background-color: rgb(var(--color-surface-900) / 0.95);
    min-height: 1.375rem;
  }

  .scripts-workbench-status-item {
    @apply truncate text-surface-400;
  }

  .scripts-workbench-status-center {
    @apply cursor-pointer transition hover:text-surface-200;
  }

  /* In-place tab rename — edit the title, don't drop a form field into the strip. */
  .script-editor-tab-rename {
    @apply min-w-[5rem] max-w-[10rem] flex-1 border-0 border-b bg-transparent px-0 py-0 text-[11px] font-medium leading-none text-primary-200 outline-none;
    appearance: none;
    -webkit-appearance: none;
    border-bottom-color: rgb(var(--color-primary-400) / 0.45);
    border-radius: 0;
    box-shadow: none;
    caret-color: rgb(var(--color-primary-300));
  }

  .script-editor-tab-rename:focus,
  .script-editor-tab-rename:focus-visible {
    border-bottom-color: rgb(var(--color-primary-300) / 0.85);
    outline: none;
    box-shadow: none;
    background: transparent;
  }

  .script-editor-tab-rename::selection {
    background: rgb(var(--color-primary-500) / 0.28);
    color: rgb(var(--color-surface-50));
  }

  /* Library list rename — same type as the row title, hairline underline only. */
  .script-library-rename {
    @apply w-full border-0 border-b bg-transparent px-0 py-0 text-sm font-medium leading-snug text-surface-100 outline-none;
    appearance: none;
    -webkit-appearance: none;
    border-bottom-color: rgb(var(--color-surface-500) / 0.55);
    border-radius: 0;
    box-shadow: none;
    caret-color: rgb(var(--color-primary-300));
  }

  .script-library-rename:focus,
  .script-library-rename:focus-visible {
    border-bottom-color: rgb(var(--color-primary-400) / 0.7);
    outline: none;
    box-shadow: none;
    background: transparent;
  }

  .script-library-rename::selection {
    background: rgb(var(--color-primary-500) / 0.28);
    color: rgb(var(--color-surface-50));
  }

  .scripts-workbench-modules-split {
    border-top: 1px solid rgb(var(--color-surface-500) / 0.18);
  }

  .scripts-workbench-module-detail {
    background:
      radial-gradient(
        ellipse 80% 40% at 50% 0%,
        rgb(var(--color-primary-500) / 0.03),
        transparent 70%
      ),
      rgb(var(--color-surface-950) / 0.2);
  }

  .scripts-workbench-module-pick:focus-visible {
    @apply outline-none ring-2 ring-primary-500/40 ring-inset;
  }

  .scripts-workbench-meta-chip {
    @apply rounded px-1.5 py-0.5 text-[10px] text-surface-400;
    background-color: rgb(var(--color-surface-800) / 0.7);
  }

  .scripts-workbench-effect-chip {
    @apply rounded px-1.5 py-0.5 text-[10px];
    background-color: rgb(var(--color-surface-800) / 0.5);
  }

  .scripts-workbench-effect-chip-muted {
    @apply text-surface-500;
  }

  .scripts-workbench-effect-chip-default {
    @apply text-surface-300;
  }

  .scripts-workbench-effect-chip-warning {
    @apply text-warning-400;
  }

  /* Modules Action Library — premium liquid pieces */
  .scripts-piece-detail-header {
    @apply relative overflow-hidden px-3 pb-3 pt-2.5;
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.22);
    background:
      linear-gradient(
        180deg,
        rgb(var(--color-primary-500) / 0.06) 0%,
        transparent 70%
      ),
      rgb(var(--color-surface-900) / 0.2);
  }

  .scripts-piece-scope {
    @apply text-[11px] font-medium tracking-[-0.01em] text-surface-100;
  }

  .scripts-piece-blurb {
    @apply mt-0.5 text-[11px] leading-snug text-surface-500;
  }

  .scripts-piece-hint {
    @apply mt-1.5 text-[10px] text-surface-500;
  }

  .scripts-piece-meta {
    @apply mt-2 flex flex-wrap items-center gap-1;
  }

  .scripts-piece-meta .scripts-workbench-meta-chip,
  .scripts-piece-meta .scripts-workbench-effect-chip {
    @apply rounded-md px-1.5 py-px text-[9px] tracking-wide;
    background-color: rgb(var(--color-surface-800) / 0.45);
    border: 1px solid rgb(var(--color-surface-500) / 0.18);
  }

  .scripts-workbench-module-list {
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.22);
  }

  .scripts-workbench-module-pick {
    @apply relative rounded-none px-3 py-2 transition-colors duration-150;
  }

  .scripts-workbench-module-pick:hover {
    background: rgb(var(--color-surface-800) / 0.45);
  }

  .scripts-workbench-module-pick-active {
    background: rgb(var(--color-primary-500) / 0.08);
  }

  .scripts-workbench-module-pick-active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.45rem;
    bottom: 0.45rem;
    width: 2px;
    border-radius: 9999px;
    background: rgb(var(--color-primary-400) / 0.85);
    box-shadow: 0 0 10px -1px rgb(var(--color-primary-400) / 0.45);
  }

  .scripts-piece-list {
    position: relative;
    margin: 0;
    list-style: none;
    padding: 0.65rem 0.55rem 0.85rem 0.4rem;
  }

  .scripts-piece-list::before {
    content: "";
    position: absolute;
    left: calc(0.4rem + 0.42rem);
    top: 1.15rem;
    bottom: 1.35rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      rgb(var(--color-primary-500) / 0.35),
      rgb(var(--color-surface-500) / 0.12) 55%,
      transparent
    );
  }

  .scripts-piece-spine-item {
    position: relative;
    display: grid;
    grid-template-columns: 0.85rem minmax(0, 1fr);
    gap: 0.55rem;
    padding-bottom: 0.45rem;
    animation: scripts-piece-in 520ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .scripts-piece-spine-item:nth-child(1) {
    animation-delay: 20ms;
  }
  .scripts-piece-spine-item:nth-child(2) {
    animation-delay: 55ms;
  }
  .scripts-piece-spine-item:nth-child(3) {
    animation-delay: 90ms;
  }
  .scripts-piece-spine-item:nth-child(4) {
    animation-delay: 125ms;
  }
  .scripts-piece-spine-item:nth-child(5) {
    animation-delay: 160ms;
  }
  .scripts-piece-spine-item:nth-child(6) {
    animation-delay: 195ms;
  }
  .scripts-piece-spine-item:nth-child(7) {
    animation-delay: 230ms;
  }
  .scripts-piece-spine-item:nth-child(8) {
    animation-delay: 265ms;
  }
  .scripts-piece-spine-item:nth-child(n + 9) {
    animation-delay: 290ms;
  }

  .scripts-piece-spine-item:last-child {
    padding-bottom: 0.15rem;
  }

  .scripts-piece-rail {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    padding-top: 1.05rem;
  }

  .scripts-piece-node {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 9999px;
    background: rgb(var(--color-primary-300) / 0.9);
    box-shadow:
      0 0 0 3px rgb(var(--color-surface-950) / 0.95),
      0 0 0 4px rgb(var(--color-primary-500) / 0.28);
  }

  .scripts-piece-card {
    display: flex;
    width: 100%;
    flex-direction: column;
    border-radius: 0.7rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.28);
    background:
      linear-gradient(
        165deg,
        rgb(var(--color-surface-800) / 0.35) 0%,
        rgb(var(--color-surface-950) / 0.45) 100%
      );
    padding: 0.65rem 0.7rem 0.6rem;
    text-align: left;
    transition:
      transform 180ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .scripts-piece-card:hover {
    border-color: rgb(var(--color-primary-500) / 0.38);
    background:
      linear-gradient(
        165deg,
        rgb(var(--color-surface-800) / 0.55) 0%,
        rgb(var(--color-surface-900) / 0.65) 100%
      );
    box-shadow: 0 8px 22px -16px rgb(var(--color-primary-500) / 0.55);
    transform: translateY(-1px);
  }

  .scripts-piece-card:hover .scripts-piece-insert {
    color: rgb(var(--color-primary-200));
    background: rgb(var(--color-primary-500) / 0.14);
  }

  .scripts-piece-card:focus-visible {
    outline: none;
    border-color: rgb(var(--color-primary-400) / 0.55);
    box-shadow: 0 0 0 2px rgb(var(--color-primary-500) / 0.22);
  }

  .scripts-piece-card-inserting {
    animation: scripts-piece-press 300ms cubic-bezier(0.16, 1, 0.3, 1);
    border-color: rgb(var(--color-primary-400) / 0.6);
    box-shadow:
      0 0 0 3px rgb(var(--color-primary-500) / 0.18),
      0 10px 24px -14px rgb(var(--color-primary-500) / 0.5);
  }

  .scripts-piece-mark {
    display: inline-flex;
    height: 1.55rem;
    width: 1.55rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 0.45rem;
    font-size: 0.625rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(var(--color-primary-100) / 0.92);
    background: rgb(var(--color-primary-500) / 0.16);
    border: 1px solid rgb(var(--color-primary-400) / 0.22);
  }

  .scripts-piece-title {
    font-size: 0.8125rem;
    font-weight: 560;
    letter-spacing: -0.015em;
    color: rgb(var(--color-surface-50));
    line-height: 1.25;
  }

  .scripts-piece-sig {
    margin-top: 0.2rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    letter-spacing: -0.01em;
    color: rgb(var(--color-surface-500));
  }

  .scripts-piece-insert {
    flex-shrink: 0;
    border-radius: 9999px;
    padding: 0.15rem 0.45rem;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgb(var(--color-primary-300) / 0.85);
    background: rgb(var(--color-primary-500) / 0.08);
    transition:
      color 160ms ease,
      background 160ms ease;
  }

  .scripts-piece-chips {
    margin-top: 0.45rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    opacity: 0.72;
    transition: opacity 160ms ease;
  }

  .scripts-piece-card:hover .scripts-piece-chips {
    opacity: 1;
  }

  .scripts-piece-chips .scripts-workbench-meta-chip,
  .scripts-piece-chips .scripts-workbench-effect-chip {
    @apply rounded px-1 py-px text-[9px];
    background-color: transparent;
    border: 1px solid rgb(var(--color-surface-500) / 0.22);
  }

  .scripts-piece-hits {
    padding: 0.45rem 0.55rem 0.55rem;
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.22);
    background: rgb(var(--color-surface-950) / 0.25);
  }

  .scripts-piece-hits-label {
    @apply px-0.5 pb-1.5 text-[9px] font-semibold uppercase tracking-[0.14em] text-surface-500;
  }

  .scripts-piece-hit {
    margin-bottom: 0.4rem;
    animation: scripts-piece-in 460ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .scripts-piece-hit:last-child {
    margin-bottom: 0;
  }

  .scripts-piece-hit:nth-child(1) {
    animation-delay: 20ms;
  }
  .scripts-piece-hit:nth-child(2) {
    animation-delay: 50ms;
  }
  .scripts-piece-hit:nth-child(3) {
    animation-delay: 80ms;
  }
  .scripts-piece-hit:nth-child(4) {
    animation-delay: 110ms;
  }
  .scripts-piece-hit:nth-child(5) {
    animation-delay: 140ms;
  }

  .grapheme-script-editor.scripts-piece-landed {
    animation: scripts-piece-land 480ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes scripts-piece-in {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes scripts-piece-press {
    0% {
      transform: translateY(-1px) scale(1);
    }
    35% {
      transform: translateY(0.5px) scale(0.978);
    }
    100% {
      transform: translateY(0) scale(1);
    }
  }

  @keyframes scripts-piece-land {
    0% {
      box-shadow: inset 0 0 0 0 transparent;
      background-color: transparent;
    }
    30% {
      box-shadow: inset 0 0 0 1px rgb(var(--color-primary-400) / 0.28);
      background-color: rgb(var(--color-primary-500) / 0.04);
    }
    100% {
      box-shadow: inset 0 0 0 0 transparent;
      background-color: transparent;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scripts-piece-spine-item,
    .scripts-piece-hit {
      animation: none;
    }

    .scripts-piece-card {
      transition: none;
    }

    .scripts-piece-card:hover {
      transform: none;
      box-shadow: none;
    }

    .scripts-piece-card-inserting,
    .grapheme-script-editor.scripts-piece-landed {
      animation: none;
    }
  }

  .scripts-workbench-center-mobile {
    @apply relative;
    --scripts-workbench-status-height: 2rem;
  }

  .scripts-workbench-mobile-empty {
    z-index: 5;
  }

  .scripts-workbench-fab {
    z-index: 25;
  }

  .script-workbench-chat-panel-mobile,
  .script-workbench-chat-panel.script-workbench-chat-panel-mobile {
    @apply w-full max-w-full min-w-0 shrink flex-1 border-0;
  }

  .script-workbench-chat-mobile-root {
    @apply flex min-h-0 w-full max-w-full min-w-0 flex-1 flex-col;
  }

  .script-workbench-chat-composer {
    @apply shrink-0;
    padding-bottom: max(0.35rem, env(safe-area-inset-bottom, 0px));
  }

  .cron-panel-mobile {
    @apply overflow-x-hidden;
  }

  .workshop-tabs-mobile {
    @apply -mx-1 overflow-x-auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .workshop-tabs-mobile .workshop-tab {
    @apply shrink-0 px-3.5;
  }

  .cron-panel-mobile .workshop-header {
    @apply py-2;
  }

  .cron-panel-mobile .workshop-header-line {
    @apply hidden;
  }

  .cron-panel-mobile .cron-create-form {
    @apply space-y-3 pb-6;
  }

  .cron-panel-mobile .cron-field-label {
    @apply mb-1 text-[11px] normal-case tracking-normal text-surface-400;
  }

  .cron-panel-mobile .cron-field-bar {
    @apply rounded-xl;
  }

  .cron-panel-mobile .cron-field-bar-compact {
    @apply py-1;
  }

  .cron-panel-mobile aside,
  .cron-panel-mobile .workshop-detail-pane {
    @apply px-3 py-3;
  }

  .friendly-schedule {
    @apply space-y-3;
  }

  .friendly-schedule-summary {
    @apply text-sm leading-snug text-surface-200;
  }

  .friendly-schedule-frequency {
    @apply flex flex-wrap gap-2;
  }

  .friendly-schedule-chip {
    @apply rounded-full border border-surface-500/40 bg-surface-900/40 px-3 py-1.5 text-xs text-surface-300 transition active:scale-[0.98];
  }

  .friendly-schedule-chip-active {
    @apply border-primary-500/45 text-surface-50;
    background-color: rgb(var(--color-primary-500) / 0.12);
  }

  .friendly-schedule-row {
    @apply grid gap-3 sm:grid-cols-2;
  }

  .friendly-schedule-field {
    @apply block min-w-0;
  }

  .friendly-schedule-field-label {
    @apply mb-1 block text-[11px] text-surface-400;
  }

  .friendly-schedule-hint {
    @apply mt-1 text-[10px] leading-snug text-surface-500;
  }

  .friendly-schedule-mobile .friendly-schedule-chip {
    @apply py-2 text-[13px];
  }

  .flow-composer-mobile {
    @apply space-y-3;
  }

  .flow-composer-mobile .workshop-flow-step {
    @apply rounded-xl p-3;
  }

  .flow-composer-actions-mobile {
    @apply flex-col gap-2.5 pt-2;
  }

  .flow-composer-actions-mobile :is(.btn, button) {
    @apply w-full justify-center;
  }

  .automations-history {
    @apply overflow-x-hidden;
  }

  .scripts-workbench-tools-backdrop,
  .scripts-workbench-output-backdrop {
    z-index: 35;
  }

  .scripts-workbench-tools-sheet .script-workbench-chat-panel-mobile {
    @apply h-full w-full max-w-full min-w-0;
  }

  .scripts-workbench-tools-sheet .script-workbench-chat-mobile-root {
    @apply h-full w-full max-w-full min-w-0;
  }

  .scripts-workbench-tools-sheet,
  .scripts-workbench-output-sheet {
    max-height: min(88vh, 42rem);
  }

  .scripts-workbench-sheet-header {
    @apply flex-col items-stretch gap-2;
  }

  .scripts-workbench-template-row:focus-visible {
    @apply outline-none ring-2 ring-primary-500/40 ring-inset;
  }

  .scripts-workbench-center {
    background-color: rgb(var(--color-surface-950) / 0.55);
  }

  .scripts-workbench-console {
    @apply relative flex min-h-0 flex-col;
    background-color: rgb(var(--color-surface-950) / 0.92);
  }

  .scripts-workbench-console.is-resizing {
    @apply select-none;
  }

  .scripts-workbench-console-resizer {
    @apply absolute inset-x-0 top-0 z-10 h-1.5 cursor-row-resize;
  }

  .scripts-workbench-console-resizer::after {
    content: "";
    @apply absolute inset-x-8 top-0.5 h-px rounded-full bg-surface-600/0 transition;
  }

  .scripts-workbench-console-resizer:hover::after,
  .scripts-workbench-console.is-resizing .scripts-workbench-console-resizer::after {
    background-color: rgb(var(--color-primary-400) / 0.55);
  }

  .scripts-workbench-console-head {
    @apply flex shrink-0 items-center justify-between gap-2 border-b border-surface-500/30 px-3 py-1;
  }

  .scripts-workbench-console-body {
    @apply min-h-0 flex-1 overflow-y-auto px-3 py-2;
  }

  .scripts-workbench-chat {
    background-color: rgb(var(--color-surface-950) / 0.4);
  }

  .script-workbench-chat-panel:not(.script-workbench-chat-panel-mobile) {
    @apply w-[min(320px,30%)] shrink-0 overflow-hidden border-l border-surface-500/40;
  }

  .vault-link-chip {
    @apply rounded-container-token px-2 py-1.5 text-xs text-primary-300 transition-colors hover:bg-primary-500/10 hover:text-primary-200;
  }

  .vault-links-panel {
    @apply backdrop-blur-sm;
  }

  .vault-save-whisper {
    @apply min-w-[4.5rem] text-right font-medium tracking-wide transition-opacity duration-300;
  }

  .markdown-callout {
    @apply my-3 overflow-hidden rounded-md border border-surface-500/40 bg-surface-800/60;
  }

  .markdown-callout-title {
    @apply border-b border-surface-500/35 px-3 py-1.5 text-xs font-semibold uppercase tracking-wide text-surface-200;
  }

  .markdown-callout-body {
    @apply px-3 py-2 text-surface-200;
  }

  .markdown-callout-body p {
    @apply my-1 first:mt-0 last:mb-0;
  }

  .markdown-callout-note .markdown-callout-title {
    @apply text-primary-300;
    background-color: rgb(var(--color-primary-500) / 0.12);
  }

  .markdown-callout-tip .markdown-callout-title {
    @apply text-success-300;
    background-color: rgb(var(--color-success-500) / 0.12);
  }

  .markdown-callout-warning .markdown-callout-title {
    @apply text-warning-300;
    background-color: rgb(var(--color-warning-500) / 0.12);
  }

  .markdown-callout-danger .markdown-callout-title,
  .markdown-callout-error .markdown-callout-title {
    @apply text-error-300;
    background-color: rgb(var(--color-error-500) / 0.12);
  }

  .markdown-content pre.mermaid {
    @apply my-4 overflow-x-auto rounded-lg border border-surface-500/30 bg-surface-900/80 p-4 text-sm leading-relaxed;
  }

  .markdown-mermaid-error {
    @apply border-error-500/40 text-error-300;
  }

  .markdown-inline-code,
  .markdown-content :not(pre) > code {
    @apply rounded px-1 font-mono text-[0.9em];
  }

  .markdown-content a {
    @apply hover:underline;
  }

  .markdown-highlight,
  .markdown-content mark.markdown-highlight {
    @apply rounded-sm px-0.5;
    background-color: rgb(250 204 21 / 0.35);
    color: inherit;
  }

  html:not(.dark) .markdown-highlight,
  html:not(.dark) .markdown-content mark.markdown-highlight {
    background-color: rgb(254 240 138 / 0.85);
    color: rgb(66 32 6);
  }

  .markdown-color-red,
  .markdown-content .markdown-color-red,
  .markdown-content span.markdown-color-red {
    color: #f87171 !important;
  }

  .markdown-color-orange,
  .markdown-content .markdown-color-orange,
  .markdown-content span.markdown-color-orange {
    color: #fb923c !important;
  }

  .markdown-color-yellow,
  .markdown-content .markdown-color-yellow,
  .markdown-content span.markdown-color-yellow {
    color: #facc15 !important;
  }

  .markdown-color-green,
  .markdown-content .markdown-color-green,
  .markdown-content span.markdown-color-green {
    color: #4ade80 !important;
  }

  .markdown-color-blue,
  .markdown-content .markdown-color-blue,
  .markdown-content span.markdown-color-blue {
    color: #60a5fa !important;
  }

  .markdown-color-purple,
  .markdown-content .markdown-color-purple,
  .markdown-content span.markdown-color-purple {
    color: #c084fc !important;
  }

  .markdown-color-pink,
  .markdown-content .markdown-color-pink,
  .markdown-content span.markdown-color-pink {
    color: #f472b6 !important;
  }

  html:not(.dark) .markdown-color-red,
  html:not(.dark) .markdown-content .markdown-color-red,
  html:not(.dark) .markdown-content span.markdown-color-red {
    color: #dc2626 !important;
  }

  html:not(.dark) .markdown-color-orange,
  html:not(.dark) .markdown-content .markdown-color-orange,
  html:not(.dark) .markdown-content span.markdown-color-orange {
    color: #ea580c !important;
  }

  html:not(.dark) .markdown-color-yellow,
  html:not(.dark) .markdown-content .markdown-color-yellow,
  html:not(.dark) .markdown-content span.markdown-color-yellow {
    color: #ca8a04 !important;
  }

  html:not(.dark) .markdown-color-green,
  html:not(.dark) .markdown-content .markdown-color-green,
  html:not(.dark) .markdown-content span.markdown-color-green {
    color: #16a34a !important;
  }

  html:not(.dark) .markdown-color-blue,
  html:not(.dark) .markdown-content .markdown-color-blue,
  html:not(.dark) .markdown-content span.markdown-color-blue {
    color: #2563eb !important;
  }

  html:not(.dark) .markdown-color-purple,
  html:not(.dark) .markdown-content .markdown-color-purple,
  html:not(.dark) .markdown-content span.markdown-color-purple {
    color: #9333ea !important;
  }

  html:not(.dark) .markdown-color-pink,
  html:not(.dark) .markdown-content .markdown-color-pink,
  html:not(.dark) .markdown-content span.markdown-color-pink {
    color: #db2777 !important;
  }

  .vault-color-swatch {
    @apply relative h-5 w-5 shrink-0 rounded-full border border-surface-600/80 transition hover:scale-110 hover:ring-2 hover:ring-primary-400/50 disabled:opacity-40;
  }

  .vault-color-swatch--custom {
    @apply cursor-pointer overflow-hidden bg-[conic-gradient(from_0deg,#f87171,#facc15,#4ade80,#60a5fa,#c084fc,#f87171)];
  }

  .vault-color-hex {
    position: relative;
    z-index: 41;
    display: inline-flex;
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    vertical-align: middle;
  }

  .vault-color-hex .vault-color-swatch {
    margin: 0;
  }

  .vault-color-hex-scrim {
    position: fixed;
    inset: 0;
    z-index: 39;
  }

  .vault-color-hex-popover {
    position: absolute;
    top: calc(100% + 0.4rem);
    right: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.4);
    border-radius: 0.65rem;
    background: rgb(var(--color-surface-900) / 0.98);
    padding: 0.45rem 0.5rem;
    box-shadow: 0 10px 28px rgb(0 0 0 / 0.3);
  }

  .vault-color-hex-wheel {
    width: 1.75rem;
    height: 1.75rem;
    flex-shrink: 0;
    cursor: pointer;
    border: 1px solid rgb(var(--color-surface-500) / 0.45);
    border-radius: 0.35rem;
    background: transparent;
    padding: 0;
  }

  .vault-color-hex-field {
    width: 5.5rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.35);
    border-radius: 0.4rem;
    background: rgb(var(--color-surface-950) / 0.45);
    padding: 0.28rem 0.4rem;
    color: rgb(var(--color-surface-100));
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.7rem;
    outline: none;
  }

  .vault-color-hex-field:focus {
    border-color: rgb(var(--color-primary-400) / 0.45);
  }

  .vault-color-hex-apply {
    border: 0;
    border-radius: 0.4rem;
    background: rgb(var(--color-primary-500) / 0.88);
    padding: 0.28rem 0.55rem;
    color: rgb(var(--color-surface-950));
    font-size: 0.68rem;
    font-weight: 650;
  }

  .vault-color-hex-apply:hover:not(:disabled) {
    background: rgb(var(--color-primary-400));
  }

  .markdown-code-block {
    @apply my-3 max-w-full min-w-0 overflow-hidden rounded-lg;
    background-color: rgb(var(--md-code-bg)) !important;
    border: 1px solid rgb(var(--md-code-border)) !important;
    box-shadow: var(--md-code-shadow) !important;
  }

  .markdown-code-header {
    @apply flex min-w-0 items-center justify-between gap-2 px-2.5 py-1.5;
    background-color: rgb(var(--md-code-header-bg)) !important;
    border-bottom: 1px solid rgb(var(--md-code-border)) !important;
  }

  .markdown-code-lang {
    @apply min-w-0 truncate px-1 font-mono text-[10px] uppercase tracking-wide;
  }

  .markdown-code-lang-muted {
    @apply normal-case tracking-normal;
  }

  .markdown-code-copy {
    @apply shrink-0 rounded px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide transition;
  }

  .markdown-code-copy-done {
    @apply text-success-300;
  }

  .markdown-pre {
    @apply overflow-x-hidden px-3 py-3;
    background-color: rgb(var(--md-code-bg));
  }

  .markdown-code {
    @apply block bg-transparent font-mono text-[13px] leading-relaxed;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  /* Syntax token colors live in markdown-tokens.postcss */

  /* Mobile shell (M8) */
  .mobile-shell {
    padding-top: env(safe-area-inset-top, 0px);
    height: 100dvh;
    max-height: 100dvh;
  }

  html[data-mobile-composer-active="true"] .mobile-shell {
    position: fixed;
    inset: 0;
    width: 100%;
    overflow: hidden;
  }

  .mobile-shell > main {
    padding-bottom: var(--mobile-bottom-chrome-height, 5.5rem);
  }

  html[data-mobile-composer-active="true"] .mobile-shell > main {
    padding-bottom: 0;
  }

  .mobile-top-bar {
    @apply border-b border-surface-500/40 bg-surface-900/95;
    padding-top: max(0.5rem, env(safe-area-inset-top, 0px));
  }

  .mobile-bottom-chrome {
    @apply fixed bottom-0 left-0 right-0 z-40 flex flex-col;
    box-sizing: border-box;
    padding-bottom: var(--mobile-chrome-safe-bottom, env(safe-area-inset-bottom, 0px));
    background-color: rgb(var(--color-surface-900) / 0.98);
    border-top: 1px solid rgb(var(--color-surface-600) / 0.38);
    -webkit-backdrop-filter: blur(24px) saturate(1.2);
    backdrop-filter: blur(24px) saturate(1.2);
    transition: transform 0.2s ease-out;
  }

  /* Tauri iOS: after ios-webview-insets plugin, env(safe-area-inset-bottom) pads tabs above home indicator. */
  html[data-native-shell="ios"] .mobile-bottom-chrome {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  html[data-mobile-composer-active="true"] .mobile-bottom-chrome {
    transform: translateY(calc(-1 * var(--mobile-keyboard-inset, 0px)));
  }

  html[data-mobile-browser-url-active="true"] [data-browser-bottom-chrome] {
    transform: translateY(calc(-1 * var(--mobile-keyboard-inset, 0px)));
  }

  html[data-mobile-browser-url-active="true"] .mobile-bottom-chrome {
    transform: translateY(calc(-1 * var(--mobile-keyboard-inset, 0px)));
  }

  [data-browser-bottom-chrome],
  html[data-mobile-browser-url-active="true"] .mobile-bottom-chrome {
    transition: transform 0.2s ease-out;
  }

  .mobile-shell:not([data-mobile-tab="chat"]) .mobile-bottom-chrome {
    border-top: 1px solid rgb(var(--color-surface-600) / 0.45);
  }

  /*
   * Web tab: column flex — browser panel + tab bar are siblings in the shell box.
   * Avoids main padding-bottom vs fixed tab bar (native embed host must match its parent).
   */
  .mobile-shell[data-mobile-tab="web"] {
    display: flex;
    flex-direction: column;
  }

  .mobile-shell[data-mobile-tab="web"] > main {
    flex: 1 1 0;
    min-height: 0;
    padding-bottom: 0;
  }

  .mobile-shell[data-mobile-tab="web"] .mobile-bottom-chrome {
    position: relative;
    flex-shrink: 0;
    z-index: 20;
  }

  html:not([data-native-shell="ios"]) .mobile-shell[data-mobile-tab="web"] .mobile-bottom-chrome {
    padding-bottom: 0;
  }

  html[data-native-shell="ios"] .mobile-shell[data-mobile-tab="web"] [data-browser-panel] {
    background: transparent;
  }

  [data-browser-embed-host] {
    contain: layout style;
  }

  /* Desktop native embed: transparent hole in shell webview so child WKWebView shows through. */
  [data-browser-embed-host].pointer-events-none {
    background: transparent !important;
  }

  .mobile-browser-bottom-chrome {
    --browser-chrome-pad-top: 0.375rem;
    --browser-chrome-pad-bottom: 0.25rem;
    --browser-chrome-pad-x: 0.5rem;
    padding: var(--browser-chrome-pad-top) var(--browser-chrome-pad-x)
      var(--browser-chrome-pad-bottom);
  }

  /* iOS native WKWebView: float browser chrome above tab bar (Svelte layer over native embed). */
  html[data-native-shell="ios"] .mobile-shell[data-mobile-tab="web"] [data-browser-bottom-chrome] {
    position: fixed;
    left: 0;
    right: 0;
    bottom: var(--mobile-bottom-chrome-height, 5.5rem);
    z-index: 45;
    pointer-events: auto;
  }

  .mobile-browser-url-pill {
    font-size: 0.8125rem;
  }

  .mobile-browser-url-dock {
    @apply flex w-full min-w-0 flex-1 items-center gap-1 rounded-[22px] px-2 py-1 transition-[border-radius,background-color,box-shadow,border-color] duration-200 ease-out;
    border: 1px solid rgb(var(--color-surface-600) / 0.48);
    background-color: rgb(var(--color-surface-800) / 0.78);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.07),
      inset 0 -1px 0 rgb(0 0 0 / 0.12),
      0 1px 3px rgb(0 0 0 / 0.2);
  }

  .mobile-browser-url-dock:focus-within {
    border-color: rgb(var(--color-surface-500) / 0.58);
    background-color: rgb(var(--color-surface-800) / 0.92);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.09),
      0 0 0 3px rgb(var(--color-primary-500) / 0.14),
      0 4px 16px rgb(0 0 0 / 0.22);
  }

  .mobile-browser-url-dock .mobile-browser-url-pill {
    @apply border-0 bg-transparent px-1 py-1 text-base shadow-none focus:border-0 focus:outline-none focus:ring-0;
  }

  .mobile-chat-composer {
    @apply px-3 pt-1 pb-0.5;
    border-bottom: 1px solid rgb(var(--color-surface-600) / 0.28);
  }

  .mobile-composer-pills {
    @apply mb-2 flex min-w-0 flex-wrap items-center gap-1.5;
  }

  .mobile-composer-pills .mobile-composer-turn {
    @apply min-w-0 flex-1;
  }

  html[data-mobile-composer-active="true"] .mobile-tab-bar-inner {
    display: none;
  }

  .mobile-tab-bar-inner {
    @apply flex h-12 items-center justify-around px-0.5;
  }

  .mobile-tab-btn {
    @apply flex min-w-0 flex-1 flex-col items-center justify-center gap-0.5 rounded-lg px-0.5 py-1 text-[9px] font-medium leading-none text-surface-500 transition active:scale-95;
  }

  @media (min-width: 360px) {
    .mobile-tab-btn {
      @apply text-[10px];
    }
  }

  .mobile-tab-btn-active {
    @apply text-primary-300;
    background-color: rgb(var(--color-primary-500) / 0.1);
  }

  .mobile-icon-btn {
    @apply flex h-10 w-10 items-center justify-center rounded-md text-surface-400 transition hover:bg-surface-800 hover:text-surface-200;
  }

  .mobile-connection-pill {
    @apply rounded-md px-2 py-1.5 transition hover:bg-surface-800/80;
  }

  .mobile-profile-pill {
    @apply inline-flex max-w-[8.5rem] items-center gap-1.5 rounded-full border border-surface-700/80 bg-surface-900/90 px-2.5 py-1.5 transition hover:border-surface-600 hover:bg-surface-800/90 disabled:opacity-50;
  }

  .mobile-profile-monogram {
    @apply flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary-500/20 text-[10px] font-semibold uppercase text-primary-200;
  }

  .mobile-pulse {
    padding-top: max(0.75rem, env(safe-area-inset-top, 0px));
  }

  .mobile-pulse-status {
    @apply flex items-center gap-2 rounded-lg px-1 py-1 transition active:bg-surface-800/60;
  }

  .mobile-alive-dot {
    @apply h-2 w-2 shrink-0 rounded-full;
  }

  .mobile-alive-dot-active {
    animation: mobile-alive-breathe 2.4s ease-in-out infinite;
  }

  @keyframes mobile-alive-breathe {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
      box-shadow: 0 0 0 0 rgb(var(--color-success-500) / 0.35);
    }
    50% {
      opacity: 0.85;
      transform: scale(1.15);
      box-shadow: 0 0 0 6px rgb(var(--color-success-500) / 0);
    }
  }

  .mobile-pulse-eyebrow {
    @apply text-xs font-medium uppercase tracking-[0.2em] text-primary-300/90;
  }

  .mobile-pulse-headline {
    @apply text-[1.75rem] font-semibold leading-[1.15] tracking-tight text-surface-50;
  }

  .mobile-pulse-subline {
    @apply text-sm leading-relaxed text-surface-400;
  }

  .mobile-pulse-cta {
    @apply rounded-2xl py-3 text-base font-semibold;
  }

  .mobile-pulse-shortcuts {
    @apply mt-4 grid grid-cols-3 gap-2;
  }

  .mobile-pulse-shortcut {
    @apply flex min-w-0 flex-col gap-1 rounded-2xl border border-surface-500/35 bg-surface-900/45 px-2.5 py-3 text-left transition active:bg-surface-800/80 disabled:opacity-45;
  }

  .mobile-pulse-shortcut-icon {
    @apply text-surface-400;
  }

  .mobile-pulse-shortcut-label {
    @apply truncate text-sm font-medium text-surface-100;
  }

  .mobile-pulse-shortcut-hint {
    @apply truncate text-[10px] leading-tight text-surface-500;
  }

  .mobile-pulse-whisper {
    @apply text-[11px] text-surface-500;
  }

  .mobile-home {
    background-color: rgb(var(--color-surface-950));
  }

  .mobile-home-cards {
    @apply flex gap-2 overflow-x-auto pb-1;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .mobile-home-cards::-webkit-scrollbar {
    display: none;
  }

  .mobile-home-card {
    @apply flex min-w-[7.5rem] max-w-[9rem] shrink-0 flex-col gap-1 rounded-2xl border border-surface-500/35 bg-surface-900/45 px-2.5 py-3 text-left transition active:bg-surface-800/80 disabled:opacity-45;
  }

  .mobile-home-card-icon {
    @apply text-surface-400;
  }

  .mobile-home-card-label {
    @apply truncate text-sm font-medium text-surface-100;
  }

  .mobile-home-card-hint {
    @apply truncate text-[10px] leading-tight text-surface-500;
  }

  .mobile-home-greeting {
    @apply text-2xl font-semibold tracking-tight text-surface-50;
  }

  .mobile-home-ask {
    @apply flex w-full items-center gap-3 rounded-3xl border border-surface-500/40 bg-surface-900/60 px-5 py-4 text-left shadow-sm transition active:bg-surface-800/70;
  }

  .mobile-home-ask-placeholder {
    @apply min-w-0 flex-1 truncate text-base text-surface-400;
  }

  .mobile-home-ask-send {
    @apply flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary-600 text-surface-50;
  }

  .mobile-home-peer-strip {
    @apply mt-5 rounded-2xl border border-surface-500/30 bg-surface-900/35 px-3 py-3;
  }

  .mobile-home-peer-strip-head {
    @apply mb-2 flex items-center justify-between gap-2 px-0.5;
  }

  .mobile-home-peer-strip-title {
    @apply text-xs font-semibold uppercase tracking-wide text-surface-500;
  }

  .mobile-home-peer-strip-all {
    @apply text-xs font-medium text-primary-300 transition active:text-primary-200;
  }

  .mobile-home-peer-list {
    @apply m-0 list-none p-0;
  }

  .mobile-home-peer-row {
    @apply flex w-full items-center gap-3 rounded-xl px-1 py-2.5 text-left transition active:bg-surface-800/70;
  }

  .mobile-home-peer-avatar {
    @apply flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-500/15 text-sm font-semibold text-primary-200;
  }

  .mobile-home-peer-copy {
    @apply min-w-0 flex-1;
  }

  .mobile-home-peer-top {
    @apply flex items-baseline justify-between gap-2;
  }

  .mobile-home-peer-name {
    @apply truncate text-sm font-medium text-surface-100;
  }

  .mobile-home-peer-time {
    @apply shrink-0 text-[10px] text-surface-500;
  }

  .mobile-home-peer-preview {
    @apply mt-0.5 block truncate text-xs text-surface-500;
  }

  .mobile-home-peer-unread {
    @apply inline-flex min-w-[1.15rem] shrink-0 justify-center rounded-full bg-primary-500 px-1.5 py-0.5 text-[10px] font-bold text-primary-50;
  }

  .mobile-home-statusline {
    @apply mt-3 flex w-full items-center gap-2 px-1 text-sm text-surface-400;
  }

  .mobile-home-fab {
    @apply fixed z-30 flex h-14 w-14 items-center justify-center rounded-full bg-primary-600 text-surface-50 shadow-lg transition active:scale-95;
    right: 1rem;
    bottom: calc(var(--mobile-bottom-chrome-height, 5.5rem) + 0.75rem);
  }

  .mobile-chat-scroll-fab {
    @apply fixed z-20 flex h-11 w-11 items-center justify-center rounded-full border border-surface-500/50 bg-surface-800/95 text-surface-100 shadow-lg backdrop-blur-sm transition active:scale-95;
    right: 1rem;
    bottom: calc(var(--mobile-bottom-chrome-height, 5.5rem) + 0.75rem);
  }

  .mobile-notes-header {
    padding-top: max(0.75rem, env(safe-area-inset-top, 0px));
  }

  .mobile-notes-subheader {
    @apply flex h-14 shrink-0 items-center border-b border-surface-500/40 px-3;
  }

  .mobile-work-status {
    @apply border-b border-surface-500/25;
  }

  .mobile-you-section-title {
    @apply text-xs font-semibold uppercase tracking-[0.16em] text-surface-400;
  }

  .mobile-you-scroll {
    -webkit-overflow-scrolling: touch;
    padding-top: 1rem;
  }

  .mobile-activity-sheet-header {
    @apply items-start;
  }

  .mobile-activity-feed {
    @apply px-4 pb-6 pt-2;
  }

  .mobile-activity-actions {
    @apply mb-3 flex flex-wrap items-center justify-center gap-3;
  }

  .mobile-activity-intro {
    @apply mb-4 text-center text-[11px] text-surface-500;
  }

  .mobile-activity-banner {
    @apply mb-3 rounded-lg border border-error-500/30 bg-error-500/10 px-3 py-2 text-xs;
  }

  .mobile-activity-list {
    @apply space-y-0;
  }

  .mobile-activity-item {
    @apply flex gap-3;
  }

  .mobile-activity-rail {
    @apply flex w-8 shrink-0 flex-col items-center pt-1;
  }

  .mobile-activity-dot {
    @apply flex h-7 w-7 items-center justify-center rounded-full border;
  }

  .mobile-activity-line {
    @apply mt-1 w-px flex-1 rounded-full bg-surface-600/50;
    min-height: 0.75rem;
  }

  .mobile-activity-card {
    @apply mb-4 min-w-0 flex-1 rounded-2xl border px-3.5 py-3;
  }

  .mobile-activity-card-top {
    @apply flex items-center justify-between gap-2;
  }

  .mobile-activity-label {
    @apply text-[11px] font-semibold uppercase tracking-wide;
  }

  .mobile-activity-time {
    @apply shrink-0 text-[10px] text-surface-500;
  }

  .mobile-activity-summary {
    @apply mt-1.5 text-sm leading-snug text-surface-100;
  }

  .mobile-activity-context {
    @apply mt-1 text-xs leading-snug text-surface-500;
  }

  .mobile-activity-success .mobile-activity-dot {
    @apply border-success-500/35 text-success-400;
    background-color: rgb(var(--color-success-500) / 0.1);
  }

  .mobile-activity-success .mobile-activity-card {
    @apply border-success-500/20;
    background-color: rgb(var(--color-success-500) / 0.05);
  }

  .mobile-activity-success .mobile-activity-label {
    @apply text-success-300;
  }

  .mobile-activity-motion .mobile-activity-dot {
    @apply border-primary-500/35 text-primary-300;
    background-color: rgb(var(--color-primary-500) / 0.1);
  }

  .mobile-activity-motion .mobile-activity-card {
    @apply border-primary-500/20;
    background-color: rgb(var(--color-primary-500) / 0.05);
  }

  .mobile-activity-motion .mobile-activity-label {
    @apply text-primary-300;
  }

  .mobile-activity-attention .mobile-activity-dot {
    @apply border-warning-500/35 text-warning-300;
    background-color: rgb(var(--color-warning-500) / 0.1);
  }

  .mobile-activity-attention .mobile-activity-card {
    @apply border-warning-500/25;
    background-color: rgb(var(--color-warning-500) / 0.06);
  }

  .mobile-activity-attention .mobile-activity-label {
    @apply text-warning-300;
  }

  .mobile-activity-vault .mobile-activity-dot {
    @apply border-tertiary-500/35 text-tertiary-300;
    background-color: rgb(var(--color-tertiary-500) / 0.1);
  }

  .mobile-activity-vault .mobile-activity-card {
    @apply border-surface-500/30 bg-surface-800/40;
  }

  .mobile-activity-vault .mobile-activity-label {
    @apply text-tertiary-300;
  }

  .mobile-activity-neutral .mobile-activity-dot {
    @apply border-surface-500/40 text-surface-400;
    @apply bg-surface-800/80;
  }

  .mobile-activity-neutral .mobile-activity-card {
    @apply border-surface-500/30 bg-surface-800/35;
  }

  .mobile-activity-neutral .mobile-activity-label {
    @apply text-surface-400;
  }

  .mobile-activity-empty {
    @apply flex flex-col items-center px-4 py-16 text-center;
  }

  .mobile-activity-empty-icon {
    @apply mb-4 text-surface-600;
  }

  .mobile-pulse-title {
    @apply text-2xl font-semibold leading-tight tracking-tight text-surface-50;
  }

  .mobile-sheet-backdrop {
    @apply fixed inset-0 z-50 flex items-end justify-center p-0;
    background-color: rgb(var(--color-surface-950) / 0.7);
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  .mobile-sheet {
    @apply flex w-full max-h-[85vh] flex-col rounded-t-2xl border border-surface-500/40 bg-surface-900 shadow-xl;
  }

  .mobile-sheet-tall {
    @apply max-h-[92vh];
  }

  .mobile-browser-workshop-sheet {
    max-height: min(88dvh, 820px);
    min-height: min(56dvh, 520px);
  }

  .mobile-browser-workshop-dock {
    bottom: calc(4.75rem + env(safe-area-inset-bottom, 0px));
  }

  .mobile-sheet-peek-backdrop {
    background-color: rgb(var(--color-surface-950) / 0.42);
    backdrop-filter: blur(3px);
  }

  .mobile-sheet-peek {
    @apply max-h-[min(58vh,26rem)] will-change-transform;
    border-radius: 1.25rem 1.25rem 0 0;
    background: rgb(var(--color-surface-900) / 0.98);
    backdrop-filter: blur(20px);
  }

  .mobile-sheet-peek-tall {
    max-height: min(68vh, 30rem);
  }

  .mobile-chat-history-header {
    @apply border-b border-surface-500/35 py-2;
  }

  .mobile-chat-history-search {
    @apply border-b border-surface-500/30 px-3 py-2;
  }

  .mobile-chat-history-list {
    @apply min-h-0 flex-1 space-y-2 overflow-y-auto p-2;
  }

  .mobile-chat-history-new-btn {
    @apply btn btn-sm variant-filled-primary w-full text-sm;
  }

  .mobile-sheet-header {
    @apply flex shrink-0 items-center justify-between border-b border-surface-500/40 px-4 py-3;
  }

  .workshop-rail-sheet-backdrop {
    @apply items-start justify-start p-0;
    background-color: rgb(var(--color-surface-950) / 0.28);
    backdrop-filter: blur(2px);
  }

  .workshop-rail-sheet {
    @apply fixed w-[min(17.5rem,calc(100vw-1rem))] overflow-hidden rounded-xl border border-surface-500/40 shadow-2xl;
    top: 0;
    left: 0;
    max-height: min(32rem, calc(100vh - 1rem));
    background-color: rgb(var(--color-surface-900) / 0.96);
    backdrop-filter: blur(16px);
    animation: workshop-switcher-in 140ms ease-out;
  }

  @keyframes workshop-switcher-in {
    from {
      opacity: 0;
      transform: translateX(-4px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  .workshop-rail-workshop-btn-open {
    @apply ring-2 ring-primary-400/50 ring-offset-2 ring-offset-surface-900;
  }

  .workshop-switcher-menu {
    @apply flex min-h-0 flex-col;
  }

  .workshop-switcher-header {
    @apply shrink-0 px-3 pb-2.5 pt-3;
  }

  .workshop-switcher-title {
    @apply text-[13px] font-semibold tracking-tight text-surface-50;
  }

  .workshop-switcher-subtitle {
    @apply mt-0.5 text-[11px] leading-snug text-surface-500;
  }

  .workshop-switcher-list {
    @apply min-h-0 flex-1 space-y-0.5 overflow-y-auto px-2 py-1;
  }

  .workshop-switcher-row {
    @apply flex w-full items-center gap-2.5 rounded-lg px-2 py-2 text-left transition;
  }

  .workshop-switcher-row:hover {
    @apply bg-surface-800/55;
  }

  .workshop-switcher-row-active {
    background-color: rgb(var(--color-primary-500) / 0.22);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.08),
      inset 0 -1px 0 rgb(0 0 0 / 0.16);
  }

  .workshop-switcher-row-active:hover {
    background-color: rgb(var(--color-primary-500) / 0.28);
  }

  .workshop-switcher-avatar {
    @apply flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-[11px] font-semibold tracking-tight text-surface-50;
    background-color: rgb(var(--color-primary-500) / 0.22);
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.28);
  }

  .workshop-switcher-avatar[style*="--workshop-brand"] {
    background-color: color-mix(in srgb, var(--workshop-brand) 28%, rgb(var(--color-surface-900)));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--workshop-brand) 45%, transparent);
  }

  .workshop-switcher-row-body {
    @apply min-w-0 flex-1;
  }

  .workshop-switcher-row-name {
    @apply truncate text-[13px] font-medium text-surface-50;
  }

  .workshop-switcher-row-meta {
    @apply truncate text-[11px] text-surface-500;
  }

  .workshop-switcher-row-check {
    @apply shrink-0 text-primary-300;
  }

  .workshop-switcher-divider {
    @apply mx-3 my-1.5 h-px bg-surface-700/50;
  }

  .workshop-switcher-action {
    @apply flex w-full items-center gap-2.5 rounded-lg px-3 py-2 text-left text-[13px] text-surface-200 transition hover:bg-surface-800/55;
  }

  .workshop-switcher-action-icon {
    @apply flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-surface-800/80 text-surface-400;
  }

  .workshop-switcher-manage {
    @apply mt-0.5 w-full px-3 py-1.5 text-left text-[11px] text-surface-500 transition hover:text-surface-300;
  }

  .workshop-switcher-footer {
    @apply shrink-0 border-t border-surface-700/35 px-2 pb-2 pt-1.5;
  }

  .mobile-story-overlay {
    @apply fixed inset-0 z-40 flex min-w-0 flex-col overflow-hidden;
    background-color: rgb(var(--color-surface-950));
    padding-top: env(safe-area-inset-top, 0px);
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  .mobile-story-header {
    @apply shrink-0 border-b border-surface-500/40 px-4 py-3;
  }

  .mobile-pull-scroll {
    -webkit-overflow-scrolling: touch;
  }

  .mobile-pull-indicator {
    @apply flex items-end justify-center overflow-hidden transition-[height];
  }

  .mobile-fab {
    @apply fixed z-30 flex h-14 w-14 items-center justify-center rounded-full bg-primary-600 text-surface-50 shadow-lg transition active:scale-95;
    right: 1rem;
    bottom: calc(var(--mobile-bottom-chrome-height, 5.5rem) + 0.75rem);
  }

  .mobile-fab.scripts-workbench-fab {
    bottom: calc(
      var(--mobile-bottom-chrome-height, 5.5rem) + var(--scripts-workbench-status-height, 2rem) + 0.625rem
    );
    z-index: 25;
  }

  .mobile-swipe-row {
    @apply touch-pan-y;
  }

  .mobile-swipe-cancel-bg {
    @apply absolute inset-y-0 right-0 flex w-[5.5rem] items-center justify-center text-xs font-semibold uppercase tracking-wide text-surface-50;
    background-color: rgb(var(--color-error-600) / 0.9);
  }

  .mobile-toast {
    @apply fixed left-4 right-4 z-40 flex items-center gap-3 rounded-lg border border-surface-500/50 bg-surface-800 px-3 py-2.5 shadow-lg;
    bottom: calc(var(--mobile-bottom-chrome-height, 5.5rem) + 1rem);
  }

  .mobile-toast-action {
    @apply shrink-0 text-sm font-semibold text-primary-300;
  }

  .mobile-toast-dismiss {
    @apply shrink-0 px-1 text-sm text-surface-500;
  }

  .chat-restore-toast {
    @apply fixed left-1/2 z-40 flex max-w-md -translate-x-1/2 items-center gap-3 rounded-lg border border-primary-500/20 px-3 py-2 text-[11px] text-surface-300 shadow-lg backdrop-blur-sm;
    bottom: 4.75rem;
    background-color: rgb(var(--color-surface-900) / 0.94);
  }

  .chat-restore-toast-mobile {
    @apply left-4 right-4 max-w-none translate-x-0;
    bottom: calc(var(--mobile-bottom-chrome-height, 5.5rem) + 1rem);
  }

  .chat-restore-toast-dismiss {
    @apply shrink-0 px-1 text-surface-500 transition hover:text-surface-300;
  }

  .mobile-chat-panel {
    @apply flex h-full min-h-0 w-full min-w-0 max-w-full flex-col;
  }

  .mobile-chat-body {
    @apply relative flex min-h-0 min-w-0 w-full max-w-full flex-1 flex-col overflow-hidden;
  }

  .mobile-chat-header {
    @apply shrink-0 border-b border-surface-500/40 bg-surface-900/95 px-3 py-2;
  }

  .mobile-chat-phase {
    @apply flex shrink-0 items-center gap-2 border-b border-primary-500/25 px-4 py-2 text-xs text-primary-200;
    background-color: rgb(var(--color-primary-500) / 0.08);
  }

  .daemon-portal-chip {
    @apply flex min-w-0 items-center gap-2 text-[10px] text-surface-400;
  }

  .daemon-portal-chip-badge {
    @apply shrink-0 rounded-full border border-surface-500/50 bg-surface-900/80 px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-surface-300;
  }

  .mobile-chat-scroll {
    @apply min-h-0 min-w-0 w-full max-w-full flex-1 overflow-x-hidden overflow-y-auto px-3 py-3;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    touch-action: pan-y;
    padding-bottom: 0.375rem;
  }

  html[data-mobile-composer-active="true"] .mobile-chat-scroll {
    padding-bottom: calc(
      var(--mobile-bottom-chrome-height, 5.5rem) + var(--mobile-keyboard-inset, 0px) + 0.375rem
    );
  }

  .mobile-chat-user-row {
    @apply flex w-full min-w-0 max-w-full justify-end;
  }

  .mobile-chat-bubble-user {
    @apply box-border ml-auto block w-fit max-w-[min(100%,85%)] min-w-0 overflow-hidden rounded-2xl rounded-br-md border border-primary-500/15 px-3.5 py-2.5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)];
    background-image: linear-gradient(
      to bottom right,
      rgb(var(--color-primary-500) / 0.12),
      rgb(var(--color-surface-900) / 0.35)
    );
  }

  .mobile-chat-user-text {
    @apply block min-w-0 max-w-full whitespace-pre-wrap break-words text-sm leading-relaxed text-surface-100;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .mobile-chat-bubble-assistant {
    @apply mr-0 min-w-0 max-w-full overflow-hidden border-l-2 border-primary-500/25 py-0.5 pl-3;
  }

  /* Timeline shell: full-width assistant, no left stripe */
  .mobile-chat-voice-full {
    @apply mr-0 min-w-0 max-w-full overflow-hidden border-0 py-0.5 pl-0;
  }

  .mobile-chat-bubble-assistant .chat-voice,
  .mobile-chat-bubble-assistant .markdown-content,
  .mobile-chat-voice-full .chat-voice,
  .mobile-chat-voice-full .markdown-content {
    @apply min-w-0 max-w-full overflow-x-hidden;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  /* iMessage-style growing composer */
  .composer-bar {
    @apply flex items-end gap-1.5 rounded-[22px] px-2 py-1 transition-[border-radius,background-color,box-shadow,border-color,transform] duration-200 ease-out;
    border: 1px solid rgb(var(--color-surface-600) / 0.42);
    background-color: rgb(var(--color-surface-800) / 0.65);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.05),
      0 1px 2px rgb(0 0 0 / 0.16);
  }

  /* Cursor-quiet stacked composer: textarea above, compact footer below */
  .composer-bar.composer-bar-stacked {
    @apply flex-col items-stretch gap-0.5 px-2 py-1.5;
  }

  .composer-bar-stacked-input {
    @apply w-full min-w-0 px-1.5 pt-0.5;
  }

  .composer-bar-footer {
    @apply flex min-w-0 items-center gap-1;
  }

  .composer-bar-footer-spacer {
    @apply min-w-0 flex-1;
  }

  .composer-bar:focus-within {
    border-color: rgb(var(--color-primary-500) / 0.42);
    background-color: rgb(var(--color-surface-800) / 0.82);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.07),
      0 0 0 3px rgb(var(--color-primary-500) / 0.14),
      0 2px 10px rgb(0 0 0 / 0.2);
  }

  .composer-bar:has(.composer-bar-input[data-expanded="true"]) {
    @apply rounded-[20px] py-1.5;
  }

  .composer-bar-mobile {
    @apply gap-1.5 rounded-[22px] px-1.5 py-0.5;
    border-color: rgb(var(--color-surface-600) / 0.48);
    background-color: rgb(var(--color-surface-800) / 0.78);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.07),
      inset 0 -1px 0 rgb(0 0 0 / 0.12),
      0 1px 3px rgb(0 0 0 / 0.2);
  }

  .composer-bar-mobile:focus-within {
    border-color: rgb(var(--color-surface-500) / 0.58);
    background-color: rgb(var(--color-surface-800) / 0.92);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.09),
      0 0 0 3px rgb(var(--color-primary-500) / 0.14),
      0 4px 16px rgb(0 0 0 / 0.22);
  }

  .composer-bar-mobile:has(.composer-bar-input[data-expanded="true"]) {
    @apply rounded-[22px] py-1.5;
  }

  .composer-bar-input {
    @apply min-h-[36px] max-h-32 flex-1 resize-none border-0 bg-transparent py-2 pl-2.5 pr-1 text-sm leading-[1.35] text-surface-50 shadow-none placeholder:text-surface-400 focus:border-0 focus:outline-none focus:ring-0;
    -webkit-font-smoothing: antialiased;
  }

  .composer-bar-mobile .composer-bar-input {
    @apply min-h-[34px] py-1.5 pl-3 pr-0.5 text-base leading-snug;
    letter-spacing: -0.01em;
  }

  .composer-bar-mobile .composer-bar-input::placeholder {
    color: rgb(var(--color-surface-400) / 0.85);
  }

  .composer-bar-send {
    @apply mb-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-[15px] font-semibold transition-all duration-200 ease-out;
    background-color: rgb(var(--color-surface-600) / 0.55);
    color: rgb(var(--color-surface-400));
  }

  .composer-bar-send:disabled {
    opacity: 0.55;
    transform: scale(0.94);
  }

  .composer-bar-send:not(:disabled) {
    background-color: rgb(var(--color-primary-500));
    color: rgb(var(--color-surface-50));
    box-shadow:
      0 1px 2px rgb(0 0 0 / 0.2),
      0 0 12px rgb(var(--color-primary-500) / 0.28);
    transform: scale(1);
  }

  .composer-bar-send:not(:disabled):active {
    transform: scale(0.92);
  }

  .composer-bar-mobile .composer-bar-send {
    @apply mb-0 h-8 w-8 text-sm;
    transition:
      transform 0.22s cubic-bezier(0.34, 1.4, 0.64, 1),
      background-color 0.2s ease,
      box-shadow 0.2s ease,
      opacity 0.2s ease;
  }

  /* Mobile chat dock — separate from .composer-bar row flex (Hermes-style) */
  .mobile-composer-dock {
    @apply flex w-full flex-col items-stretch gap-0 rounded-[22px] px-2 py-1.5 transition-[border-radius,background-color,box-shadow,border-color] duration-200 ease-out;
    border: 1px solid rgb(var(--color-surface-600) / 0.48);
    background-color: rgb(var(--color-surface-800) / 0.78);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.07),
      inset 0 -1px 0 rgb(0 0 0 / 0.12),
      0 1px 3px rgb(0 0 0 / 0.2);
  }

  .mobile-composer-dock:focus-within {
    border-color: rgb(var(--color-surface-500) / 0.58);
    background-color: rgb(var(--color-surface-800) / 0.92);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.09),
      0 0 0 3px rgb(var(--color-primary-500) / 0.14),
      0 4px 16px rgb(0 0 0 / 0.22);
  }

  .mobile-composer-dock-voice {
    @apply flex-row items-end px-1.5 py-0.5;
  }

  .mobile-composer-dock-input.composer-bar-input {
    @apply w-full max-h-36 min-h-[34px] flex-none resize-none border-0 bg-transparent py-1.5 pl-1 pr-1 text-base leading-snug text-surface-50 shadow-none placeholder:text-surface-400 focus:border-0 focus:outline-none focus:ring-0;
    flex: 0 0 auto;
    letter-spacing: -0.01em;
  }

  .mobile-composer-dock-input.composer-bar-input::placeholder {
    color: rgb(var(--color-surface-400) / 0.85);
  }

  .mobile-composer-dock-toolbar {
    @apply flex w-full min-w-0 flex-row items-center gap-1 pb-0.5 pt-1.5;
    border-top: 1px solid rgb(var(--color-surface-600) / 0.25);
  }

  .mobile-composer-dock-spacer {
    @apply min-w-0 flex-1;
  }

  .mobile-composer-select {
    @apply min-w-0 max-w-[9rem] truncate rounded-lg border bg-surface-900/50 px-1.5 py-1 text-[11px] text-surface-300;
    border-color: rgb(var(--color-surface-600) / 0.35);
  }

  .mobile-composer-select:disabled {
    @apply opacity-45;
  }

  .mobile-composer-select-depth {
    max-width: 5.5rem;
  }

  .mobile-composer-turn {
    @apply relative min-w-0 flex-1;
  }

  .mobile-composer-turn-trigger {
    @apply flex max-w-full min-w-0 items-center gap-1 rounded-full px-2.5 py-1.5 text-left transition;
    background: rgb(var(--color-surface-700) / 0.42);
    border: 1px solid rgb(var(--color-surface-600) / 0.28);
  }

  .mobile-composer-turn-trigger--quiet {
    @apply max-w-[10rem] border-transparent bg-transparent px-1.5 py-1;
  }

  .mobile-composer-turn-trigger--quiet .mobile-composer-turn-trigger-label {
    @apply text-[12px] font-normal text-surface-400;
  }

  .mobile-composer-turn-trigger:disabled {
    @apply opacity-45;
  }

  .mobile-composer-turn-trigger-open {
    background: rgb(var(--color-surface-700) / 0.58);
    border-color: rgb(var(--color-surface-500) / 0.38);
  }

  .mobile-composer-turn-trigger-label {
    @apply min-w-0 flex-1 truncate text-[13px] font-medium text-surface-200;
    letter-spacing: -0.01em;
  }

  .mobile-composer-turn-trigger-sep {
    @apply px-0.5 text-surface-500;
  }

  .mobile-composer-turn-trigger-chevron {
    @apply shrink-0 text-surface-500 transition-transform duration-200;
  }

  .mobile-composer-turn-trigger-open .mobile-composer-turn-trigger-chevron {
    transform: rotate(180deg);
  }

  .mobile-turn-sheet-backdrop {
    z-index: 70;
  }

  .mobile-turn-sheet {
    @apply max-h-[min(78vh,640px)] will-change-transform;
    border-radius: 1.25rem 1.25rem 0 0;
    background: rgb(var(--color-surface-900) / 0.98);
    backdrop-filter: blur(24px);
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-turn-sheet-backdrop,
    .mobile-turn-sheet {
      transition: none !important;
      animation: none !important;
    }
  }

  .mobile-turn-sheet-grabber {
    @apply mx-auto mt-2 h-1 w-10 shrink-0 rounded-full;
    background: rgb(var(--color-surface-500) / 0.55);
  }

  .mobile-turn-sheet-header {
    @apply grid shrink-0 grid-cols-[2.5rem_1fr_2.5rem] items-center px-3 pb-2 pt-1;
  }

  .mobile-turn-sheet-title {
    @apply relative overflow-hidden text-center text-[15px] font-semibold text-surface-50;
    letter-spacing: -0.01em;
  }

  .mobile-turn-sheet-title-text {
    @apply block;
  }

  .mobile-turn-sheet-header-spacer {
    @apply h-9 w-9;
  }

  .mobile-turn-sheet-icon-btn {
    @apply flex h-9 w-9 items-center justify-center rounded-full text-surface-300 transition active:scale-95;
    background: rgb(var(--color-surface-800) / 0.72);
  }

  .mobile-turn-sheet-body {
    @apply relative min-h-0 flex-1 overflow-x-hidden overflow-y-auto px-4 pb-6 pt-1;
    padding-bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px));
  }

  .mobile-turn-sheet-panel {
    @apply w-full;
  }

  .mobile-turn-sheet-empty {
    @apply px-1 py-6 text-center text-sm text-surface-500;
  }

  .mobile-turn-sheet-routing-hint {
    @apply mb-3 px-1 text-xs leading-relaxed text-surface-500;
  }

  .mobile-turn-sheet-group {
    @apply overflow-hidden rounded-2xl;
    background: rgb(var(--color-surface-800) / 0.72);
    border: 1px solid rgb(var(--color-surface-600) / 0.28);
  }

  .mobile-turn-sheet-section-label {
    @apply px-4 pb-1 pt-3 text-[11px] font-semibold uppercase tracking-[0.12em] text-surface-500;
  }

  .mobile-turn-sheet-section-gap {
    @apply h-2;
  }

  .mobile-turn-sheet-group-secondary {
    @apply mt-3;
  }

  .mobile-turn-sheet-row {
    @apply flex w-full items-center gap-3 px-4 py-3.5 text-left transition active:bg-surface-700/35;
  }

  .mobile-turn-sheet-row-divider {
    box-shadow: inset 0 1px 0 rgb(var(--color-surface-600) / 0.22);
  }

  .mobile-turn-sheet-row-copy {
    @apply min-w-0 flex-1;
  }

  .mobile-turn-sheet-row-title {
    @apply block text-[15px] font-medium leading-snug text-surface-50;
    letter-spacing: -0.01em;
  }

  .mobile-turn-sheet-row-subtitle {
    @apply mt-0.5 block text-[13px] leading-snug text-surface-500;
  }

  .mobile-turn-sheet-row-check {
    @apply shrink-0 text-primary-400;
  }

  .mobile-turn-sheet-link-row {
    @apply flex w-full items-center justify-between gap-3 px-4 py-3.5 text-left transition active:bg-surface-700/35;
  }

  .mobile-turn-sheet-link-label {
    @apply text-[15px] font-medium text-surface-100;
  }

  .mobile-turn-sheet-link-value {
    @apply inline-flex items-center gap-0.5 text-[15px] text-surface-500;
  }

  .mobile-turn-sheet-link-chevron {
    @apply text-surface-600;
  }

  .mobile-composer-dock .composer-bar-send {
    @apply mb-0 h-8 w-8 shrink-0 text-sm;
  }

  .composer-bar-send-text {
    @apply h-8 w-auto min-w-[3.25rem] px-3.5 text-xs font-semibold;
  }

  /* Cron — composer-style fields; 16px inputs on mobile prevent iOS focus zoom */
  .cron-create-form {
    @apply mt-3 space-y-4;
  }

  .cron-field-label {
    @apply mb-1.5 block text-[10px] uppercase tracking-wide text-surface-500;
  }

  .cron-field-bar {
    @apply rounded-[14px];
  }

  .cron-field-bar-compact {
    @apply px-2.5 py-0.5;
  }

  .cron-field-input,
  .cron-search-input {
    @apply min-h-[36px] w-full border-0 bg-transparent py-2 pl-1 pr-1 text-base leading-snug text-surface-50 shadow-none placeholder:text-surface-400 focus:border-0 focus:outline-none focus:ring-0;
    -webkit-font-smoothing: antialiased;
  }

  .cron-search-bar {
    @apply rounded-[14px] px-2.5 py-0.5;
  }

  .cron-search-input {
    @apply pl-2;
  }

  .cron-field-row {
    @apply grid gap-3 sm:grid-cols-[minmax(0,1.6fr)_minmax(0,1fr)];
  }

  .cron-field-hint {
    @apply text-xs text-surface-500;
  }

  .cron-form-actions {
    @apply flex flex-wrap gap-2 border-t border-surface-500/30 pt-4;
  }

  .cron-create-form-mobile :is(.cron-field-input, .composer-bar-input),
  .cron-panel-mobile :is(.cron-search-input, .composer-bar-input) {
    font-size: 16px;
    line-height: 1.35;
  }

  .cron-panel-mobile .cron-create-form {
    @apply pb-8;
  }

  .cron-panel-mobile .cron-form-actions {
    @apply flex-col gap-2.5;
  }

  .cron-panel-mobile .cron-form-submit {
    @apply w-full;
  }

  .mobile-you-header {
    @apply shrink-0 border-b border-surface-500/40 px-4 py-3;
  }

  .mobile-you-subheader {
    @apply flex h-14 shrink-0 items-center border-b border-surface-500/40 px-3;
  }

  .mobile-you-destination {
    @apply flex w-full items-center gap-3 rounded-xl border border-surface-500/35 px-3 py-3.5 text-left transition active:bg-surface-800/80;
  }

  .mobile-you-destination-icon {
    @apply flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-surface-800 text-surface-300;
  }

  .mobile-you-row {
    @apply rounded-lg px-3 py-2.5 transition active:bg-surface-800/80;
  }

  .mobile-library-tabs {
    @apply shrink-0;
  }

  .mobile-library-tab {
    @apply flex-1 rounded-lg border border-transparent px-3 py-2 text-center text-xs font-semibold text-surface-400 transition active:bg-surface-800/80;
  }

  .mobile-library-tab-active {
    @apply border-surface-500/45 bg-surface-800/70 text-surface-100;
  }

  .mobile-channel-strip {
    -webkit-overflow-scrolling: touch;
  }

  .mobile-channel-chip {
    @apply flex shrink-0 flex-col items-start gap-0.5 rounded-lg border border-surface-500/40 px-3 py-2 text-left text-xs text-surface-300;
  }

  .mobile-channel-chip-active {
    @apply border-primary-500/45 text-surface-100;
    background-color: rgb(var(--color-primary-500) / 0.1);
  }

  /* Messaging — workshop-native channel accents */
  .messaging-channel-icon {
    @apply flex shrink-0 items-center justify-center rounded-lg ring-1 ring-inset;
  }

  .messaging-channel-icon-lg {
    @apply h-11 w-11 rounded-xl;
  }

  .messaging-channel-icon:not(.messaging-channel-icon-lg) {
    @apply h-9 w-9;
  }

  .messaging-channel-icon-primary {
    background-color: rgb(var(--color-primary-500) / 0.2);
    color: rgb(var(--color-primary-300));
    --tw-ring-color: rgb(var(--color-primary-500) / 0.34);
  }

  .messaging-channel-icon-secondary {
    background-color: rgb(var(--color-secondary-500) / 0.2);
    color: rgb(var(--color-secondary-300));
    --tw-ring-color: rgb(var(--color-secondary-500) / 0.34);
  }

  .messaging-channel-icon-tertiary {
    background-color: rgb(var(--color-tertiary-500) / 0.18);
    color: rgb(var(--color-tertiary-300));
    --tw-ring-color: rgb(var(--color-tertiary-500) / 0.32);
  }

  .messaging-channel-icon-success {
    background-color: rgb(var(--color-success-500) / 0.16);
    color: rgb(var(--color-success-400));
    --tw-ring-color: rgb(var(--color-success-500) / 0.28);
  }

  .messaging-status-dot {
    @apply mt-1.5 h-2 w-2 shrink-0 rounded-full;
  }

  .messaging-status-dot-live {
    background-color: rgb(var(--color-primary-400));
    box-shadow: 0 0 10px rgb(var(--color-primary-500) / 0.45);
  }

  .messaging-status-dot-ready {
    background-color: rgb(var(--color-primary-500) / 0.55);
  }

  .messaging-status-dot-setup {
    @apply bg-surface-600;
  }

  .workshop-liveliness-chip,
  .messaging-liveliness-chip {
    @apply inline-flex items-center rounded-full px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-wide;
  }

  .workshop-liveliness-chip-live,
  .messaging-liveliness-chip-live {
    background-color: rgb(var(--color-primary-500) / 0.16);
    color: rgb(var(--color-primary-300));
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.28);
  }

  .workshop-liveliness-chip-ready,
  .messaging-liveliness-chip-ready {
    background-color: rgb(var(--color-primary-500) / 0.1);
    color: rgb(var(--color-primary-300));
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.2);
  }

  .workshop-liveliness-chip-setup,
  .messaging-liveliness-chip-setup {
    @apply bg-surface-800 text-surface-500;
    box-shadow: inset 0 0 0 1px rgb(var(--color-surface-500) / 0.35);
  }

  .workshop-liveliness-chip-muted,
  .messaging-liveliness-chip-muted {
    @apply bg-surface-800 text-surface-400;
    box-shadow: inset 0 0 0 1px rgb(var(--color-surface-500) / 0.3);
  }

  .workshop-liveliness-chip-scheduled {
    background-color: rgb(var(--color-primary-500) / 0.12);
    color: rgb(var(--color-primary-300));
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.22);
  }

  .workshop-liveliness-chip-paused {
    @apply bg-surface-800 text-surface-500;
    box-shadow: inset 0 0 0 1px rgb(var(--color-surface-500) / 0.32);
  }

  .workshop-liveliness-chip-running {
    background-color: rgb(var(--color-primary-500) / 0.18);
    color: rgb(var(--color-primary-200));
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.32);
  }

  .workshop-liveliness-chip-warning {
    background-color: rgb(var(--color-warning-500) / 0.14);
    color: rgb(var(--color-warning-300));
    box-shadow: inset 0 0 0 1px rgb(var(--color-warning-500) / 0.28);
  }

  .messaging-guide-link {
    @apply mt-3 inline-flex items-center gap-1.5 rounded-container-token px-3 py-2 text-sm font-medium transition;
    background-color: rgb(var(--color-primary-500) / 0.1);
    color: rgb(var(--color-primary-300));
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.22);
  }

  .messaging-guide-link:hover {
    background-color: rgb(var(--color-primary-500) / 0.16);
    color: rgb(var(--color-primary-200));
  }

  .messaging-credentials-inset {
    @apply workshop-inset p-4;
    border-left-width: 3px;
    border-left-color: rgb(var(--color-primary-500) / 0.35);
  }

  .messaging-credentials-inset-tertiary {
    border-left-color: rgb(var(--color-tertiary-500) / 0.4);
  }

  .messaging-credentials-inset-secondary {
    border-left-color: rgb(var(--color-secondary-500) / 0.4);
  }

  .messaging-credentials-inset-primary {
    border-left-color: rgb(var(--color-primary-500) / 0.45);
  }

  .messaging-credentials-inset-success {
    border-left-color: rgb(var(--color-success-500) / 0.38);
  }

  /* Settings — color theme picker */
  .theme-option {
    @apply flex w-full items-start gap-3 rounded-container-token border border-surface-500/40 bg-surface-800/60 p-3 text-left transition hover:border-surface-500/60 hover:bg-surface-800;
  }

  .theme-option-active {
    @apply border-primary-500/45 ring-1 ring-inset ring-primary-500/30;
    background-color: rgb(var(--color-primary-500) / 0.06);
  }

  .theme-option-swatches {
    @apply flex h-12 w-16 shrink-0 overflow-hidden rounded-md border border-surface-500/35;
  }

  .theme-option-swatches span {
    @apply block h-full flex-1;
  }

  /* Settings — M10 shell */
  .settings-panel {
    background-color: rgb(var(--color-surface-950));
  }

  .settings-summary-strip {
    @apply text-surface-400;
  }

  .settings-shell-nav {
    @apply w-full lg:w-52 xl:w-56;
  }

  .settings-nav {
    @apply flex flex-col gap-1;
  }

  .settings-nav-item {
    @apply rounded-container-token px-3 py-2.5 text-left transition hover:bg-surface-800/80;
  }

  .settings-nav-item-active {
    @apply bg-primary-500/10 ring-1 ring-inset ring-primary-500/30;
  }

  .settings-nav-mobile {
    @apply -mx-1;
  }

  .settings-nav-chip {
    @apply shrink-0 rounded-full border border-surface-500/40 px-3 py-1.5 text-xs font-medium text-surface-300;
  }

  .settings-nav-chip-active {
    @apply border-primary-500/45 bg-primary-500/10 text-primary-200;
  }

  .settings-section-header {
    @apply max-w-2xl;
  }

  .settings-toggle-list {
    @apply divide-y divide-surface-500/35 rounded-container-token border border-surface-500/35 bg-surface-900/30;
  }

  .settings-toggle-row {
    @apply flex cursor-pointer items-center gap-4 px-4 py-3.5;
  }

  .settings-metric-row {
    cursor: default;
  }

  .settings-metric-value {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .settings-metric-input {
    width: 3.25rem;
    height: 1.85rem;
    border-radius: 0.45rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.45);
    background: rgb(var(--shell-pane-bg, var(--color-surface-900)) / 0.55);
    padding: 0 0.4rem;
    text-align: center;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
    color: rgb(var(--shell-label, var(--color-surface-100)));
    appearance: textfield;
    -moz-appearance: textfield;
  }

  .settings-metric-input-wide {
    width: 4.5rem;
  }

  .settings-metric-input:focus {
    outline: none;
    border-color: rgb(var(--color-primary-500) / 0.55);
    box-shadow: 0 0 0 2px rgb(var(--color-primary-500) / 0.18);
  }

  .settings-metric-input:disabled,
  .settings-metric-input:read-only {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .settings-metric-input::-webkit-outer-spin-button,
  .settings-metric-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .settings-metric-unit {
    font-size: 0.75rem;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    min-width: 2.5rem;
  }

  .settings-subsection-heading {
    margin: 0 0 0.35rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgb(var(--shell-label, var(--color-surface-100)));
  }

  .settings-subsection-lead {
    margin: 0 0 0.65rem;
    font-size: 0.75rem;
    line-height: 1.45;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
  }

  .settings-charter-line {
    @apply max-w-2xl leading-relaxed;
  }

  .settings-depth-card {
    @apply rounded-container-token border border-surface-500/40 bg-surface-900/30 px-3 py-3 text-left transition;
  }

  .settings-depth-card:hover:not(:disabled) {
    @apply border-surface-400/50 bg-surface-800/50;
  }

  .settings-depth-card-active {
    @apply border-primary-500/45 bg-primary-500/10 ring-1 ring-inset ring-primary-500/25;
  }

  .settings-depth-card:disabled {
    @apply cursor-not-allowed opacity-70;
  }

  .settings-profile-stack {
    @apply flex max-w-2xl flex-col gap-4;
  }

  .settings-profile-card {
    @apply rounded-2xl border border-surface-500/35 p-4;
    background: linear-gradient(
      180deg,
      rgb(var(--color-surface-900) / 0.55),
      rgb(var(--color-surface-900) / 0.35)
    );
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.04);
  }

  .settings-profile-header {
    @apply flex items-start justify-between gap-3;
  }

  .settings-profile-title {
    @apply text-sm font-semibold text-surface-50;
  }

  .settings-profile-subtitle {
    @apply mt-1 text-xs leading-relaxed text-surface-500;
  }

  .settings-profile-status {
    @apply shrink-0 rounded-full px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em];
  }

  .settings-profile-status-ok {
    background-color: rgb(var(--color-success-500) / 0.15);
    @apply text-success-300;
  }

  .settings-profile-status-warn {
    background-color: rgb(var(--color-warning-500) / 0.12);
    @apply text-warning-200;
  }

  .settings-profile-current {
    @apply mt-4 flex items-center gap-3 rounded-xl border border-surface-600/30 bg-surface-900/45 px-3 py-2.5;
  }

  .settings-profile-favorite-btn {
    @apply inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-surface-500 transition hover:text-surface-200 disabled:opacity-45;
    border: 1px solid rgb(var(--color-surface-600) / 0.35);
    background: rgb(var(--color-surface-900) / 0.45);
  }

  .settings-profile-favorite-btn.is-active {
    @apply text-primary-200;
    border-color: rgb(var(--color-primary-500) / 0.35);
    background-color: rgb(var(--color-primary-500) / 0.12);
  }

  .settings-favorites-list {
    @apply mt-3 space-y-2;
  }

  .settings-favorites-row {
    @apply flex items-stretch gap-2;
  }

  .settings-favorites-main {
    @apply flex min-w-0 flex-1 items-center gap-3 rounded-xl border border-surface-600/30 bg-surface-900/35 px-3 py-2.5 text-left transition hover:border-surface-500/45 hover:bg-surface-800/45 disabled:opacity-45;
  }

  .settings-favorites-main.is-active {
    @apply border-primary-500/40;
    background-color: rgb(var(--color-primary-500) / 0.1);
  }

  .settings-favorites-remove {
    @apply shrink-0 rounded-xl border border-surface-600/35 px-3 text-xs font-medium text-surface-400 transition hover:border-surface-500/45 hover:text-surface-200 disabled:opacity-45;
  }

  .settings-profile-badge {
    @apply flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-[10px] font-semibold tracking-[0.06em] text-primary-100;
    background: linear-gradient(
      145deg,
      rgb(var(--color-primary-500) / 0.4),
      rgb(var(--color-secondary-700) / 0.32)
    );
  }

  .settings-profile-model {
    @apply truncate text-sm font-medium text-surface-100;
  }

  .settings-profile-provider {
    @apply truncate text-xs text-surface-500;
  }

  .settings-profile-detail {
    @apply mt-3 text-xs leading-relaxed text-surface-400;
  }

  .settings-profile-footnote {
    @apply max-w-2xl text-xs text-surface-500;
  }

  .settings-profile-quick {
    @apply mt-4;
  }

  .settings-profile-quick-label {
    @apply mb-2 block text-[10px] font-medium uppercase tracking-[0.14em] text-surface-500;
  }

  .settings-profile-quick-row {
    @apply flex flex-wrap gap-2;
  }

  .settings-profile-quick-btn {
    @apply rounded-full border border-surface-600/40 px-3 py-1.5 text-xs font-medium text-surface-300 transition hover:border-surface-500/55 hover:text-surface-100 disabled:opacity-45;
  }

  .settings-profile-quick-btn-active {
    @apply border-primary-500/40 bg-primary-500/10 text-primary-100;
  }

  .settings-profile-key {
    @apply mt-4;
  }

  .settings-profile-key-row {
    @apply flex flex-wrap items-center justify-between gap-2 rounded-xl border border-surface-600/35 bg-surface-900/40 px-3 py-2.5;
  }

  .settings-profile-key-label {
    @apply block text-xs font-medium text-surface-300;
  }

  .settings-profile-key-action {
    @apply text-xs font-medium text-primary-300 transition hover:text-primary-100;
  }

  .settings-profile-key-input {
    @apply input mt-2 w-full font-mono text-sm;
  }

  .settings-advanced-toggle {
    @apply mt-4 flex w-full items-center justify-between gap-2 rounded-xl px-2 py-2 text-left text-xs font-medium text-surface-400 transition hover:bg-surface-800/45 hover:text-surface-200 disabled:opacity-45;
  }

  .settings-advanced-chevron {
    @apply shrink-0 transition-transform duration-200;
  }

  .settings-advanced-chevron.is-open {
    transform: rotate(180deg);
  }

  .settings-advanced-panel {
    @apply mt-2 rounded-xl border border-surface-600/30 p-3;
    background-color: rgb(var(--color-surface-950) / 0.4);
  }

  .settings-choice-segment {
    @apply grid gap-2 sm:grid-cols-3;
  }

  .settings-choice-segment-btn {
    @apply rounded-xl border border-surface-600/35 bg-surface-900/35 px-3 py-3 text-left transition hover:border-surface-500/45 hover:bg-surface-800/45 disabled:opacity-45;
  }

  .settings-choice-segment-btn-active {
    @apply border-primary-500/40 bg-primary-500/10 ring-1 ring-inset ring-primary-500/20;
  }

  .settings-choice-segment-label {
    @apply block text-sm font-medium text-surface-100;
  }

  .settings-choice-segment-hint {
    @apply mt-1 block text-[11px] leading-snug text-surface-500;
  }

  .settings-profile-list-row {
    @apply flex flex-wrap items-center justify-between gap-3 rounded-xl border border-surface-600/30 bg-surface-900/35 px-3 py-2.5;
  }

  .settings-profile-progress-track {
    @apply h-2 overflow-hidden rounded-full bg-surface-800;
  }

  .settings-profile-progress-fill {
    @apply h-full rounded-full bg-primary-500 transition-all duration-300;
  }

  .settings-inline-status {
    @apply mt-3 max-w-2xl text-xs text-surface-300;
  }

  .settings-segmented {
    @apply inline-flex max-w-md rounded-container-token border border-surface-500/40 bg-surface-900/50 p-1;
  }

  .settings-segmented-btn {
    @apply min-h-9 flex-1 rounded-container-token px-4 text-sm font-medium text-surface-400 transition;
  }

  .settings-segmented-btn-active {
    @apply bg-primary-500/15 text-surface-50 shadow-sm ring-1 ring-primary-500/25;
  }

  .settings-section-models {
    @apply relative pb-12;
  }

  .models-workshop-status {
    @apply flex flex-wrap gap-2;
  }

  .models-workshop-status-chip {
    @apply inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-xs;
  }

  .models-workshop-status-ok {
    @apply border-success-500/25 bg-success-500/10 text-surface-200;
  }

  .models-workshop-status-warn {
    @apply border-warning-500/30 bg-warning-500/10 text-surface-200;
  }

  .models-workshop-status-neutral {
    @apply border-surface-500/30 bg-surface-900/40 text-surface-400;
  }

  .models-workshop-status-dot {
    @apply h-1.5 w-1.5 shrink-0 rounded-full;
  }

  .models-workshop-status-ok .models-workshop-status-dot {
    @apply bg-success-400;
  }

  .models-workshop-status-warn .models-workshop-status-dot {
    @apply bg-warning-400;
  }

  .models-workshop-status-neutral .models-workshop-status-dot {
    @apply bg-surface-500;
  }

  .models-workshop-status-label {
    @apply font-medium text-surface-200;
  }

  .models-workshop-status-detail {
    @apply text-surface-400;
  }

  .models-save-toast {
    @apply pointer-events-none fixed bottom-16 left-1/2 z-40 -translate-x-1/2 rounded-full border border-surface-500/40 bg-surface-900/95 px-4 py-2 text-xs text-surface-300 shadow-lg backdrop-blur-sm;
  }

  .models-save-toast-ok {
    @apply border-success-500/30 text-success-300;
  }

  .settings-native-nested {
    @apply border-t border-surface-500/20 bg-surface-900/25 pl-2;
  }

  .settings-native-row-monogram {
    @apply flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-surface-800 text-[10px] font-semibold text-surface-200;
  }

  .settings-native-row-value-accent {
    @apply font-medium text-surface-100;
  }

  .settings-native-row-chevron-open {
    transform: rotate(90deg);
  }

  .settings-native-row-expanded {
    @apply bg-surface-800/35;
  }

  .settings-native-stack {
    @apply max-w-xl space-y-6;
  }

  .settings-native-heading {
    @apply text-xs font-semibold uppercase tracking-wide text-surface-400;
  }

  .settings-native-subheading {
    @apply px-4 pt-2 text-[11px] font-medium uppercase tracking-wide text-surface-500;
  }

  .settings-native-footnote {
    @apply mt-1 text-xs leading-relaxed text-surface-500;
  }

  .settings-native-group {
    @apply mt-2 overflow-hidden rounded-container-token border border-surface-500/35 bg-surface-900/30;
  }

  .settings-native-group-spaced {
    @apply mt-3;
  }

  .settings-native-row {
    @apply flex w-full items-center gap-2 border-b border-surface-500/25 px-4 py-3 text-left transition hover:bg-surface-800/50 disabled:cursor-not-allowed disabled:opacity-50;
  }

  .settings-native-row:last-child {
    @apply border-b-0;
  }

  .settings-native-row-destructive .settings-native-row-label {
    @apply text-error-400;
  }

  .settings-native-row-copy {
    @apply min-w-0 flex-1;
  }

  .settings-native-row-label {
    @apply block text-sm text-surface-100;
  }

  .settings-native-row-hint {
    @apply mt-0.5 block text-xs text-surface-500;
  }

  .settings-native-row-value {
    @apply max-w-[42%] truncate text-sm text-surface-400;
  }

  .settings-native-row-chevron {
    @apply shrink-0 text-surface-500;
  }

  .settings-native-row-add {
    @apply items-center gap-2 text-surface-300;
  }

  .settings-native-row-add-icon {
    @apply text-surface-500;
  }

  .settings-native-favorite-row {
    @apply flex items-center gap-3 border-b border-surface-500/25 px-4 py-3;
  }

  .settings-native-favorite-badge {
    @apply flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-surface-800 text-[11px] font-semibold text-surface-200;
  }

  .settings-native-favorite-copy {
    @apply min-w-0 flex-1;
  }

  .settings-native-favorite-name {
    @apply block text-sm text-surface-100;
  }

  .settings-native-favorite-meta {
    @apply block text-xs text-surface-500;
  }

  .settings-native-icon-btn {
    @apply flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-surface-400 transition hover:bg-surface-800 hover:text-surface-100;
  }

  .model-catalog-backdrop {
    @apply fixed inset-0 z-50 flex items-end justify-center bg-black/60 p-4 backdrop-blur-sm sm:items-center;
  }

  .model-catalog-sheet {
    @apply flex max-h-[min(720px,90vh)] w-full max-w-2xl flex-col overflow-hidden rounded-container-token border border-surface-500/40 bg-surface-900 shadow-2xl ring-1 ring-white/5;
  }

  .model-catalog-sheet-narrow {
    @apply max-w-md;
  }

  .model-catalog-sheet-header {
    @apply flex items-start gap-3 border-b border-surface-500/30 px-4 py-4;
  }

  .model-catalog-sheet-title {
    @apply text-base font-semibold text-surface-50;
  }

  .model-catalog-sheet-subtitle {
    @apply mt-0.5 text-xs text-surface-500;
  }

  .model-catalog-sheet-close {
    @apply flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-surface-400 hover:bg-surface-800 hover:text-surface-100;
  }

  .model-catalog-sheet-back {
    @apply -ml-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-surface-400 hover:bg-surface-800 hover:text-surface-100;
  }

  .model-catalog-provider-list {
    @apply flex-1 space-y-1 overflow-y-auto px-2 pb-4;
  }

  .model-catalog-provider-group-label {
    @apply px-2 pb-1 pt-3 text-[11px] font-semibold uppercase tracking-wide text-surface-500;
  }

  .model-catalog-provider-row {
    @apply flex w-full items-center gap-3 rounded-container-token px-2 py-2.5 text-left transition hover:bg-surface-800/60 active:bg-surface-800;
  }

  .model-catalog-provider-row-clear {
    @apply mb-1 border border-dashed border-surface-500/35;
  }

  .model-catalog-provider-row-copy {
    @apply min-w-0 flex-1;
  }

  .model-catalog-provider-row-label {
    @apply block text-sm font-medium text-surface-100;
  }

  .model-catalog-provider-row-hint {
    @apply mt-0.5 block line-clamp-2 text-xs leading-snug text-surface-500;
  }

  .model-catalog-provider-row-chevron {
    @apply shrink-0 text-surface-500;
  }

  .model-catalog-manual {
    @apply flex shrink-0 flex-col gap-2 border-t border-surface-500/30 bg-surface-900/80 px-4 py-3 sm:flex-row sm:items-end;
  }

  .model-catalog-manual-label {
    @apply min-w-0 flex-1;
  }

  .model-catalog-manual-title {
    @apply mb-1.5 block text-xs font-medium text-surface-400;
  }

  .model-catalog-manual-input {
    @apply w-full rounded-container-token border border-surface-500/35 bg-surface-900/50 px-3 py-2 font-mono text-sm text-surface-100 placeholder:text-surface-500 focus:border-primary-500/40 focus:outline-none;
  }

  .model-catalog-manual-btn {
    @apply shrink-0 rounded-container-token border border-primary-500/35 bg-primary-500/10 px-4 py-2 text-sm font-medium text-surface-50 transition hover:bg-primary-500/20 disabled:cursor-not-allowed disabled:opacity-40;
  }

  .model-catalog-custom-form {
    @apply flex flex-1 flex-col gap-4 overflow-y-auto px-4 pb-4;
  }

  .model-catalog-custom-field {
    @apply block;
  }

  .model-catalog-custom-label {
    @apply block text-sm font-medium text-surface-100;
  }

  .model-catalog-custom-hint {
    @apply mt-0.5 block text-xs leading-snug text-surface-500;
  }

  .model-catalog-custom-field .model-catalog-manual-input {
    @apply mt-2;
  }

  .model-catalog-custom-error {
    @apply text-sm text-warning-400;
  }

  .model-catalog-custom-continue {
    @apply mt-2 w-full sm:w-auto;
  }

  .model-catalog-provider-tabs {
    @apply flex gap-2 overflow-x-auto border-b border-surface-500/25 px-4 py-3;
  }

  .model-catalog-provider-tab {
    @apply shrink-0 rounded-full border border-transparent px-3 py-1.5 text-xs font-medium text-surface-400 transition;
  }

  .model-catalog-provider-tab-active {
    @apply border-primary-500/35 bg-primary-500/10 text-surface-50;
  }

  .model-catalog-search {
    @apply mx-4 mt-3 flex items-center gap-2 rounded-container-token border border-surface-500/35 bg-surface-900/50 px-3 py-2;
  }

  .model-catalog-search-icon {
    @apply shrink-0 text-surface-500;
  }

  .model-catalog-search-input {
    @apply min-w-0 flex-1 border-0 bg-transparent text-sm text-surface-100 placeholder:text-surface-500 focus:outline-none;
  }

  .model-catalog-grid {
    @apply grid flex-1 grid-cols-1 gap-2 overflow-y-auto p-4 sm:grid-cols-2;
  }

  .model-catalog-tile {
    @apply flex flex-col items-start gap-1.5 rounded-container-token border border-surface-500/30 bg-surface-900/40 p-3.5 text-left transition duration-150 hover:border-surface-400/40 hover:bg-surface-800/50 active:scale-[0.99];
  }

  .model-catalog-tile-selected {
    @apply border-primary-500/45 bg-primary-500/10 ring-1 ring-primary-500/20;
  }

  .model-catalog-tile-head {
    @apply flex w-full items-center gap-2.5;
  }

  .model-catalog-tile-monogram {
    @apply flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-surface-800 text-[10px] font-semibold text-surface-200;
  }

  .model-catalog-tile-clear {
    @apply border-dashed;
  }

  .model-catalog-tile-name {
    @apply text-sm font-medium text-surface-100;
  }

  .model-catalog-tile-meta {
    @apply line-clamp-1 font-mono text-[11px] text-surface-500;
  }

  .model-catalog-empty {
    @apply col-span-full py-8 text-center text-sm text-surface-500;
  }

  .settings-connection-card {
    max-width: 36rem;
    border-radius: var(--theme-rounded-container, 0.75rem);
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.4);
    background: rgb(var(--shell-pane-bg, var(--color-surface-900)) / 0.55);
    padding: 1rem;
  }

  .settings-connection-icon {
    @apply flex h-9 w-9 shrink-0 items-center justify-center rounded-full;
  }

  .settings-connection-icon-ok {
    background-color: rgb(var(--color-success-500) / 0.15);
    @apply text-success-400;
  }

  .settings-connection-icon-off {
    background: rgb(var(--shell-pane-muted-bg, var(--color-surface-800)));
    color: rgb(var(--shell-muted, var(--color-surface-400)));
  }

  .settings-connection-meta {
    margin: 0;
    display: grid;
    gap: 0.45rem;
  }

  .settings-connection-meta-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.75rem;
  }

  .settings-connection-meta-row dt {
    color: rgb(var(--shell-muted, var(--color-surface-500)));
    flex-shrink: 0;
  }

  .settings-connection-meta-row dd {
    margin: 0;
    color: rgb(var(--shell-label, var(--color-surface-300)));
    text-align: right;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .settings-hub-list {
    @apply divide-y divide-surface-500/35 overflow-hidden rounded-container-token border border-surface-500/35;
  }

  .settings-hub-row {
    @apply flex w-full items-center gap-3 px-4 py-3.5 text-left transition hover:bg-surface-800/60;
  }

  .settings-hub-icon {
    @apply flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-surface-800 text-surface-300;
  }

  /* Black Lily / Obsidian theme overlays live in theme-*.postcss */

  /* Light mode shell regions live in workshop-shell.postcss (--shell-* tokens). */

  /* Temporary layout debug — enabled via data-layout-debug on Tauri iOS */
  html[data-layout-debug] body {
    outline: 3px solid #f97316;
    outline-offset: -3px;
  }

  html[data-layout-debug] .mobile-shell {
    outline: 3px solid #0ea5e9;
    outline-offset: -3px;
  }

  html[data-layout-debug] .mobile-bottom-chrome {
    outline: 3px solid #ef4444;
    background-color: rgb(239 68 68 / 0.1) !important;
  }

  html[data-layout-debug] .mobile-tab-bar-inner {
    outline: 3px solid #84cc16;
  }

  html[data-layout-debug] .mobile-chat-composer {
    outline: 3px solid #a855f7;
  }

  html[data-layout-debug]::after {
    content: "";
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    height: 3px;
    background: #ec4899;
    z-index: 99998;
    pointer-events: none;
  }

  html[data-layout-debug][data-native-shell="ios"] .mobile-bottom-chrome::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    height: env(safe-area-inset-bottom, 0px);
    background: rgb(6 182 212 / 0.5);
    pointer-events: none;
    z-index: 2;
  }

  html[data-layout-debug] .mobile-layout-debug-hud {
    position: fixed;
    top: max(0.5rem, env(safe-area-inset-top, 0px));
    left: 0.5rem;
    right: 0.5rem;
    z-index: 99999;
    padding: 0.5rem 0.625rem;
    border-radius: 0.5rem;
    border: 1px solid rgb(0 0 0 / 0.12);
    background: rgb(255 255 255 / 0.94);
    color: #111827;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 10px;
    line-height: 1.45;
    white-space: pre-wrap;
    pointer-events: none;
    box-shadow: 0 4px 20px rgb(0 0 0 / 0.12);
  }

  html.dark[data-layout-debug] .mobile-layout-debug-hud {
    background: rgb(15 23 42 / 0.92);
    color: #e2e8f0;
    border-color: rgb(255 255 255 / 0.15);
  }

  body.vault-tree-dragging {
    cursor: grabbing;
    user-select: none;
  }

  body.vault-tree-dragging .vault-tree-drop-target {
    cursor: copy;
  }

  body.vault-tree-dragging .vault-tree-drag-handle {
    cursor: grabbing;
  }

  .vault-tree-node--path-folder {
    margin-bottom: 0.15rem;
  }

  .vault-tree-node--path-folder.vault-tree-node--open {
    margin-bottom: 0.35rem;
  }

  .vault-tree-row--folder {
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .vault-tree-row--folder-open {
    background: rgb(var(--color-surface-800) / 0.35);
    color: rgb(var(--color-surface-50));
  }

  .vault-tree-row--note {
    font-weight: 450;
  }

  .vault-tree-folder-icon {
    color: rgb(var(--color-surface-400));
  }

  .vault-tree-row--folder .vault-tree-folder-icon,
  .vault-tree-row--folder-open .vault-tree-folder-icon {
    color: rgb(var(--color-primary-300) / 0.85);
  }

  .vault-tree-folder-count {
    flex-shrink: 0;
    min-width: 1.1rem;
    padding: 0.05rem 0.3rem;
    border-radius: 999px;
    background: rgb(var(--color-surface-800) / 0.7);
    color: rgb(var(--color-surface-450, var(--color-surface-500)));
    font-size: 0.6rem;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    line-height: 1.3;
    text-align: center;
  }

  .vault-tree-nest--path {
    position: relative;
    margin: 0.05rem 0.35rem 0.15rem 0;
    padding: 0.15rem 0 0.2rem 0.7rem;
  }

  .vault-tree-nest--path::before {
    content: "";
    position: absolute;
    top: 0.05rem;
    bottom: 0.2rem;
    left: var(--vault-tree-nest-inset, 1.4rem);
    z-index: 0;
    width: 1.5px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      rgb(var(--color-primary-400) / 0.45) 0%,
      rgb(var(--color-surface-500) / 0.28) 100%
    );
  }

  .vault-tree-nest--path::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0.15rem;
    bottom: 0.05rem;
    left: calc(var(--vault-tree-nest-inset, 1.4rem) + 0.55rem);
    z-index: 0;
    border-radius: 0 0.5rem 0.5rem 0;
    background: linear-gradient(
      90deg,
      rgb(var(--color-surface-950) / 0.45) 0%,
      rgb(var(--color-surface-950) / 0.18) 100%
    );
    pointer-events: none;
  }

  .vault-tree-nest--path > :global(*) {
    position: relative;
    z-index: 1;
  }

  .vault-tree-nest--space {
    margin-top: 0.1rem;
    margin-bottom: 0.35rem;
    padding-bottom: 0.15rem;
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.22);
  }

  .vault-tree-nest--space:last-child {
    border-bottom: 0;
    margin-bottom: 0;
  }

  body.vault-kanban-dragging {
    cursor: grabbing;
    user-select: none;
  }

  body.vault-workshop-dragging {
    cursor: grabbing;
    user-select: none;
  }

  body.vault-workshop-dragging * {
    user-select: none !important;
  }

  body.vault-kanban-dragging [data-kanban-drop-column] {
    cursor: grabbing;
  }

  .vault-kanban-board-row {
    display: flex;
    align-items: stretch;
    gap: 0.65rem;
    height: 100%;
    min-height: 240px;
  }

  .vault-kanban-column {
    display: flex;
    flex-direction: column;
    width: min(17.5rem, 78vw);
    height: 100%;
    max-height: 100%;
    flex-shrink: 0;
    border: 1px solid rgb(var(--color-surface-500) / 0.4);
    border-radius: 0.75rem;
    background:
      linear-gradient(
        180deg,
        rgb(var(--color-primary-500) / 0.06) 0,
        transparent 2.75rem
      ),
      rgb(var(--color-surface-900) / 0.4);
    overflow: hidden;
  }

  .vault-kanban-column-header {
    flex-shrink: 0;
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.28);
    padding: 0.6rem 0.7rem 0.5rem;
  }

  .vault-kanban-column-header-row {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .vault-kanban-column-title {
    min-width: 0;
    flex: 1 1 auto;
    margin: 0;
    border: 0;
    border-radius: 0.35rem;
    background: transparent;
    padding: 0.1rem 0.2rem;
    color: rgb(var(--color-surface-100));
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.01em;
    line-height: 1.3;
    outline: none;
    transition: background-color 140ms ease, box-shadow 140ms ease;
  }

  .vault-kanban-column-title:hover:not(:disabled):not(:focus) {
    background: rgb(var(--color-surface-800) / 0.35);
  }

  .vault-kanban-column-title:focus {
    background: rgb(var(--color-surface-950) / 0.45);
    box-shadow: inset 0 -1px 0 rgb(var(--color-primary-400) / 0.55);
  }

  .vault-kanban-column-title:disabled {
    opacity: 1;
    color: rgb(var(--color-surface-100));
  }

  .vault-kanban-column-count {
    margin: 0.15rem 0 0;
    padding: 0 0.2rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.625rem;
    font-variant-numeric: tabular-nums;
  }

  .vault-kanban-column-remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    flex-shrink: 0;
    border: 0;
    border-radius: 0.35rem;
    background: transparent;
    color: rgb(var(--color-surface-500));
    opacity: 0;
    transition: opacity 120ms ease, background-color 120ms ease, color 120ms ease;
  }

  .vault-kanban-column:hover .vault-kanban-column-remove,
  .vault-kanban-column:focus-within .vault-kanban-column-remove {
    opacity: 1;
  }

  .vault-kanban-column-remove:hover {
    background: rgb(var(--color-surface-700) / 0.8);
    color: rgb(var(--color-surface-200));
  }

  .vault-kanban-column-body {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    gap: 0.4rem;
    min-height: 0;
    overflow-x: hidden;
    overflow-y: auto;
    padding: 0.45rem;
  }

  .vault-kanban-card-stack {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .vault-kanban-column--drop-active {
    box-shadow: inset 0 0 0 2px rgb(var(--color-primary-400) / 0.45);
  }

  .vault-kanban-card.workshop-kanban-card {
    position: relative;
    width: 100%;
    flex-shrink: 0;
    border: 1px solid transparent;
    border-left: 2px solid rgb(var(--color-primary-400) / 0.4);
    border-radius: 0.55rem;
    background-color: rgb(var(--color-surface-950) / 0.42);
    padding: 0.45rem 0.4rem;
    text-align: left;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease,
      opacity 160ms ease,
      transform 160ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .vault-kanban-card.workshop-kanban-card:hover {
    background-color: rgb(var(--color-surface-800) / 0.42);
    border-color: rgb(var(--color-surface-500) / 0.22);
    border-left-color: rgb(var(--color-primary-400) / 0.7);
    box-shadow: 0 4px 14px -8px rgb(0 0 0 / 0.32);
    transform: translateY(-1px);
  }

  .vault-kanban-card.workshop-kanban-card:focus-visible {
    outline: 2px solid rgb(var(--color-primary-400) / 0.65);
    outline-offset: 1px;
  }

  .vault-kanban-card--editing.workshop-kanban-card,
  .vault-kanban-card--editing.workshop-kanban-card:hover {
    background-color: rgb(var(--color-surface-950) / 0.62);
    border-color: rgb(var(--color-surface-500) / 0.18);
    border-left-color: rgb(var(--color-primary-400) / 0.85);
    box-shadow: 0 0 0 1px rgb(var(--color-primary-400) / 0.12);
    transform: none;
  }

  .vault-kanban-card-row {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
    padding-left: 0.1rem;
  }

  .vault-kanban-card--done.workshop-kanban-card {
    opacity: 0.62;
    border-left-color: rgb(var(--color-surface-500) / 0.35);
    background-color: rgb(var(--color-surface-950) / 0.28);
  }

  .vault-kanban-card--done.workshop-kanban-card:hover {
    opacity: 0.78;
    transform: none;
    box-shadow: none;
  }

  .vault-kanban-card--done .vault-kanban-card-text {
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    text-decoration: line-through;
    text-decoration-color: rgb(var(--color-surface-500) / 0.55);
  }

  .vault-kanban-card-face {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .vault-kanban-card-face--done .vault-kanban-card-title,
  .vault-kanban-card-face--done .vault-kanban-card-body {
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    text-decoration: line-through;
    text-decoration-color: rgb(var(--color-surface-500) / 0.5);
  }

  .vault-kanban-card-emoji {
    flex-shrink: 0;
    padding-top: 0.05rem;
    font-size: 1rem;
    line-height: 1.2;
  }

  .vault-kanban-card-title {
    display: -webkit-box;
    width: 100%;
    margin: 0;
    padding: 0;
    overflow: hidden;
    border: 0;
    background: transparent;
    color: rgb(var(--color-surface-50));
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    text-align: left;
    cursor: text;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .vault-kanban-card-title--empty {
    color: rgb(var(--color-surface-500));
    font-style: italic;
    font-weight: 500;
  }

  .vault-kanban-card-title:disabled {
    cursor: default;
  }

  .vault-kanban-card-body {
    display: -webkit-box;
    width: 100%;
    margin: 0.2rem 0 0;
    overflow: hidden;
    border: 0;
    background: transparent;
    padding: 0;
    color: rgb(var(--color-surface-300));
    font-size: 0.72rem;
    line-height: 1.4;
    text-align: left;
    white-space: pre-wrap;
    cursor: text;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .vault-kanban-card-body:disabled {
    cursor: default;
  }

  .vault-kanban-card-body--expanded {
    display: block;
    -webkit-line-clamp: unset;
    line-clamp: unset;
  }

  .vault-kanban-card-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.35rem;
  }

  .vault-kanban-chip {
    display: inline-flex;
    align-items: center;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    border-radius: 0.3rem;
    padding: 0.05rem 0.28rem;
    font-size: 0.625rem;
    font-weight: 500;
    line-height: 1.35;
  }

  .vault-kanban-chip--link {
    border: 0;
    background: transparent;
    color: rgb(var(--color-primary-300) / 0.9);
    text-decoration: underline;
    text-decoration-color: rgb(var(--color-primary-400) / 0.35);
    text-underline-offset: 0.12em;
    cursor: pointer;
  }

  .vault-kanban-chip--link:hover:not(:disabled) {
    background: rgb(var(--color-primary-500) / 0.1);
    color: rgb(var(--color-primary-200));
    text-decoration-color: rgb(var(--color-primary-300) / 0.7);
  }

  .vault-kanban-chip--link:disabled {
    cursor: default;
    opacity: 0.85;
  }

  .vault-kanban-chip--tag {
    background: transparent;
    color: rgb(var(--color-surface-450, var(--color-surface-500)));
  }

  .vault-kanban-card-open {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.35rem;
    border: 0;
    border-radius: 0.3rem;
    background: transparent;
    padding: 0;
    color: rgb(var(--color-primary-300) / 0.72);
    font-size: 0.68rem;
    font-weight: 500;
    opacity: 0.7;
    transition: opacity 140ms ease, color 140ms ease;
  }

  .vault-kanban-card-open:hover {
    color: rgb(var(--color-primary-200));
    opacity: 1;
  }

  .vault-kanban-card-expand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    flex-shrink: 0;
    margin-top: 0.05rem;
    border: 0;
    border-radius: 0.35rem;
    background: transparent;
    color: rgb(var(--color-surface-500));
    transition: transform 160ms ease, color 140ms ease, background-color 140ms ease;
  }

  .vault-kanban-card-expand:hover {
    background: rgb(var(--color-surface-800) / 0.8);
    color: rgb(var(--color-surface-200));
  }

  .vault-kanban-card-expand--open {
    transform: rotate(180deg);
  }

  .vault-kanban-card-media {
    margin: -0.15rem -0.1rem 0.4rem;
    overflow: hidden;
    border-radius: 0.35rem;
    background: rgb(var(--color-surface-900) / 0.8);
  }

  .vault-kanban-card-media img {
    display: block;
    width: 100%;
    max-height: 5.5rem;
    object-fit: cover;
  }

  .vault-kanban-card-input {
    display: block;
    width: 100%;
    min-height: 1.35em;
    margin: 0;
    resize: none;
    overflow: hidden;
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 0;
    color: rgb(var(--color-surface-50));
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.35;
    outline: none;
    box-shadow: none;
    field-sizing: content;
    caret-color: rgb(var(--color-primary-300));
  }

  .vault-kanban-card-input::placeholder {
    color: rgb(var(--color-surface-500));
    font-weight: 500;
    font-style: italic;
  }

  .vault-kanban-card-hint {
    display: none;
  }

  .vault-kanban-column:nth-child(3n + 1) {
    border-top: 2px solid rgb(var(--color-primary-400) / 0.35);
  }

  .vault-kanban-column:nth-child(3n + 2) {
    border-top: 2px solid rgb(var(--color-secondary-400, var(--color-primary-300)) / 0.35);
  }

  .vault-kanban-column:nth-child(3n + 3) {
    border-top: 2px solid rgb(var(--color-success-500, 52 199 89) / 0.4);
  }

  .vault-kanban-card-text {
    display: -webkit-box;
    width: 100%;
    margin: 0;
    padding: 0.1rem 0;
    overflow: hidden;
    border: 0;
    background: transparent;
    color: rgb(var(--color-surface-100));
    font-size: 0.8125rem;
    line-height: 1.35;
    text-align: left;
    cursor: text;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .vault-kanban-card-text--empty {
    color: rgb(var(--color-surface-500));
    font-style: italic;
  }

  .vault-kanban-card-text:disabled {
    cursor: default;
  }

  .vault-kanban-grip {
    position: absolute;
    top: 0.12rem;
    left: -0.15rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    border: 0;
    border-radius: 0.3rem;
    background: transparent;
    color: rgb(var(--color-surface-600));
    cursor: grab;
    opacity: 0;
    transition: opacity 140ms ease, background-color 140ms ease, color 140ms ease;
  }

  .vault-kanban-card:hover .vault-kanban-grip,
  .vault-kanban-card:focus-within .vault-kanban-grip,
  body.vault-kanban-dragging .vault-kanban-grip {
    opacity: 1;
  }

  .vault-kanban-grip:hover {
    background: rgb(var(--color-surface-800) / 0.7);
    color: rgb(var(--color-surface-300));
  }

  .vault-kanban-grip:active {
    cursor: grabbing;
  }

  .vault-kanban-check-wrap {
    position: relative;
    display: inline-flex;
    width: 1rem;
    height: 1rem;
    margin: 0.2rem 0.1rem 0 0;
    flex-shrink: 0;
    cursor: pointer;
  }

  .vault-kanban-check {
    position: absolute;
    inset: 0;
    z-index: 1;
    margin: 0;
    opacity: 0;
    cursor: pointer;
  }

  .vault-kanban-check-face {
    display: block;
    width: 100%;
    height: 100%;
    border: 1.5px solid rgb(var(--color-surface-500) / 0.55);
    border-radius: 999px;
    background: transparent;
    opacity: 0.45;
    transition:
      opacity 140ms ease,
      border-color 140ms ease,
      background-color 140ms ease,
      transform 140ms ease;
  }

  .vault-kanban-card:hover .vault-kanban-check-face,
  .vault-kanban-card:focus-within .vault-kanban-check-face,
  .vault-kanban-check:focus-visible + .vault-kanban-check-face {
    opacity: 0.9;
  }

  .vault-kanban-check:checked + .vault-kanban-check-face {
    opacity: 1;
    border-color: rgb(var(--color-primary-400) / 0.85);
    background:
      radial-gradient(
        circle at center,
        rgb(var(--color-primary-400) / 0.95) 0 38%,
        transparent 40%
      );
    animation: vault-kanban-check-pop 220ms ease;
  }

  .vault-kanban-check:checked {
    animation: none;
  }

  @keyframes vault-kanban-check-pop {
    0% {
      transform: scale(0.86);
    }
    55% {
      transform: scale(1.08);
    }
    100% {
      transform: scale(1);
    }
  }

  .vault-kanban-column--quiet {
    opacity: 0.72;
    background:
      linear-gradient(
        180deg,
        rgb(var(--color-surface-500) / 0.04) 0,
        transparent 2.75rem
      ),
      rgb(var(--color-surface-900) / 0.28);
  }

  .vault-kanban-column--quiet .vault-kanban-column-header {
    opacity: 0.85;
  }

  .vault-kanban-column--quiet .vault-kanban-card.workshop-kanban-card {
    border-left-color: rgb(var(--color-surface-500) / 0.35);
    opacity: 0.85;
  }

  .vault-kanban-column--collapsed {
    align-self: flex-start;
    width: min(11.5rem, 62vw);
    height: auto;
    max-height: 100%;
    opacity: 0.58;
  }

  .vault-kanban-column--collapsed .vault-kanban-column-body {
    flex: 0 1 auto;
  }

  .vault-kanban-column--collapsed .vault-kanban-empty {
    min-height: 1.75rem;
    padding: 0.35rem 0.25rem;
  }

  .vault-kanban-column--collapsed .vault-kanban-add {
    padding: 0.25rem 0.2rem;
    font-size: 0.68rem;
    opacity: 0.75;
  }

  .vault-kanban-empty {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.15rem;
    margin: 0;
    flex-shrink: 0;
    min-height: 2.25rem;
    padding: 0.45rem 0.35rem;
    text-align: left;
    color: rgb(var(--color-surface-500));
    border: 0;
    border-radius: 0;
    background: transparent;
  }

  .vault-kanban-empty p {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 500;
    color: rgb(var(--color-surface-450, var(--color-surface-500)));
  }

  .vault-kanban-empty span {
    font-size: 0.65rem;
    color: rgb(var(--color-surface-550, var(--color-surface-500)));
  }

  .vault-kanban-card--drop-before::before,
  .vault-kanban-card--drop-after::after {
    content: "";
    position: absolute;
    left: 0.35rem;
    right: 0.35rem;
    height: 2px;
    border-radius: 999px;
    background: rgb(var(--color-primary-400) / 0.85);
    pointer-events: none;
    animation: vault-kanban-drop-line 180ms ease;
  }

  .vault-kanban-card--drop-before::before {
    top: -0.2rem;
  }

  .vault-kanban-card--drop-after::after {
    bottom: -0.2rem;
  }

  @keyframes vault-kanban-drop-line {
    from {
      opacity: 0;
      transform: scaleX(0.72);
    }
    to {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  .vault-kanban-card-expand {
    transition:
      transform 200ms cubic-bezier(0.22, 1, 0.36, 1),
      color 140ms ease,
      background-color 140ms ease;
  }

  .vault-kanban-card-body {
    transition: max-height 200ms ease, opacity 160ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .vault-kanban-check:checked + .vault-kanban-check-face,
    .vault-kanban-card--drop-before::before,
    .vault-kanban-card--drop-after::after,
    .vault-kanban-card-expand,
    .vault-kanban-card.workshop-kanban-card {
      animation: none;
      transition: none;
      transform: none;
    }
  }

  .vault-kanban-card-remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    border: 0;
    border-radius: 0.35rem;
    background: transparent;
    color: rgb(var(--color-surface-500));
    opacity: 0;
    transition: opacity 120ms ease, background-color 120ms ease, color 120ms ease;
  }

  .vault-kanban-card:hover .vault-kanban-card-remove,
  .vault-kanban-card:focus-within .vault-kanban-card-remove {
    opacity: 1;
  }

  .vault-kanban-card-remove:hover {
    background: rgb(var(--color-surface-700) / 0.8);
    color: rgb(var(--color-surface-200));
  }

  .vault-kanban-add {
    display: flex;
    width: 100%;
    flex-shrink: 0;
    align-items: center;
    justify-content: flex-start;
    gap: 0.35rem;
    margin-top: 0.1rem;
    border: 0;
    border-radius: 0.4rem;
    background: transparent;
    padding: 0.35rem 0.35rem 0.35rem 0.2rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.72rem;
    font-weight: 500;
    opacity: 0.72;
    transition:
      color 140ms ease,
      background-color 140ms ease,
      opacity 140ms ease;
  }

  .vault-kanban-add:hover:not(:disabled) {
    background: rgb(var(--color-surface-800) / 0.35);
    color: rgb(var(--color-surface-250, var(--color-surface-200)));
    opacity: 1;
  }

  .vault-kanban-add:disabled {
    opacity: 0.4;
  }

  .vault-kanban-add-column {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    width: min(8.5rem, 42vw);
    min-height: 7.5rem;
    flex-shrink: 0;
    align-self: flex-start;
    border: 0;
    border-radius: 0.75rem;
    background: rgb(var(--color-surface-900) / 0.18);
    color: rgb(var(--color-surface-500));
    font-size: 0.72rem;
    font-weight: 500;
    opacity: 0.75;
    transition:
      color 140ms ease,
      background-color 140ms ease,
      opacity 140ms ease;
  }

  .vault-kanban-add-column:hover {
    background: rgb(var(--color-surface-800) / 0.35);
    color: rgb(var(--color-surface-200));
    opacity: 1;
  }

  .vault-kanban-peek-backdrop {
    position: fixed;
    inset: 0;
    z-index: 130;
    background: rgb(0 0 0 / 0.18);
  }

  .vault-kanban-peek {
    position: fixed;
    z-index: 131;
    display: flex;
    max-height: min(22rem, calc(100vh - 1.5rem));
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgb(var(--color-surface-500) / 0.45);
    border-radius: 0.75rem;
    background: rgb(var(--color-surface-900) / 0.96);
    box-shadow: 0 18px 40px -16px rgb(0 0 0 / 0.55);
    outline: none;
  }

  .vault-kanban-peek-header {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.35);
    padding: 0.65rem 0.7rem 0.55rem;
  }

  .vault-kanban-peek-title {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: rgb(var(--color-surface-50));
    font-size: 0.85rem;
    font-weight: 600;
  }

  .vault-kanban-peek-path {
    margin: 0.15rem 0 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: rgb(var(--color-surface-500));
    font-size: 0.65rem;
  }

  .vault-kanban-peek-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.55rem;
    height: 1.55rem;
    flex-shrink: 0;
    border: 0;
    border-radius: 0.4rem;
    background: transparent;
    color: rgb(var(--color-surface-400));
  }

  .vault-kanban-peek-icon:hover {
    background: rgb(var(--color-surface-700) / 0.85);
    color: rgb(var(--color-surface-100));
  }

  .vault-kanban-peek-body {
    min-height: 0;
    flex: 1 1 auto;
    overflow: auto;
    padding: 0.65rem 0.75rem;
  }

  .vault-kanban-peek-status {
    margin: 0;
    color: rgb(var(--color-surface-400));
    font-size: 0.78rem;
  }

  .vault-kanban-peek-footer {
    display: flex;
    justify-content: flex-end;
    border-top: 1px solid rgb(var(--color-surface-500) / 0.35);
    padding: 0.45rem 0.55rem;
  }

  .vault-kanban-peek-open {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: 0;
    border-radius: 0.4rem;
    background: rgb(var(--color-primary-500) / 0.16);
    padding: 0.35rem 0.55rem;
    color: rgb(var(--color-primary-200));
    font-size: 0.72rem;
    font-weight: 600;
  }

  .vault-kanban-peek-open:hover {
    background: rgb(var(--color-primary-500) / 0.28);
  }

  .vault-kanban-card--drop-before {
    box-shadow: none;
  }

  .vault-kanban-card--dragging {
    opacity: 0.55;
  }

  .vault-tree-row--drop-active {
    background-color: rgb(var(--color-primary-500) / 0.1);
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-400) / 0.6);
  }

  .vault-context-menu {
    @apply fixed z-[120] min-w-[12rem] overflow-hidden rounded-container-token border border-surface-500/45 bg-surface-900 py-1 shadow-xl;
  }

  .vault-context-menu--icons {
    width: min(17.5rem, calc(100vw - 1rem));
    max-height: min(24rem, calc(100vh - 1rem));
    overflow: auto;
    padding: 0.35rem 0.4rem 0.55rem;
  }

  .vault-context-menu-item {
    @apply block w-full px-3 py-2 text-left text-sm text-surface-100 transition hover:bg-surface-700/80 disabled:cursor-not-allowed disabled:opacity-45;
  }

  .vault-folder-icon-picker-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.25rem 0.2rem 0.45rem;
  }

  .vault-folder-icon-picker-title {
    margin: 0;
    color: rgb(var(--color-surface-200));
    font-size: 0.72rem;
    font-weight: 600;
  }

  .vault-folder-icon-picker-reset {
    border: 0;
    border-radius: 0.3rem;
    background: transparent;
    padding: 0.15rem 0.35rem;
    color: rgb(var(--color-surface-400));
    font-size: 0.65rem;
    font-weight: 500;
  }

  .vault-folder-icon-picker-reset:hover {
    background: rgb(var(--color-surface-700) / 0.8);
    color: rgb(var(--color-surface-100));
  }

  .vault-folder-icon-group {
    margin: 0.45rem 0.2rem 0.25rem;
    color: rgb(var(--color-surface-500));
    font-size: 0.6rem;
    font-weight: 650;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .vault-folder-icon-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.2rem;
  }

  .vault-folder-icon-option {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    border: 0;
    border-radius: 0.4rem;
    background: transparent;
    color: rgb(var(--color-surface-300));
  }

  .vault-folder-icon-option:hover {
    background: rgb(var(--color-surface-700) / 0.85);
    color: rgb(var(--color-surface-50));
  }

  .vault-folder-icon-option--active {
    background: rgb(var(--color-primary-500) / 0.22);
    color: rgb(var(--color-primary-200));
  }

  .vault-note-picker-backdrop,
  .vault-quick-switcher-backdrop {
    @apply backdrop-blur-[2px];
  }

  .vault-note-picker-panel,
  .vault-quick-switcher-panel {
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.45);
  }

  .command-spotlight-backdrop {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 1rem;
    padding-top: 12vh;
    background: rgb(var(--color-surface-950) / 0.72);
    backdrop-filter: blur(3px) saturate(1.05);
  }

  html:not(.dark) .command-spotlight-backdrop {
    background: rgb(var(--color-surface-50) / 0.72);
  }

  .command-spotlight-panel {
    width: min(100%, 36rem);
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid rgb(var(--color-surface-700) / 0.6);
    background: rgb(var(--color-surface-900));
    color: rgb(var(--color-surface-50));
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.45);
  }

  html:not(.dark) .command-spotlight-panel {
    background: rgb(var(--color-surface-50));
    color: rgb(var(--color-surface-900));
    border-color: rgb(var(--color-surface-300) / 0.85);
  }

  .command-spotlight-input {
    display: block;
    width: 100%;
    border: 0;
    border-bottom: 1px solid rgb(var(--color-surface-800) / 0.9);
    background: transparent;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    line-height: 1.25rem;
    color: inherit;
    outline: none;
  }

  .command-spotlight-input::placeholder {
    color: rgb(var(--color-surface-500));
  }

  .command-spotlight-prompt-header {
    border-bottom: 1px solid rgb(var(--color-surface-800) / 0.9);
    padding: 0.75rem 1rem;
  }

  .command-spotlight-kicker {
    font-size: 0.75rem;
    color: rgb(var(--color-surface-500));
  }

  .command-spotlight-prompt-label {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .command-spotlight-results {
    max-height: 20rem;
    overflow-y: auto;
    padding-block: 0.25rem;
  }

  .command-spotlight-section-label {
    padding: 0.5rem 0.75rem 0.25rem;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-surface-500));
  }

  .command-spotlight-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .command-spotlight-row {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    text-align: left;
    font-size: 0.875rem;
    color: rgb(var(--color-surface-100));
    background: transparent;
    transition: background-color 120ms ease;
  }

  html:not(.dark) .command-spotlight-row {
    color: rgb(var(--color-surface-800));
  }

  .command-spotlight-row:hover:not(:disabled) {
    background: rgb(var(--color-surface-800) / 0.8);
  }

  html:not(.dark) .command-spotlight-row:hover:not(:disabled) {
    background: rgb(var(--color-surface-200) / 0.85);
  }

  .command-spotlight-row-active {
    background: rgb(var(--color-primary-500) / 0.15);
    color: rgb(var(--color-surface-50));
  }

  html:not(.dark) .command-spotlight-row-active {
    color: rgb(var(--color-surface-900));
  }

  .command-spotlight-row-copy {
    min-width: 0;
    flex: 1 1 auto;
  }

  .command-spotlight-row-title,
  .command-spotlight-row-subtitle {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .command-spotlight-row-subtitle {
    font-size: 0.75rem;
    color: rgb(var(--color-surface-500));
  }

  .command-spotlight-row-meta {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 0.5rem;
  }

  .command-spotlight-attention {
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.625rem;
    color: rgb(var(--color-warning-400) / 0.9);
  }

  .command-spotlight-hint {
    font-size: 0.75rem;
    color: rgb(var(--color-surface-500));
  }

  .command-spotlight-empty {
    padding: 2rem 1rem;
    text-align: center;
    font-size: 0.875rem;
    color: rgb(var(--color-surface-500));
  }

  .command-spotlight-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgb(var(--color-surface-800) / 0.9);
    padding: 0.5rem 1rem;
    font-size: 0.6875rem;
    color: rgb(var(--color-surface-500));
  }

  .command-spotlight-kbd {
    border-radius: 0.25rem;
    border: 1px solid rgb(var(--color-surface-700) / 0.6);
    padding: 0.125rem 0.375rem;
    color: rgb(var(--color-surface-400));
  }

  .markdown-transclusion {
    @apply my-4 overflow-hidden rounded-container-token border border-surface-500/40 bg-surface-900/50;
  }

  .markdown-transclusion-error {
    @apply px-3 py-2 text-sm text-warning-200;
  }

  .markdown-transclusion-header {
    @apply flex items-center justify-between gap-2 border-b border-surface-500/35 bg-surface-900/80 px-3 py-2;
  }

  .markdown-transclusion-label {
    @apply truncate text-xs font-medium text-surface-200;
  }

  .markdown-transclusion-open {
    @apply shrink-0 rounded-md px-2 py-1 text-[11px] text-primary-200 transition hover:bg-primary-500/15 hover:text-primary-100;
  }

  .markdown-transclusion-body {
    @apply px-4 py-3 text-sm;
  }

  .markdown-image {
    @apply my-4;
  }

  .markdown-image img,
  .markdown-local-image {
    @apply h-auto max-w-full rounded-lg border border-surface-500/35 bg-surface-900/40;
  }

  .markdown-image--sized {
    @apply my-4 inline-block max-w-full;
  }

  .markdown-image--sized img {
    @apply max-w-full;
  }

  .markdown-local-image--missing {
    @apply min-h-24 min-w-[8rem] border-dashed opacity-60;
  }

  .vault-note-workshop {
    @apply fixed z-[85] flex w-[26rem] max-w-[calc(100vw-2rem)] flex-col overflow-hidden rounded-2xl border border-surface-500/45 bg-surface-900 shadow-2xl;
    height: min(560px, calc(100vh - 3rem));
  }

  .vault-note-workshop-sheet {
    @apply fixed inset-x-0 bottom-0 z-[85] flex flex-col overflow-hidden border-t border-surface-500/30 backdrop-blur-md;
    background-color: rgb(var(--color-surface-950) / 0.95);
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
    box-shadow: 0 -12px 40px rgb(0 0 0 / 0.35);
    animation: vault-sticky-sheet-in 180ms ease-out;
  }

  .vault-note-workshop-sheet--resizing {
    animation: none;
    user-select: none;
  }

  .vault-note-workshop-sheet-resize {
    @apply flex h-3 shrink-0 cursor-ns-resize items-center justify-center touch-none;
  }

  .vault-note-workshop-sheet-grip {
    @apply h-1 w-9 rounded-full bg-surface-500/50;
  }

  .vault-note-workshop-sheet-resize:hover .vault-note-workshop-sheet-grip,
  .vault-note-workshop-sheet-resize:focus-visible .vault-note-workshop-sheet-grip {
    @apply bg-surface-400/70;
  }

  @keyframes vault-sticky-sheet-in {
    from {
      transform: translateY(12px);
      opacity: 0.7;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .vault-note-workshop-sheet-header {
    @apply flex shrink-0 items-center gap-2 px-2.5 pb-1.5 pt-0;
  }

  .vault-note-workshop-header {
    @apply flex cursor-grab items-center gap-2 border-b border-surface-500/40 bg-surface-900/95 px-3 py-2 active:cursor-grabbing;
    user-select: none;
    touch-action: none;
  }

  .vault-note-workshop-icon-btn {
    @apply inline-flex h-7 w-7 items-center justify-center rounded-md text-surface-400 transition hover:bg-surface-800 hover:text-surface-100;
  }

  .vault-note-workshop-body {
    @apply flex min-h-0 flex-1 flex-col;
  }

  .vault-note-workshop-dock {
    @apply fixed bottom-4 right-4 z-[85] flex max-w-[16rem] items-center gap-2 rounded-full border border-primary-500/35 bg-surface-900/95 px-4 py-2 text-sm text-primary-100 shadow-xl backdrop-blur-sm transition hover:border-primary-400/50 hover:bg-surface-800;
  }

  .vault-note-workshop-dock--sticky {
    @apply bottom-3 left-1/2 right-auto max-w-[14rem] -translate-x-1/2 border-surface-500/40 bg-surface-900/90 px-3 py-1.5 text-xs text-surface-200 shadow-lg;
  }

  .vault-workshop-chat-panel {
    @apply min-h-0;
    background-color: rgb(var(--color-surface-950));
  }

  .vault-workshop-chat-panel--sticky {
    background-color: transparent;
  }

  .vault-workshop-chat-body {
    @apply min-h-0 flex-1;
  }

  .vault-workshop-chat-scroll {
    @apply h-full overflow-y-auto px-3 py-3;
  }

  .vault-workshop-chat-panel--sticky .vault-workshop-chat-scroll {
    @apply px-2.5 py-1.5;
  }

  .vault-workshop-chat-composer {
    @apply shrink-0 border-t border-surface-500/35 px-3 pb-2 pt-2;
    background-color: rgb(var(--color-surface-900) / 0.8);
  }

  .vault-workshop-chat-composer--sticky {
    @apply border-surface-500/20 px-2 pb-1.5 pt-1.5;
    background-color: transparent;
  }

  .vault-workshop-chat-composer .composer-voice-status,
  .vault-workshop-chat-composer .composer-attachment-chips {
    @apply mb-1;
  }

  .vault-chat-context-chip--whisper {
    @apply border-0 bg-transparent px-1 py-0.5;
  }

  /* LME Live | Build plane switch — quiet mode pill, not another header btn */
  .vault-editor-tools {
    opacity: 0.78;
  }

  .vault-editor-tools:hover,
  .vault-editor-tools:focus-within {
    opacity: 1;
  }

  /* Quiet icon chrome — no Skeleton pill fills */
  .vault-editor-icon-btn {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 1.75rem;
    height: 1.75rem;
    padding: 0;
    border: none;
    border-radius: 0.35rem;
    background: transparent;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    cursor: pointer;
    flex-shrink: 0;
  }

  .vault-editor-icon-btn:hover {
    color: rgb(var(--shell-fg, var(--color-surface-100)));
    background: rgb(var(--color-surface-800) / 0.55);
  }

  .vault-editor-icon-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .vault-editor-icon-btn--active,
  .vault-editor-icon-btn[aria-expanded="true"] {
    color: rgb(var(--shell-fg, var(--color-surface-100)));
    background: rgb(var(--color-surface-800) / 0.65);
  }

  .vault-editor-icon-btn__badge {
    position: absolute;
    top: 0.1rem;
    right: 0.05rem;
    min-width: 0.85rem;
    height: 0.85rem;
    padding: 0 0.2rem;
    border-radius: 999px;
    font-size: 0.5625rem;
    font-weight: 600;
    line-height: 0.85rem;
    text-align: center;
    color: rgb(var(--shell-fg, var(--color-surface-50)));
    background: rgb(var(--color-surface-600) / 0.95);
    pointer-events: none;
  }

  .vault-editor-icon-pair {
    display: inline-flex;
    align-items: center;
    gap: 0.1rem;
  }

  .vault-editor-tool-btn {
    /* legacy alias */
    color: rgb(var(--shell-muted, var(--color-surface-400)));
  }

  /* Note overflow (⋯) — Cursor-coherent menu chrome */
  .vault-editor-overflow {
    min-width: 14.5rem;
    max-width: min(18rem, calc(100vw - 1.5rem));
    padding: 0.28rem;
    border-radius: 0.55rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.42);
    background: rgb(var(--color-surface-900) / 0.97);
    box-shadow:
      0 12px 32px rgb(0 0 0 / 0.42),
      0 0 0 1px rgb(0 0 0 / 0.18);
    backdrop-filter: blur(14px);
  }

  .vault-editor-overflow__sep {
    margin: 0.28rem 0.35rem;
    border-top: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.32);
  }

  .vault-editor-overflow__item,
  .vault-editor-overflow__toggle {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 0.55rem;
    padding: 0.38rem 0.55rem;
    border-radius: 0.35rem;
    text-align: left;
    font-size: 0.8125rem;
    line-height: 1.25;
    color: rgb(var(--shell-fg, var(--color-surface-100)));
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .vault-editor-overflow__item:hover,
  .vault-editor-overflow__toggle:hover {
    background: rgb(var(--color-surface-700) / 0.72);
  }

  .vault-editor-overflow__item:disabled {
    cursor: not-allowed;
    opacity: 0.42;
  }

  .vault-kind-badge__trigger {
    cursor: pointer;
  }

  .vault-kind-badge__trigger:hover {
    filter: brightness(1.08);
  }

  .vault-kind-badge__item {
    display: block;
    width: 100%;
    padding: 0.4rem 0.75rem;
    text-align: left;
    font-size: 0.8125rem;
    color: rgb(var(--shell-fg, var(--color-surface-200)));
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .vault-kind-badge__item:hover {
    background: rgb(var(--color-surface-800) / 0.8);
  }

  .vault-kind-badge__item--active {
    color: rgb(var(--shell-muted, var(--color-surface-500)));
    font-weight: 500;
    opacity: 0.55;
    cursor: default;
  }

  .vault-kind-badge__item--active:hover {
    background: transparent;
  }

  .vault-editor-overflow__icon {
    display: inline-flex;
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
  }

  .vault-editor-overflow__label {
    flex: 1;
    min-width: 0;
    text-align: left;
  }

  .vault-editor-overflow__shortcut {
    flex-shrink: 0;
    margin-left: 1.25rem;
    font-size: 0.75rem;
    letter-spacing: 0.01em;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
    font-variant-numeric: tabular-nums;
  }

  .vault-editor-overflow__toggle {
    justify-content: space-between;
  }

  .vault-editor-overflow__switch {
    position: relative;
    width: 1.85rem;
    height: 1.05rem;
    flex-shrink: 0;
    border-radius: 999px;
    background: rgb(var(--color-surface-700) / 0.9);
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.35);
    transition: background 120ms ease;
  }

  .vault-editor-overflow__switch--on {
    background: rgb(var(--color-success-600, 22 163 74) / 0.85);
    border-color: rgb(var(--color-success-500, 34 197 94) / 0.45);
  }

  .vault-editor-overflow__knob {
    position: absolute;
    top: 1px;
    left: 1px;
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 999px;
    background: rgb(var(--color-surface-50));
    transition: transform 120ms ease;
  }

  .vault-editor-overflow__switch--on .vault-editor-overflow__knob {
    transform: translateX(0.75rem);
  }

  .vault-note-plane-pill {
    @apply inline-flex items-center rounded-full border border-surface-500/35 p-0.5;
    background-color: rgb(var(--color-surface-900) / 0.55);
  }

  .vault-note-plane-pill-btn {
    @apply rounded-full px-2.5 py-1 text-[11px] font-medium tracking-wide text-surface-400 transition-colors;
  }

  .vault-note-plane-pill-btn:hover {
    @apply text-surface-200;
  }

  .vault-note-plane-pill-btn--active {
    @apply bg-surface-800/90 text-surface-50 shadow-sm;
  }

  .vault-markdown-editor--live .vault-codemirror-host--write .cm-content {
    @apply px-8 py-7;
  }

  .vault-live-editor {
    @apply min-w-0 max-w-full px-8 py-7;
    overflow-anchor: none;
  }

  /* Keep note surface inside tiled shell panes (flex min-content otherwise expands). */
  .shell-pane .vault-editor,
  .shell-pane .lme-panel,
  .shell-pane .lme-editor-host {
    @apply min-w-0 max-w-full overflow-hidden;
  }

  /*
   * Vault reading surface — always dark-canvas coherent with the workshop shell.
   * Chart/report tokens here beat html:not(.dark) “paper ink” so embeds don’t flashbang
   * or paint body-dark text on the note canvas.
   */
  .vault-editor {
    --vault-read-fg: rgb(var(--color-surface-100));
    --vault-read-muted: rgb(var(--shell-muted, var(--color-surface-400)));
    --vault-read-accent: rgb(var(--color-primary-300));
    --vault-read-bg: transparent;
    --vault-embed-bg: color-mix(
      in srgb,
      rgb(var(--shell-pane-bg, var(--color-surface-900))) 78%,
      transparent
    );
    --vault-embed-border: color-mix(
      in srgb,
      rgb(var(--shell-border, var(--color-surface-500))) 34%,
      transparent
    );

    --chart-fg: 241 245 249;
    --chart-fg-secondary: 203 213 225;
    --chart-fg-muted: 148 163 184;
    --chart-fg-subtle: 100 116 139;
    --chart-plot-ink: 241 245 249;
    --chart-plot: color-mix(in srgb, rgb(241 245 249) 7%, transparent);
    --chart-plot-muted: color-mix(in srgb, rgb(241 245 249) 14%, transparent);
    --chart-grid: color-mix(in srgb, rgb(148 163 184) 28%, transparent);
    --markdown-chart-red: 248 113 113;
    --markdown-chart-orange: 251 146 60;
    --markdown-chart-yellow: 250 204 21;
    --markdown-chart-green: 74 222 128;
    --markdown-chart-blue: 96 165 250;
    --markdown-chart-purple: 192 132 252;
    --markdown-chart-pink: 244 114 182;
    --markdown-chart-gray: 148 163 184;
  }

  /* Medousa-native reading palettes (Live + preview), not shell colorTheme. */
  .vault-editor[data-reading-palette="neutral"] {
    --vault-read-fg: rgb(var(--color-surface-100));
    --vault-read-muted: rgb(var(--color-surface-400));
    --vault-read-bg: transparent;
    --vault-read-accent: rgb(var(--color-primary-300));
  }

  .vault-editor[data-reading-palette="warm"] {
    --vault-read-fg: #f6ecdf;
    --vault-read-muted: #d0b896;
    --vault-read-bg: rgb(42 32 24 / 0.22);
    --vault-read-accent: #e8b57a;
    --chart-fg: 246 236 223;
    --chart-fg-secondary: 224 200 168;
    --chart-fg-muted: 196 169 138;
    --chart-plot-ink: 246 236 223;
  }

  .vault-editor[data-reading-palette="cool"] {
    --vault-read-fg: #eef4fb;
    --vault-read-muted: #a8bdd4;
    --vault-read-bg: rgb(20 32 48 / 0.22);
    --vault-read-accent: #8ec4f0;
    --chart-fg: 238 244 251;
    --chart-fg-secondary: 196 214 232;
    --chart-fg-muted: 143 166 194;
    --chart-plot-ink: 238 244 251;
  }

  .vault-editor[data-reading-palette="ink"] {
    --vault-read-fg: #f0eee8;
    --vault-read-muted: #b4b0a4;
    --vault-read-bg: rgb(12 12 11 / 0.28);
    --vault-read-accent: #dcc9a4;
    --chart-fg: 240 238 232;
    --chart-fg-secondary: 210 206 194;
    --chart-fg-muted: 154 150 140;
    --chart-plot-ink: 240 238 232;
  }

  .vault-editor[data-reading-palette] .vault-live-editor .ProseMirror,
  .vault-editor[data-reading-palette] .vault-live-prose,
  .vault-editor[data-reading-palette] .markdown-content {
    color: var(--vault-read-fg);
  }

  /* Beat hard-coded surface/shell colors on body copy (headings already inherit). */
  .vault-editor[data-reading-palette]
    :is(.vault-live-prose, .markdown-content)
    :is(p, li, td, th, h1, h2, h3, h4, h5, h6) {
    color: var(--vault-read-fg);
  }

  .vault-editor[data-reading-palette]
    :is(.vault-live-prose, .markdown-content)
    :is(blockquote, del),
  .vault-editor[data-reading-palette] .vault-live-heading-marks,
  .vault-editor[data-reading-palette]
    .vault-live-prose
    ul[data-type="taskList"]
    li[data-checked="true"],
  .vault-editor[data-reading-palette]
    .markdown-content
    li:has(> input[type="checkbox"]:checked) {
    color: var(--vault-read-muted);
  }

  .vault-editor[data-reading-palette]
    :is(.vault-live-prose, .markdown-content)
    :is(a, a.vault-live-link),
  .vault-editor[data-reading-palette] .vault-live-prose a[href^="wikilink:"],
  .vault-editor[data-reading-palette] .markdown-wikilink {
    color: var(--vault-read-accent);
  }

  .vault-editor[data-reading-palette] .vault-live-prose code,
  .vault-editor[data-reading-palette] .markdown-content :not(pre) > code {
    color: var(--vault-read-fg);
    background: color-mix(in srgb, var(--vault-read-fg) 10%, transparent);
  }

  .vault-editor[data-reading-palette="warm"] .vault-live-editor,
  .vault-editor[data-reading-palette="cool"] .vault-live-editor,
  .vault-editor[data-reading-palette="ink"] .vault-live-editor,
  .vault-editor[data-reading-palette="warm"] .vault-markdown-preview,
  .vault-editor[data-reading-palette="cool"] .vault-markdown-preview,
  .vault-editor[data-reading-palette="ink"] .vault-markdown-preview {
    background: var(--vault-read-bg);
  }

  /* Named color marks keep their swatches; force bright (dark-canvas) values in light shell. */
  html:not(.dark) .vault-editor .markdown-color-red,
  html:not(.dark) .vault-editor .markdown-content .markdown-color-red,
  html:not(.dark) .vault-editor .markdown-content span.markdown-color-red {
    color: #f87171 !important;
  }

  html:not(.dark) .vault-editor .markdown-color-orange,
  html:not(.dark) .vault-editor .markdown-content .markdown-color-orange,
  html:not(.dark) .vault-editor .markdown-content span.markdown-color-orange {
    color: #fb923c !important;
  }

  html:not(.dark) .vault-editor .markdown-color-yellow,
  html:not(.dark) .vault-editor .markdown-content .markdown-color-yellow,
  html:not(.dark) .vault-editor .markdown-content span.markdown-color-yellow {
    color: #facc15 !important;
  }

  html:not(.dark) .vault-editor .markdown-color-green,
  html:not(.dark) .vault-editor .markdown-content .markdown-color-green,
  html:not(.dark) .vault-editor .markdown-content span.markdown-color-green {
    color: #4ade80 !important;
  }

  html:not(.dark) .vault-editor .markdown-color-blue,
  html:not(.dark) .vault-editor .markdown-content .markdown-color-blue,
  html:not(.dark) .vault-editor .markdown-content span.markdown-color-blue {
    color: #60a5fa !important;
  }

  html:not(.dark) .vault-editor .markdown-color-purple,
  html:not(.dark) .vault-editor .markdown-content .markdown-color-purple,
  html:not(.dark) .vault-editor .markdown-content span.markdown-color-purple {
    color: #c084fc !important;
  }

  html:not(.dark) .vault-editor .markdown-color-pink,
  html:not(.dark) .vault-editor .markdown-content .markdown-color-pink,
  html:not(.dark) .vault-editor .markdown-content span.markdown-color-pink {
    color: #f472b6 !important;
  }

  /* Embeds: shell pane glass — never light-paper flash inside the note. */
  .vault-editor .liquid-chart,
  .vault-editor .liquid-report,
  html:not(.dark) .vault-editor .liquid-chart,
  html:not(.dark) .vault-editor .liquid-report {
    background: var(--vault-embed-bg);
    border-color: var(--vault-embed-border);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.04);
  }

  .vault-editor .liquid-chart-tooltip,
  html:not(.dark) .vault-editor .liquid-chart-tooltip {
    background: color-mix(
      in srgb,
      rgb(var(--shell-pane-bg, var(--color-surface-900))) 86%,
      transparent
    );
    border-color: var(--vault-embed-border);
    box-shadow: 0 10px 28px rgb(0 0 0 / 0.4);
    color: rgb(var(--chart-fg));
  }

  .vault-editor .vault-live-chart {
    background: var(--vault-embed-bg);
    border-color: var(--vault-embed-border);
  }

  /* Gapcursor: TipTap/StarterKit needs these or the widget paints as a blank square. */
  .vault-live-editor .ProseMirror-gapcursor {
    display: none;
    pointer-events: none;
    position: absolute;
  }

  .vault-live-editor .ProseMirror-gapcursor:after {
    content: "";
    display: block;
    position: absolute;
    top: -2px;
    width: 20px;
    border-top: 1px solid rgb(var(--shell-fg, var(--color-surface-50)));
    animation: vault-live-gapcursor-blink 1.1s steps(2, start) infinite;
  }

  @keyframes vault-live-gapcursor-blink {
    to {
      visibility: hidden;
    }
  }

  .vault-live-editor .ProseMirror-focused .ProseMirror-gapcursor {
    display: block;
  }

  .vault-live-prose table.vault-live-table,
  .vault-live-prose .vault-live-table {
    width: 100%;
    margin: 0.75rem 0 1rem;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .vault-live-prose .vault-live-table th,
  .vault-live-prose .vault-live-table td {
    position: relative;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.35);
    padding: 0.35rem 0.55rem;
    vertical-align: top;
    min-width: 3rem;
  }

  .vault-live-prose .vault-live-table th {
    background: rgb(var(--color-surface-800) / 0.55);
    font-weight: 600;
    color: rgb(var(--color-surface-100));
    text-align: left;
  }

  .vault-live-prose .vault-live-table td {
    background: rgb(var(--color-surface-900) / 0.25);
  }

  /* Resume Live: section rhythm + wide short-cell tables as matrix chips. */
  [data-note-kind="resume"] .vault-live-prose h1 {
    margin: 0 0 0.35rem;
    font-size: 1.65rem;
    letter-spacing: -0.03em;
  }

  [data-note-kind="resume"] .vault-live-prose h1 + p {
    margin: 0 0 1rem;
    font-size: 0.875rem;
    color: rgb(var(--color-surface-400));
  }

  [data-note-kind="resume"] .vault-live-prose h2 {
    margin: 1.65rem 0 0.55rem;
    padding-bottom: 0.3rem;
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-surface-400));
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.4);
  }

  [data-note-kind="resume"] .vault-live-prose h3 {
    margin: 1rem 0 0.2rem;
    font-size: 1rem;
    font-weight: 650;
  }

  [data-note-kind="resume"] .vault-live-prose h3 + p {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.35rem 1rem;
    margin: 0 0 0.45rem;
    font-size: 0.875rem;
    color: rgb(var(--color-surface-400));
  }

  [data-note-kind="resume"] .vault-live-prose ul,
  [data-note-kind="resume"] .vault-live-prose ol {
    margin: 0.35rem 0 0.85rem;
  }

  [data-note-kind="resume"] .vault-live-prose li {
    margin: 0.35rem 0;
    line-height: 1.45;
  }

  [data-note-kind="resume"] .vault-live-prose li > strong:first-child {
    color: rgb(var(--color-surface-100));
    font-weight: 650;
  }

  /* Live: section skill lists directly under H2 become chip rows. */
  [data-note-kind="resume"] .vault-live-prose h2 + ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.45rem 0 0.85rem;
    padding: 0;
    list-style: none;
  }

  [data-note-kind="resume"] .vault-live-prose h2 + ul > li {
    margin: 0;
    padding: 0.28rem 0.65rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.34);
    border-radius: 999px;
    background: rgb(var(--color-surface-800) / 0.48);
    font-size: 0.8rem;
    font-weight: 550;
    line-height: 1.3;
  }

  [data-note-kind="resume"] .vault-live-prose .vault-live-table:has(tr > :nth-child(3)) {
    border-collapse: separate;
    border-spacing: 0.4rem;
    margin: 0.5rem 0 1rem;
  }

  [data-note-kind="resume"] .vault-live-prose .vault-live-table:has(tr > :nth-child(3)) th,
  [data-note-kind="resume"] .vault-live-prose .vault-live-table:has(tr > :nth-child(3)) td {
    border: 1px solid rgb(var(--color-surface-500) / 0.35);
    border-radius: 0.55rem;
    text-align: center;
    background: rgb(var(--color-surface-800) / 0.45);
    font-size: 0.8rem;
    font-weight: 550;
  }

  [data-note-kind="resume"] .vault-live-prose .vault-live-table:has(tr > :nth-child(3)) th {
    background: rgb(var(--color-surface-700) / 0.55);
    text-transform: none;
    letter-spacing: 0.01em;
  }

  .vault-live-prose .vault-live-table .selectedCell::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: rgb(var(--color-primary-500) / 0.12);
  }

  .vault-live-table-chrome {
    position: fixed;
    z-index: 80;
    display: flex;
    align-items: center;
    gap: 0.15rem;
    padding: 0.2rem 0.3rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.4);
    border-radius: 0.4rem;
    background: rgb(var(--color-surface-900) / 0.96);
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.35);
  }

  .vault-live-table-chrome__btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.3rem;
    color: rgb(var(--color-surface-300));
    transition: background 120ms ease, color 120ms ease;
  }

  .vault-live-table-chrome__btn:hover:not(:disabled) {
    background: rgb(var(--color-surface-700) / 0.7);
    color: rgb(var(--color-surface-50));
  }

  .vault-live-table-chrome__btn--danger:hover:not(:disabled) {
    color: rgb(var(--color-error-300));
  }

  .vault-live-table-chrome__sep {
    width: 1px;
    height: 1rem;
    margin: 0 0.15rem;
    background: rgb(var(--color-surface-500) / 0.45);
  }

  .vault-live-table-chrome__badge {
    position: absolute;
    right: 0.1rem;
    bottom: 0.1rem;
  }

  .vault-live-mini-kanban,
  .liquid-mini-kanban {
    margin: 0.65rem 0 1rem;
    min-width: 0;
  }

  .vault-live-mini-kanban__label,
  .liquid-mini-kanban__label {
    margin: 0 0 0.4rem;
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
  }

  .vault-live-mini-kanban__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .vault-live-mini-kanban__board,
  .liquid-mini-kanban__board {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8.5rem, 1fr));
    gap: 0.5rem;
  }

  .vault-live-mini-kanban__column,
  .liquid-mini-kanban__column {
    min-width: 0;
    padding: 0.45rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.28);
    border-radius: 0.35rem;
    background: rgb(var(--color-surface-900) / 0.35);
  }

  .vault-live-mini-kanban__column.is-drop-target {
    border-color: rgb(var(--color-primary-400) / 0.55);
  }

  .vault-live-mini-kanban__column-title,
  .liquid-mini-kanban__column-title {
    margin: 0 0 0.4rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgb(var(--color-surface-200));
  }

  .vault-live-mini-kanban__cards,
  .liquid-mini-kanban__cards {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .vault-live-mini-kanban__card,
  .liquid-mini-kanban__card {
    padding: 0.4rem 0.45rem;
    border-radius: 0.28rem;
    background: rgb(var(--color-surface-800) / 0.7);
    color: rgb(var(--color-surface-100));
    font-size: 0.8125rem;
    line-height: 1.35;
    cursor: grab;
  }

  .vault-live-mini-kanban__card.is-drop-before {
    box-shadow: inset 0 2px 0 rgb(var(--color-primary-400) / 0.7);
  }

  .vault-live-mini-kanban__card.is-drop-after {
    box-shadow: inset 0 -2px 0 rgb(var(--color-primary-400) / 0.7);
  }

  .vault-live-mini-kanban__card-text {
    outline: none;
    min-height: 1.1em;
  }

  .vault-live-mini-kanban__add {
    margin-top: 0.35rem;
    width: 100%;
    padding: 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.6875rem;
    color: rgb(var(--color-surface-400));
    text-align: left;
  }

  .vault-live-mini-kanban__add:hover {
    background: rgb(var(--color-surface-700) / 0.45);
    color: rgb(var(--color-surface-200));
  }

  .vault-live-mini-kanban__source {
    font-size: 0.6875rem;
    color: rgb(var(--color-surface-400));
  }

  .vault-live-tag-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0 0 1rem;
    padding: 0;
  }

  .vault-live-tag-chip {
    appearance: none;
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    background: rgb(var(--color-surface-800) / 0.55);
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.22);
    border-radius: 0.25rem;
    padding: 0.15rem 0.45rem;
  }

  .vault-live-tag-chip--more {
    cursor: pointer;
    color: rgb(var(--color-surface-500));
  }

  .vault-live-tag-chip--more:hover {
    color: rgb(var(--color-surface-300));
  }

  /* Live properties — intimate rows, not a metadata spreadsheet */
  .vault-live-properties {
    --vlp-key-w: 4.85rem;
    --vlp-ink: rgb(var(--shell-fg, var(--color-surface-100)));
    --vlp-mute: rgb(var(--shell-muted, var(--color-surface-400)));
    --vlp-faint: rgb(var(--shell-muted, var(--color-surface-500)));
    margin: 0 0 1.35rem;
    padding: 0;
  }

  .vault-live-properties__disclosure {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    margin: 0 0 0.2rem;
    padding: 0.2rem 0.35rem 0.2rem 0.1rem;
    border: none;
    border-radius: 0.3rem;
    background: transparent;
    cursor: pointer;
    color: var(--vlp-mute);
    transition: color 140ms ease, background-color 140ms ease;
  }

  .vault-live-properties__disclosure:hover {
    color: var(--vlp-ink);
    background: rgb(var(--color-surface-800) / 0.4);
  }

  .vault-live-properties__disclosure-label {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1;
  }

  .vault-live-properties__chevron {
    display: block;
    flex-shrink: 0;
    margin-top: 0.05rem;
    opacity: 0.75;
    transition: transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 140ms ease;
  }

  .vault-live-properties__disclosure:hover .vault-live-properties__chevron {
    opacity: 1;
  }

  .vault-live-properties--open .vault-live-properties__chevron {
    transform: rotate(90deg);
  }

  .vault-live-properties__body {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    animation: vault-live-properties-in 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  @keyframes vault-live-properties-in {
    from {
      opacity: 0;
      transform: translateY(-3px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .vault-live-properties__row {
    display: grid;
    grid-template-columns: var(--vlp-key-w) minmax(0, 1fr);
    align-items: center;
    column-gap: 0.85rem;
    min-height: 1.85rem;
    margin: 0;
    padding: 0.22rem 0.4rem 0.22rem 0.15rem;
    border-radius: 0.4rem;
    transition: background-color 160ms ease;
  }

  .vault-live-properties__row:hover:not(.vault-live-properties__row--disabled) {
    background: rgb(var(--color-surface-800) / 0.22);
  }

  /* Editing = soft highlight on the row, never a field chrome */
  .vault-live-properties__row--active,
  .vault-live-properties__row:focus-within {
    background: rgb(var(--color-surface-800) / 0.3);
  }

  .vault-live-properties__row--tags {
    align-items: center;
    cursor: text;
  }

  .vault-live-properties__row--empty .vault-live-properties__tags {
    opacity: 0.92;
  }

  .vault-live-properties__row--disabled {
    opacity: 0.5;
    cursor: default;
    pointer-events: none;
  }

  /* Icon + label as one intimate unit; values share a clean left edge */
  .vault-live-properties__key {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    width: max-content;
    max-width: 100%;
    margin: 0;
    padding: 0.15rem 0;
    border: none;
    background: transparent;
    cursor: pointer;
    color: var(--vlp-mute);
    transition: color 140ms ease;
  }

  .vault-live-properties__row:hover .vault-live-properties__key,
  .vault-live-properties__row--active .vault-live-properties__key,
  .vault-live-properties__row:focus-within .vault-live-properties__key {
    color: rgb(var(--shell-muted, var(--color-surface-300)));
  }

  .vault-live-properties__key:disabled {
    cursor: default;
  }

  .vault-live-properties__icon {
    display: block;
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    color: inherit;
  }

  .vault-live-properties__label {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1;
    white-space: nowrap;
  }

  .vault-live-properties__value {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    min-width: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    padding: 0.15rem 0;
    margin: 0;
    font: inherit;
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.35;
    color: var(--vlp-ink);
    outline: none;
    caret-color: rgb(var(--shell-fg, var(--color-surface-100)));
  }

  .vault-live-properties__value:focus,
  .vault-live-properties__value:focus-visible {
    border: 0;
    outline: none;
    box-shadow: none;
    background: transparent;
    color: rgb(var(--shell-fg, var(--color-surface-50)));
  }

  .vault-live-properties__value::placeholder {
    color: var(--vlp-faint);
    font-style: italic;
    font-weight: 400;
    opacity: 0.75;
  }

  .vault-live-properties__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.32rem;
    align-items: center;
    min-width: 0;
    min-height: 1.55rem;
  }

  .vault-live-properties__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.1rem;
    max-width: 100%;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: rgb(var(--shell-fg, var(--color-surface-100)));
    background: rgb(var(--color-surface-700) / 0.45);
    border: 1px solid transparent;
    border-radius: 0.35rem;
    padding: 0.16rem 0.2rem 0.16rem 0.48rem;
    animation: vault-live-tag-in 160ms cubic-bezier(0.2, 0.8, 0.2, 1);
    transition:
      background-color 140ms ease,
      border-color 140ms ease,
      color 140ms ease;
  }

  @keyframes vault-live-tag-in {
    from {
      opacity: 0;
      transform: scale(0.96);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .vault-live-properties__tag:hover {
    background: rgb(var(--color-surface-600) / 0.4);
    border-color: rgb(var(--shell-border, var(--color-surface-500)) / 0.28);
  }

  .vault-live-properties__tag-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 1.2;
  }

  /* Remove stays quiet until the chip is hovered — less noise, more care */
  .vault-live-properties__tag-remove {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.1rem;
    height: 1.1rem;
    border: none;
    background: transparent;
    color: var(--vlp-faint);
    line-height: 1;
    padding: 0;
    margin: 0;
    border-radius: 0.25rem;
    cursor: pointer;
    opacity: 0.35;
    transition:
      opacity 120ms ease,
      color 120ms ease,
      background-color 120ms ease;
  }

  .vault-live-properties__tag:hover .vault-live-properties__tag-remove,
  .vault-live-properties__tag-remove:focus-visible {
    opacity: 1;
    color: rgb(var(--shell-fg, var(--color-surface-100)));
  }

  .vault-live-properties__tag-remove:hover {
    background: rgb(var(--color-surface-500) / 0.35);
  }

  /* Tag compose: a chip being typed — not a mini form field */
  .vault-live-properties__tag-input {
    appearance: none;
    -webkit-appearance: none;
    border: 0;
    border-radius: 0.35rem;
    background: rgb(var(--color-surface-700) / 0.35);
    box-shadow: none;
    padding: 0.16rem 0.48rem;
    margin: 0;
    font: inherit;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: rgb(var(--shell-fg, var(--color-surface-100)));
    min-width: 3.5ch;
    max-width: 14rem;
    outline: none;
    caret-color: rgb(var(--shell-fg, var(--color-surface-100)));
    animation: vault-live-tag-in 140ms cubic-bezier(0.2, 0.8, 0.2, 1);
    transition: background-color 140ms ease, width 80ms ease;
  }

  .vault-live-properties__tag-input:focus,
  .vault-live-properties__tag-input:focus-visible {
    border: 0;
    outline: none;
    box-shadow: none;
    background: rgb(var(--color-surface-600) / 0.4);
  }

  .vault-live-properties__tag-input::placeholder {
    color: var(--vlp-faint);
    font-weight: 400;
    font-style: italic;
    opacity: 0.7;
  }

  .vault-live-properties__add {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.28rem;
    min-width: 1.4rem;
    height: 1.4rem;
    padding: 0 0.28rem;
    border: 1px dashed transparent;
    border-radius: 0.35rem;
    background: transparent;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--vlp-faint);
    cursor: pointer;
    transition:
      color 140ms ease,
      background-color 140ms ease,
      border-color 140ms ease;
  }

  .vault-live-properties__add:hover {
    color: rgb(var(--shell-muted, var(--color-surface-200)));
    background: rgb(var(--color-surface-700) / 0.35);
  }

  .vault-live-properties__add--empty {
    height: auto;
    min-height: 1.35rem;
    padding: 0.1rem 0.15rem;
    border: none;
    color: var(--vlp-faint);
    font-style: italic;
    font-weight: 400;
  }

  .vault-live-properties__add--empty:hover {
    color: var(--vlp-mute);
    background: transparent;
  }

  @media (prefers-reduced-motion: reduce) {
    .vault-live-properties__body,
    .vault-live-properties__tag,
    .vault-live-properties__tag-input,
    .vault-live-properties__chevron {
      animation: none !important;
      transition: none !important;
    }
  }

  /* Selection format bubble (Live) */
  .vault-selection-format-bubble {
    position: fixed;
    z-index: 80;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.28rem 0.35rem;
    border-radius: 0.55rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.45);
    background: rgb(var(--color-surface-900) / 0.96);
    box-shadow: 0 8px 28px rgb(0 0 0 / 0.28);
    max-width: calc(100vw - 1rem);
  }

  .vault-selection-format-bubble__row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.1rem;
  }

  .vault-selection-format-bubble__sep {
    width: 1px;
    height: 1rem;
    margin: 0 0.2rem;
    background: rgb(var(--shell-border, var(--color-surface-500)) / 0.4);
    flex-shrink: 0;
  }

  .vault-selection-format-bubble__btn {
    appearance: none;
    border: none;
    background: transparent;
    color: rgb(var(--shell-muted, var(--color-surface-300)));
    width: 1.55rem;
    height: 1.55rem;
    border-radius: 0.3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
  }

  .vault-selection-format-bubble__btn:hover {
    background: rgb(var(--color-surface-700) / 0.45);
    color: rgb(var(--shell-fg, var(--color-surface-50)));
  }

  .vault-selection-format-bubble__btn--active {
    background: rgb(var(--color-surface-700) / 0.55);
    color: rgb(var(--shell-fg, var(--color-surface-50)));
  }

  .vault-selection-format-bubble__btn--label {
    font-size: 0.75rem;
    font-weight: 600;
  }

  .vault-selection-format-bubble__colors {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
    padding: 0.1rem 0.15rem 0.15rem;
  }

  .vault-selection-format-bubble__swatch {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.35);
    cursor: pointer;
    padding: 0;
  }

  .vault-selection-format-bubble__swatch--custom {
    background: conic-gradient(
      from 180deg,
      #f87171,
      #facc15,
      #4ade80,
      #60a5fa,
      #c084fc,
      #f472b6,
      #f87171
    );
  }

  .vault-selection-format-bubble__hex {
    appearance: none;
    width: 5.5rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.4);
    background: transparent;
    border-radius: 0.25rem;
    padding: 0.15rem 0.35rem;
    font-size: 0.6875rem;
    color: rgb(var(--shell-fg, var(--color-surface-50)));
  }

  .vault-selection-format-bubble__hex-apply {
    appearance: none;
    border: none;
    background: transparent;
    font-size: 0.6875rem;
    color: rgb(var(--shell-muted, var(--color-surface-300)));
    cursor: pointer;
  }

  .vault-live-prose mark.vault-live-highlight,
  .vault-live-prose mark[data-vault-highlight] {
    background: rgb(var(--color-warning-500, 250 204 21) / 0.28);
    color: inherit;
    border-radius: 0.15rem;
    padding: 0 0.05em;
  }

  .vault-live-editor__host {
    min-width: 0;
    max-width: 100%;
    min-height: 12rem;
  }

  .vault-live-editor .ProseMirror,
  .vault-live-editor .vault-live-prose {
    outline: none;
    min-width: 0;
    max-width: 100%;
    min-height: 12rem;
    color: rgb(var(--color-surface-50));
    font-size: 0.9375rem;
    line-height: 1.7;
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: anywhere;
    overflow-anchor: none;
  }

  .vault-live-editor .ProseMirror p.is-editor-empty:first-child::before {
    content: attr(data-placeholder);
    float: left;
    height: 0;
    pointer-events: none;
    color: rgb(var(--shell-muted, var(--color-surface-600)));
    font-weight: 400;
  }

  .vault-live-editor .ProseMirror > h1.vault-live-h1--dup-title {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .vault-live-prose h1 {
    @apply text-2xl font-semibold tracking-tight mb-3 mt-1;
  }

  .vault-live-prose h2 {
    @apply text-xl font-semibold tracking-tight mb-2 mt-6;
  }

  .vault-live-prose h3 {
    @apply text-lg font-medium mb-2 mt-5;
  }

  .vault-live-heading-marks {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75em;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: rgb(var(--color-surface-500));
    opacity: 0.72;
    user-select: none;
    pointer-events: none;
  }

  .vault-live-prose p {
    @apply mb-3;
  }

  .vault-live-prose ul {
    @apply list-disc pl-5 mb-3;
  }

  .vault-live-prose ol {
    @apply list-decimal pl-5 mb-3;
  }

  /* Task lists — match Preview theme-native checkboxes */
  .vault-live-prose ul[data-type="taskList"] {
    list-style: none;
    padding-left: 0;
    margin: 0 0 0.75rem;
  }

  .vault-live-prose ul[data-type="taskList"] li {
    display: flex;
    align-items: flex-start;
    gap: 0;
    margin: 0.15rem 0;
  }

  .vault-live-prose ul[data-type="taskList"] li > label {
    display: inline-flex;
    align-items: flex-start;
    margin: 0.2em 0.55rem 0 0;
    flex-shrink: 0;
  }

  .vault-live-prose ul[data-type="taskList"] li > label > span {
    display: none;
  }

  .vault-live-prose ul[data-type="taskList"] li > div {
    flex: 1;
    min-width: 0;
  }

  .vault-live-prose ul[data-type="taskList"] li > div > p {
    margin: 0;
  }

  .vault-live-prose ul[data-type="taskList"] input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    display: inline-grid;
    place-content: center;
    width: 0.95rem;
    height: 0.95rem;
    margin: 0;
    flex-shrink: 0;
    vertical-align: text-top;
    border-radius: 0.28rem;
    border: 1.5px solid rgb(var(--color-surface-400) / 0.42);
    background-color: rgb(var(--color-surface-800) / 0.55);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.04);
    cursor: pointer;
    transition:
      border-color 140ms ease,
      background-color 140ms ease,
      box-shadow 140ms ease,
      transform 140ms ease;
  }

  .vault-live-prose ul[data-type="taskList"] input[type="checkbox"]::before {
    content: "";
    width: 0.55rem;
    height: 0.55rem;
    transform: scale(0);
    transition: transform 120ms ease;
    background-color: rgb(var(--on-primary));
    clip-path: polygon(14% 44%, 0 65%, 50% 100%, 100% 16%, 80% 0, 43% 62%);
  }

  .vault-live-prose ul[data-type="taskList"] input[type="checkbox"]:checked {
    border-color: rgb(var(--color-primary-400) / 0.9);
    background-color: rgb(var(--color-primary-500));
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.12),
      0 0 0 1px rgb(var(--color-primary-500) / 0.2);
  }

  .vault-live-prose ul[data-type="taskList"] input[type="checkbox"]:checked::before {
    transform: scale(1);
  }

  .vault-live-prose ul[data-type="taskList"] input[type="checkbox"]:hover:not(:checked) {
    border-color: rgb(var(--color-primary-400) / 0.55);
    background-color: rgb(var(--color-surface-700) / 0.75);
  }

  .vault-live-prose ul[data-type="taskList"] input[type="checkbox"]:hover:checked {
    background-color: rgb(var(--color-primary-400));
  }

  .vault-live-prose ul[data-type="taskList"] input[type="checkbox"]:active {
    transform: scale(0.94);
  }

  .vault-live-prose ul[data-type="taskList"] input[type="checkbox"]:focus-visible {
    outline: 2px solid rgb(var(--color-primary-400) / 0.55);
    outline-offset: 2px;
  }

  .vault-live-prose ul[data-type="taskList"] li[data-checked="true"] {
    color: rgb(var(--shell-muted, var(--color-surface-400)));
  }

  .vault-live-prose blockquote {
    @apply border-l-2 border-surface-600 pl-3 my-3 text-surface-300;
  }

  .vault-live-hr {
    margin: 1.1rem 0;
    padding: 0.55rem 0;
    cursor: text;
  }

  .vault-live-hr__line {
    margin: 0;
    border: 0;
    border-top: 1px solid rgb(var(--color-surface-600) / 0.75);
  }

  .vault-live-hr:hover .vault-live-hr__line {
    border-top-color: rgb(var(--color-surface-400) / 0.85);
  }

  .vault-live-prose code {
    @apply text-[0.85em] px-1 py-0.5 rounded bg-surface-800/80 text-surface-200;
  }

  .vault-live-prose a.vault-live-link {
    @apply text-primary-300 underline decoration-primary-500/40 underline-offset-2;
  }

  .vault-live-prose a[href^="wikilink:"] {
    color: rgb(var(--color-primary-300));
    text-decoration: none;
    border-bottom: 1px solid rgb(var(--color-primary-500) / 0.35);
    border-radius: 0.1rem;
  }

  .vault-live-prose a[href^="wikilink:"]:hover {
    border-bottom-color: rgb(var(--color-primary-400) / 0.7);
  }

  /* Liquid Live — organism hosts (Preview-class surfaces, no Edit-in-Build) */
  .vault-live-organism-host {
    margin: 0.85rem 0 1.1rem;
  }

  .vault-live-organism {
    min-width: 0;
  }

  .vault-live-plain-fence {
    margin: 0;
    padding: 0.5rem 0.75rem 0.65rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.22);
    border-radius: 0.3rem;
    background: rgb(var(--color-surface-900) / 0.4);
  }

  .vault-live-plain-fence__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    min-height: 1.1rem;
    margin-bottom: 0.3rem;
  }

  .vault-live-plain-fence__lang {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.625rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
  }

  .vault-live-plain-fence__meta {
    margin-left: auto;
  }

  .vault-live-plain-fence__edit {
    appearance: none;
    border: none;
    background: transparent;
    padding: 0.12rem 0.2rem;
    font-size: 0.625rem;
    letter-spacing: 0.02em;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
    cursor: pointer;
  }

  .vault-live-plain-fence__edit:hover {
    color: rgb(var(--color-surface-200));
  }

  .vault-live-plain-fence__body {
    margin: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    line-height: 1.45;
    color: rgb(var(--color-surface-200));
    white-space: pre-wrap;
    word-break: break-word;
    cursor: text;
    user-select: text;
    -webkit-user-select: text;
  }

  .vault-live-code__stage,
  .vault-live-code__stage .liquid-code-pre,
  .vault-live-code__stage .liquid-code-pre code {
    cursor: text;
    user-select: text;
    -webkit-user-select: text;
  }

  .vault-live-fence-raw-shell {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
    border: 1px solid rgb(var(--color-primary-400) / 0.35);
    border-radius: 0.3rem;
    background: rgb(var(--color-surface-900) / 0.55);
    overflow: hidden;
  }

  .vault-live-fence-raw {
    display: block;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0.65rem 0.75rem;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: rgb(var(--color-surface-100));
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    line-height: 1.45;
    resize: none;
    outline: none;
    box-shadow: none;
    caret-color: rgb(var(--color-primary-300));
    appearance: none;
    -webkit-appearance: none;
    overflow: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .vault-live-fence-raw::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  .vault-live-fence-raw:focus,
  .vault-live-fence-raw:focus-visible {
    outline: none;
    box-shadow: none;
    background: transparent;
  }

  .vault-live-fence-raw::selection {
    background: rgb(var(--color-primary-500) / 0.28);
    color: rgb(var(--color-surface-50));
  }

  /* Shared quiet chrome — calm at rest, present on intent */
  .vault-live-quiet-chrome {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    pointer-events: none;
    transition:
      opacity 150ms ease,
      max-height 150ms ease;
  }

  .vault-live-organism-host:hover .vault-live-quiet-chrome,
  .vault-live-organism-host:focus-within .vault-live-quiet-chrome,
  .ProseMirror-selectednode .vault-live-quiet-chrome,
  .vault-live-callout:hover .vault-live-quiet-chrome,
  .vault-live-callout:focus-within .vault-live-quiet-chrome,
  .vault-live-report:hover .vault-live-quiet-chrome,
  .vault-live-report:focus-within .vault-live-quiet-chrome,
  .vault-live-chart:hover .vault-live-quiet-chrome,
  .vault-live-chart:focus-within .vault-live-quiet-chrome,
  .vault-live-card:hover .vault-live-quiet-chrome,
  .vault-live-card:focus-within .vault-live-quiet-chrome,
  .vault-live-dashboard:hover .vault-live-quiet-chrome,
  .vault-live-dashboard:focus-within .vault-live-quiet-chrome,
  .vault-live-tabs:hover .vault-live-quiet-chrome,
  .vault-live-tabs:focus-within .vault-live-quiet-chrome,
  .vault-live-steps:hover .vault-live-quiet-chrome,
  .vault-live-steps:focus-within .vault-live-quiet-chrome,
  .vault-live-accordion:hover .vault-live-quiet-chrome,
  .vault-live-accordion:focus-within .vault-live-quiet-chrome,
  .vault-live-code:hover .vault-live-quiet-chrome,
  .vault-live-code:focus-within .vault-live-quiet-chrome,
  .vault-live-tree:hover .vault-live-quiet-chrome,
  .vault-live-tree:focus-within .vault-live-quiet-chrome,
  .vault-live-compare:hover .vault-live-quiet-chrome,
  .vault-live-compare:focus-within .vault-live-quiet-chrome,
  .vault-live-embed:hover .vault-live-quiet-chrome,
  .vault-live-embed:focus-within .vault-live-quiet-chrome,
  .vault-live-plain-fence:hover .vault-live-quiet-chrome,
  .vault-live-plain-fence:focus-within .vault-live-quiet-chrome {
    opacity: 1;
    max-height: 2.75rem;
    pointer-events: auto;
  }

  .vault-live-callout {
    position: relative;
  }

  .vault-live-callout__chrome {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
    margin: 0 0 0.45rem;
  }

  .vault-live-callout__tone {
    font-size: 0.625rem;
    letter-spacing: 0.02em;
    text-transform: lowercase;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    background: transparent;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.35);
    border-radius: 0.2rem;
    padding: 0.1rem 0.4rem;
    cursor: pointer;
  }

  .vault-live-callout__tone[aria-pressed="true"] {
    color: rgb(var(--shell-fg, var(--color-surface-50)));
    border-color: rgb(var(--shell-border, var(--color-surface-300)) / 0.55);
  }

  .vault-live-callout__title,
  .vault-live-callout__body {
    outline: none;
    min-height: 1.25em;
  }

  .vault-live-callout__title:empty::before,
  .vault-live-callout__body:empty::before {
    content: attr(data-placeholder);
    color: rgb(var(--shell-muted, var(--color-surface-500)));
    pointer-events: none;
  }

  .vault-live-embed {
    margin: 0;
  }

  .vault-live-embed__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    cursor: pointer;
  }

  .vault-live-embed__actions {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .vault-live-embed__expand {
    opacity: 0.85;
  }

  .vault-live-embed__secondary.vault-live-quiet-chrome {
    display: inline-flex;
    flex-wrap: nowrap;
  }

  .vault-live-embed__icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    padding: 0;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    background: transparent;
    border: 1px solid transparent;
    border-radius: 0.3rem;
    cursor: pointer;
    transition:
      color 120ms ease,
      background-color 120ms ease,
      border-color 120ms ease;
  }

  .vault-live-embed__icon-btn:hover {
    color: rgb(var(--shell-fg, var(--color-surface-100)));
    background: rgb(var(--color-surface-800) / 0.7);
    border-color: rgb(var(--shell-border, var(--color-surface-500)) / 0.35);
  }

  .vault-live-embed__icon-btn .vault-live-icon {
    display: block;
  }

  /* Collapsed: folded page in the stream — not a form dropdown. */
  .vault-live-embed.vault-live-embed--collapsed {
    display: flex;
    justify-content: flex-end;
    width: 100%;
    margin: 0.45rem 0;
    border: none;
    background: transparent;
    overflow: visible;
  }

  .vault-live-embed--collapsed .vault-live-embed__body {
    display: none;
  }

  .vault-live-embed--collapsed .vault-live-embed__header {
    width: fit-content;
    max-width: min(100%, 18rem);
    margin-left: auto;
    gap: 0.35rem;
    border: none;
    border-radius: 0;
    background: transparent;
    padding: 0.15rem 0;
    border-bottom: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.28);
    box-shadow: none;
  }

  .vault-live-embed--collapsed .vault-live-embed__header:hover {
    border-bottom-color: rgb(var(--color-surface-400) / 0.55);
  }

  .vault-live-embed--collapsed .markdown-transclusion-label {
    max-width: 15rem;
    color: rgb(var(--color-surface-300));
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .vault-live-embed--collapsed .vault-live-embed__expand {
    opacity: 0.45;
    width: 1.25rem;
    height: 1.25rem;
  }

  .vault-live-embed--collapsed .vault-live-embed__header:hover .vault-live-embed__expand {
    opacity: 0.75;
  }

  .vault-live-embed--collapsed .vault-live-embed__secondary {
    display: none;
  }

  .vault-editor-tools .badge {
    opacity: 0.85;
    font-weight: 500;
  }

  .vault-live-embed--expanded {
    border-color: rgb(var(--shell-border, var(--color-surface-500)) / 0.28);
    background: transparent;
  }

  .vault-live-embed--expanded .vault-live-embed__header {
    background: transparent;
    border-bottom-color: rgb(var(--shell-border, var(--color-surface-500)) / 0.2);
  }

  .vault-live-embed--expanded .vault-live-embed__body {
    display: block;
    animation: vault-live-embed-open 180ms ease;
  }

  @keyframes vault-live-embed-open {
    from {
      opacity: 0;
      transform: translateY(-0.2rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .vault-live-embed__body--editing {
    white-space: pre-wrap;
    outline: none;
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.28);
    border-radius: 0.25rem;
    padding: 0.45rem 0.55rem;
    min-height: 3rem;
    background: rgb(var(--color-surface-900) / 0.25);
  }

  .vault-live-view-pending {
    font-size: 0.8125rem;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    padding: 0.5rem 0;
  }

  .vault-live-report__chrome,
  .vault-live-slides__chrome {
    justify-content: space-between;
    margin: 0 0 0.45rem;
  }

  /* One figure — title + type belong to the chart card, not a ribbon above it */
  .vault-live-chart {
    margin: 0.35rem 0 0.85rem;
    padding: 0.75rem 0.85rem 0.8rem;
    border-radius: 0.9rem;
    border: 1px solid rgb(var(--color-surface-500) / 0.22);
    background: rgb(var(--color-surface-50) / 0.04);
    box-sizing: border-box;
  }

  .vault-live-chart__head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 0.75rem;
    margin: 0 0 0.55rem;
    padding: 0 0 0.55rem;
    border-bottom: 1px solid rgb(var(--color-surface-500) / 0.18);
  }

  .vault-live-chart__title {
    flex: 1 1 8rem;
    margin: 0;
    outline: none;
    min-height: 1.25em;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
    color: rgb(var(--shell-fg, var(--color-surface-50)));
  }

  .vault-live-chart__title:empty::before {
    content: attr(data-placeholder);
    color: rgb(var(--shell-muted, var(--color-surface-500)));
    font-weight: 500;
    pointer-events: none;
  }

  .vault-live-chart__meta {
    flex: 0 0 auto;
    justify-content: flex-end;
    gap: 0.45rem;
  }

  .vault-live-chart__types {
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem;
  }

  .vault-live-chart__type {
    font-size: 0.625rem;
    letter-spacing: 0.02em;
    text-transform: lowercase;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
    background: transparent;
    border: none;
    border-radius: 0.2rem;
    padding: 0.12rem 0.35rem;
    cursor: pointer;
  }

  .vault-live-chart__type:hover {
    color: rgb(var(--shell-muted, var(--color-surface-300)));
  }

  .vault-live-chart__type[aria-pressed="true"] {
    color: rgb(var(--shell-fg, var(--color-surface-100)));
    background: rgb(var(--color-surface-800) / 0.55);
  }

  .vault-live-chart__configure {
    appearance: none;
    border: none;
    background: transparent;
    padding: 0.12rem 0.2rem;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: lowercase;
    color: rgb(var(--shell-muted, var(--color-surface-600)));
    cursor: pointer;
  }

  .vault-live-chart__configure:hover {
    color: rgb(var(--shell-muted, var(--color-surface-350, var(--color-surface-400))));
  }

  .vault-live-chart__stage .liquid-chart-toolbar {
    display: none !important;
  }

  .vault-live-chart__stage .liquid-chart-shell {
    margin: 0;
  }

  /* Flatten nested organism chrome — outer figure is the card */
  .vault-live-chart__stage .liquid-chart {
    margin: 0 !important;
    padding: 0 !important;
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    border-radius: 0 !important;
  }

  .vault-live-chart__arrival {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.35rem 0 0.15rem;
    min-height: 5.5rem;
  }

  .vault-live-chart__arrival-label {
    margin: 0;
    font-size: 0.8125rem;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
  }

  .vault-live-chart__arrival-types {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .vault-live-chart__arrival-type {
    appearance: none;
    font-size: 0.8125rem;
    letter-spacing: 0.01em;
    text-transform: lowercase;
    color: rgb(var(--shell-fg, var(--color-surface-100)));
    background: rgb(var(--color-surface-800) / 0.55);
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.35);
    border-radius: 0.4rem;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    transition:
      border-color 120ms ease,
      background-color 120ms ease;
  }

  .vault-live-chart__arrival-type:hover {
    border-color: rgb(var(--color-primary-500) / 0.45);
    background: rgb(var(--color-primary-500) / 0.1);
  }

  .vault-live-chart--arrival .vault-live-chart__meta {
    /* Arrival chooses type in the body; keep head calm */
    display: none;
  }

  .vault-live-report__cols,
  .vault-live-slides__cols {
    display: flex;
    gap: 0.25rem;
  }

  .vault-live-report__col,
  .vault-live-report__edit,
  .vault-live-slides__col,
  .vault-live-slides__edit {
    font-size: 0.625rem;
    letter-spacing: 0.02em;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    background: transparent;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.35);
    border-radius: 0.2rem;
    padding: 0.1rem 0.4rem;
    cursor: pointer;
  }

  .vault-live-report__col[aria-pressed="true"],
  .vault-live-slides__col[aria-pressed="true"] {
    color: rgb(var(--shell-fg, var(--color-surface-50)));
    border-color: rgb(var(--shell-border, var(--color-surface-300)) / 0.55);
  }

  .vault-live-report__field,
  .vault-live-slides__field {
    display: block;
    width: 100%;
    margin: 0 0 0.4rem;
    padding: 0.35rem 0.5rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.3);
    border-radius: 0.25rem;
    background: rgb(var(--color-surface-900) / 0.45);
    color: rgb(var(--color-surface-50));
    font-size: 0.875rem;
  }

  .vault-live-report__body,
  .vault-live-slides__body {
    display: block;
    width: 100%;
    min-height: 8rem;
    padding: 0.5rem 0.55rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.3);
    border-radius: 0.25rem;
    background: rgb(var(--color-surface-900) / 0.45);
    color: rgb(var(--color-surface-100));
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    line-height: 1.45;
    resize: vertical;
  }

  .vault-live-card {
    position: relative;
  }

  .vault-live-card__chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.35rem;
  }

  .vault-live-card__quiet {
    margin-left: auto;
    display: flex;
    align-items: center;
  }

  .vault-live-card__emoji {
    font-size: 1.1rem;
    line-height: 1;
  }

  .vault-live-card__expand,
  .vault-live-card__configure,
  .vault-live-callout__configure,
  .vault-live-dashboard__configure,
  .vault-live-tabs__configure,
  .vault-live-steps__configure,
  .vault-live-accordion__configure,
  .vault-live-code__configure,
  .vault-live-code__lang,
  .vault-live-tree__configure,
  .vault-live-compare__configure {
    appearance: none;
    border: none;
    background: transparent;
    padding: 0.12rem 0.2rem;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: lowercase;
    color: rgb(var(--shell-muted, var(--color-surface-600)));
    cursor: pointer;
  }

  .vault-live-card__configure,
  .vault-live-callout__configure,
  .vault-live-dashboard__configure,
  .vault-live-tabs__configure,
  .vault-live-steps__configure,
  .vault-live-accordion__configure,
  .vault-live-code__configure,
  .vault-live-code__lang,
  .vault-live-tree__configure,
  .vault-live-compare__configure {
    margin-left: auto;
  }

  .vault-live-card__expand:hover,
  .vault-live-card__configure:hover,
  .vault-live-callout__configure:hover,
  .vault-live-dashboard__configure:hover,
  .vault-live-tabs__configure:hover,
  .vault-live-steps__configure:hover,
  .vault-live-accordion__configure:hover,
  .vault-live-code__configure:hover,
  .vault-live-code__lang:hover,
  .vault-live-tree__configure:hover,
  .vault-live-compare__configure:hover {
    color: rgb(var(--shell-muted, var(--color-surface-350, var(--color-surface-400))));
  }

  .vault-live-card__title,
  .vault-live-card__subtitle,
  .vault-live-card__body,
  .vault-live-dashboard__title,
  .vault-live-tabs__title,
  .vault-live-steps__title,
  .vault-live-accordion__title,
  .vault-live-code__title,
  .vault-live-tree__title,
  .vault-live-compare__title {
    outline: none;
    min-height: 1.25em;
    margin: 0;
  }

  .vault-live-card__title,
  .vault-live-dashboard__title,
  .vault-live-tabs__title,
  .vault-live-steps__title,
  .vault-live-accordion__title,
  .vault-live-code__title,
  .vault-live-tree__title,
  .vault-live-compare__title {
    font-size: 1rem;
    font-weight: 600;
    color: rgb(var(--shell-fg, var(--color-surface-50)));
  }

  .vault-live-card__subtitle {
    margin-top: 0.15rem;
    font-size: 0.8125rem;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
  }

  .vault-live-card__body {
    margin-top: 0.4rem;
    font-size: 0.875rem;
    color: rgb(var(--shell-fg, var(--color-surface-100)));
  }

  .vault-live-card__title:empty::before,
  .vault-live-card__subtitle:empty::before,
  .vault-live-card__body:empty::before,
  .vault-live-dashboard__title:empty::before,
  .vault-live-tabs__title:empty::before,
  .vault-live-steps__title:empty::before,
  .vault-live-accordion__title:empty::before,
  .vault-live-code__title:empty::before,
  .vault-live-tree__title:empty::before,
  .vault-live-compare__title:empty::before {
    content: attr(data-placeholder);
    color: rgb(var(--shell-muted, var(--color-surface-600)));
  }

  .vault-live-dashboard__head,
  .vault-live-tabs__head,
  .vault-live-steps__head,
  .vault-live-accordion__head,
  .vault-live-code__head,
  .vault-live-tree__head,
  .vault-live-compare__head {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 0.35rem;
  }

  .vault-live-dashboard__meta,
  .vault-live-tabs__meta,
  .vault-live-steps__meta,
  .vault-live-accordion__meta,
  .vault-live-code__meta,
  .vault-live-tree__meta,
  .vault-live-compare__meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .vault-live-dashboard__cols,
  .vault-live-tabs__strip,
  .vault-live-compare__modes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .vault-live-dashboard__col,
  .vault-live-tabs__tab,
  .vault-live-compare__mode {
    font-size: 0.625rem;
    letter-spacing: 0.02em;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    background: transparent;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.35);
    border-radius: 0.2rem;
    padding: 0.1rem 0.4rem;
    cursor: pointer;
  }

  .vault-live-dashboard__col[aria-pressed="true"],
  .vault-live-tabs__tab[aria-selected="true"],
  .vault-live-compare__mode[aria-pressed="true"] {
    color: rgb(var(--shell-fg, var(--color-surface-50)));
    border-color: rgb(var(--shell-border, var(--color-surface-300)) / 0.55);
  }

  .vault-live-dashboard__stage .liquid-dashboard,
  .vault-live-tabs__stage .liquid-tabs,
  .vault-live-steps__stage .liquid-steps,
  .vault-live-accordion__stage .liquid-accordion,
  .vault-live-code__stage .liquid-code,
  .vault-live-tree__stage .liquid-tree,
  .vault-live-compare__stage .liquid-compare {
    margin: 0 !important;
  }

  .vault-liquid-list__item--step {
    grid-template-columns: 1fr auto auto;
    grid-template-rows: auto auto;
  }

  .vault-liquid-list__item--step .vault-liquid-list__area {
    grid-column: 1 / -1;
  }

  .vault-liquid-list__check {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.6875rem;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
  }

  /* Quiet liquid list — compact until pencil */
  .vault-liquid-quiet-list {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.2rem 0 0.5rem;
    max-height: min(55vh, 28rem);
    overflow: auto;
  }

  .vault-liquid-quiet-list__row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2rem;
    padding: 0.28rem 0.2rem;
    border-radius: 0.35rem;
    transition: background-color 140ms ease;
  }

  .vault-liquid-quiet-list__row:hover {
    background: rgb(var(--color-surface-800) / 0.4);
  }

  .vault-liquid-quiet-list__leading {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
  }

  .vault-liquid-quiet-list__preview {
    appearance: none;
    flex: 1;
    min-width: 0;
    margin: 0;
    padding: 0.1rem 0;
    border: none;
    background: transparent;
    text-align: left;
    cursor: pointer;
    color: rgb(var(--shell-fg, var(--color-surface-100)));
  }

  .vault-liquid-quiet-list__preview-text {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.8125rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .vault-liquid-quiet-list__actions {
    display: inline-flex;
    align-items: center;
    gap: 0.1rem;
    flex-shrink: 0;
    opacity: 0.45;
    transition: opacity 120ms ease;
  }

  .vault-liquid-quiet-list__row:hover .vault-liquid-quiet-list__actions,
  .vault-liquid-quiet-list__actions:focus-within {
    opacity: 1;
  }

  .vault-liquid-quiet-list__icon {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border: none;
    border-radius: 0.3rem;
    background: transparent;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    cursor: pointer;
  }

  .vault-liquid-quiet-list__icon:hover:not(:disabled) {
    color: rgb(var(--shell-fg, var(--color-surface-100)));
    background: rgb(var(--color-surface-700) / 0.45);
  }

  .vault-liquid-quiet-list__icon:disabled {
    opacity: 0.3;
    cursor: default;
  }

  .vault-liquid-quiet-list__icon--danger:hover:not(:disabled) {
    color: rgb(var(--color-error-300, 252 165 165));
  }

  .vault-liquid-quiet-list__add {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    appearance: none;
    border: none;
    background: transparent;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    font-size: 0.75rem;
    padding: 0.4rem 0.2rem 0.2rem;
    cursor: pointer;
    align-self: flex-start;
  }

  .vault-liquid-quiet-list__add:hover {
    color: rgb(var(--shell-muted, var(--color-surface-200)));
  }

  .vault-liquid-quiet-toggle {
    appearance: none;
    position: relative;
    width: 1.7rem;
    height: 0.95rem;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: rgb(var(--color-surface-700) / 0.7);
    cursor: pointer;
    transition: background-color 140ms ease;
  }

  .vault-liquid-quiet-toggle--on {
    background: rgb(var(--color-primary-500, 99 102 241) / 0.55);
  }

  .vault-liquid-quiet-toggle__knob {
    position: absolute;
    top: 0.12rem;
    left: 0.12rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: rgb(var(--color-surface-200));
    transition: transform 140ms ease;
  }

  .vault-liquid-quiet-toggle--on .vault-liquid-quiet-toggle__knob {
    transform: translateX(0.72rem);
  }

  .vault-liquid-quiet-status {
    appearance: none;
    max-width: 5.5rem;
    padding: 0.15rem 0.35rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.28);
    border-radius: 0.3rem;
    background: transparent;
    color: rgb(var(--shell-muted, var(--color-surface-300)));
    font-size: 0.6875rem;
    cursor: pointer;
  }

  .vault-liquid-quiet-item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.35rem 0 0.5rem;
  }

  .vault-liquid-quiet-item__field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .vault-liquid-quiet-item__label {
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
  }

  .vault-liquid-quiet-item__input,
  .vault-liquid-quiet-item__area {
    width: 100%;
    min-width: 0;
    padding: 0.45rem 0.55rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.28);
    border-radius: 0.35rem;
    background: rgb(var(--color-surface-900) / 0.35);
    color: rgb(var(--shell-fg, var(--color-surface-50)));
    font-size: 0.875rem;
    font-family: inherit;
    outline: none;
  }

  .vault-liquid-quiet-item__input:focus,
  .vault-liquid-quiet-item__area:focus {
    border-color: rgb(var(--shell-border, var(--color-surface-400)) / 0.5);
  }

  .vault-liquid-quiet-item__area {
    resize: vertical;
    min-height: 7rem;
    line-height: 1.45;
  }

  .vault-live-chart__stage,
  .vault-live-report__stage,
  .vault-live-report__mount,
  .vault-live-slides__stage,
  .vault-live-slides__mount {
    width: 100%;
    min-width: 0;
  }

  .vault-liquid-source {
    padding: 0.25rem 0 0.5rem;
  }

  .vault-liquid-source__area {
    display: block;
    width: 100%;
    min-height: 12rem;
    padding: 0.55rem 0.65rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.3);
    border-radius: 0.25rem;
    background: rgb(var(--color-surface-900) / 0.45);
    color: rgb(var(--color-surface-100));
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    line-height: 1.45;
    resize: vertical;
  }

  .vault-liquid-builder-kind {
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
  }

  .vault-chart-fact__value--static {
    cursor: default;
    opacity: 0.75;
  }

  .vault-liquid-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 0.25rem 0 0.5rem;
    max-height: min(55vh, 28rem);
    overflow: auto;
  }

  .vault-liquid-list__item {
    display: grid;
    grid-template-columns: 1fr 1fr auto auto auto;
    gap: 0.4rem;
    align-items: center;
  }

  .vault-liquid-list__item--panel {
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
  }

  .vault-liquid-list__item--panel .vault-liquid-list__area {
    grid-column: 1 / -1;
  }

  .vault-liquid-list__field,
  .vault-liquid-list__select,
  .vault-liquid-list__area {
    width: 100%;
    min-width: 0;
    padding: 0.35rem 0.45rem;
    border: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.3);
    border-radius: 0.25rem;
    background: rgb(var(--color-surface-900) / 0.45);
    color: rgb(var(--color-surface-50));
    font-size: 0.8125rem;
  }

  .vault-liquid-list__field--delta {
    max-width: 5.5rem;
  }

  .vault-liquid-list__area {
    resize: vertical;
    min-height: 3.5rem;
    font-family: inherit;
  }

  .vault-liquid-list__remove {
    appearance: none;
    border: none;
    background: transparent;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
    padding: 0.25rem;
    cursor: pointer;
  }

  .vault-liquid-list__remove:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .vault-liquid-list__add {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    appearance: none;
    border: none;
    background: transparent;
    color: rgb(var(--shell-muted, var(--color-surface-400)));
    font-size: 0.75rem;
    padding: 0.25rem 0;
    cursor: pointer;
    align-self: flex-start;
  }

  .vault-liquid-points {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .vault-liquid-points__row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 0.35rem;
    align-items: center;
  }

  .vault-note-status {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-shrink: 0;
    min-height: 1.5rem;
    padding: 0.2rem 1rem 0.35rem;
    border-top: 1px solid rgb(var(--shell-border, var(--color-surface-500)) / 0.18);
    background: transparent;
    color: rgb(var(--shell-muted, var(--color-surface-500)));
    font-size: 0.625rem;
    letter-spacing: 0.01em;
  }

  .vault-note-status-line {
    margin: 0;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    overflow: hidden;
    white-space: nowrap;
    opacity: 0.72;
  }

  .vault-note-status-sep {
    opacity: 0.45;
  }

  .vault-note-status-tags {
    min-width: 0;
  }

  .vault-note-status-hints {
    margin: 0;
    flex-shrink: 0;
    display: none;
    align-items: center;
    gap: 0.35rem;
    opacity: 0;
    transition: opacity 140ms ease;
  }

  @media (min-width: 640px) {
    .vault-note-status-hints {
      display: inline-flex;
    }

    .vault-note-status:hover .vault-note-status-hints,
    .vault-note-status:focus-within .vault-note-status-hints {
      opacity: 0.7;
    }
  }

  .vault-note-chat-fab-root {
    pointer-events: none;
    position: absolute;
    right: 1rem;
    bottom: 2.75rem;
    z-index: 20;
  }

  .vault-note-chat-fab {
    pointer-events: auto;
    display: flex;
    height: 2.5rem;
    width: 2.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgb(var(--color-primary-500) / 0.25);
    background: rgb(var(--color-primary-600) / 0.88);
    color: rgb(var(--color-surface-50));
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.08);
    transition:
      background 140ms ease,
      transform 140ms ease;
  }

  .vault-note-chat-fab:hover {
    background: rgb(var(--color-primary-500));
  }

  .vault-note-chat-fab:active {
    transform: scale(0.96);
  }

  .vault-note-chat-fab:disabled {
    opacity: 0.5;
  }

  .vault-note-chat-session-backdrop {
    @apply fixed inset-0 z-[84];
  }

  /* HTML presentation overlays (panel / fullscreen) — theme-aware chrome */
  .artifact-chrome-backdrop,
  .artifact-shell-backdrop {
    position: fixed;
    inset: 0;
    background: rgb(var(--color-surface-950) / 0.52);
    backdrop-filter: blur(14px) saturate(1.08);
  }

  html:not(.dark) .artifact-chrome-backdrop,
  html:not(.dark) .artifact-shell-backdrop {
    background: rgb(var(--color-surface-200) / 0.72);
  }

  .artifact-chrome-stage,
  .artifact-shell-surface {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-surface-600) 45%, transparent);
    background: transparent;
    box-shadow:
      0 1px 0 color-mix(in srgb, var(--color-surface-100) 8%, transparent) inset,
      0 32px 80px rgb(0 0 0 / 0.35);
  }

  html:not(.dark) .artifact-chrome-stage,
  html:not(.dark) .artifact-shell-surface {
    border-color: rgb(var(--color-surface-300) / 0.85);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.65) inset,
      0 24px 64px rgb(0 0 0 / 0.12);
  }

  .artifact-chrome {
    display: flex;
    flex-direction: column;
    min-height: 0;
    height: 100%;
  }

  .artifact-chrome-bar {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    height: 3rem;
    padding: 0 0.875rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-surface-600) 40%, transparent);
    background: rgb(var(--color-surface-900));
  }

  html:not(.dark) .artifact-chrome-bar {
    background: rgb(var(--color-surface-100));
    border-bottom-color: rgb(var(--color-surface-300) / 0.85);
  }

  .artifact-chrome-title {
    margin: 0;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgb(var(--color-surface-100));
  }

  .artifact-chrome-title-wrap {
    display: flex;
    min-width: 0;
    flex: 1 1 auto;
    flex-direction: column;
    gap: 0.125rem;
  }

  .artifact-chrome-status {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.625rem;
    font-weight: 500;
    color: rgb(var(--color-primary-300));
  }

  html:not(.dark) .artifact-chrome-status {
    color: rgb(var(--color-primary-700));
  }

  html:not(.dark) .artifact-chrome-title {
    color: rgb(var(--color-surface-900));
  }

  .artifact-chrome-actions {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 0.375rem;
  }

  .artifact-chrome-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid color-mix(in srgb, var(--color-surface-500) 65%, transparent);
    border-radius: 999px;
    padding: 0.32rem 0.625rem;
    font-size: 0.6875rem;
    font-weight: 600;
    color: rgb(var(--color-surface-100));
    background: color-mix(in srgb, var(--color-surface-700) 72%, var(--color-surface-900));
    cursor: pointer;
    transition:
      background 140ms ease,
      border-color 140ms ease,
      color 140ms ease;
  }

  html:not(.dark) .artifact-chrome-btn {
    color: rgb(var(--color-surface-800));
    background: rgb(var(--color-surface-50));
    border-color: rgb(var(--color-surface-400) / 0.95);
  }

  .artifact-chrome-btn:hover {
    color: rgb(var(--color-surface-50));
    border-color: color-mix(in srgb, var(--color-primary-400) 45%, var(--color-surface-500));
    background: color-mix(in srgb, var(--color-primary-500) 18%, var(--color-surface-800));
  }

  html:not(.dark) .artifact-chrome-btn:hover {
    color: rgb(var(--color-surface-900));
    background: rgb(var(--color-surface-200));
  }

  .artifact-chrome-btn-secondary {
    color: rgb(var(--color-surface-50));
    border-color: color-mix(in srgb, var(--color-primary-400) 55%, transparent);
    background: rgb(var(--color-primary-600));
  }

  html:not(.dark) .artifact-chrome-btn-secondary {
    color: rgb(var(--color-surface-50));
    background: rgb(var(--color-primary-600));
    border-color: rgb(var(--color-primary-500) / 0.65);
  }

  .artifact-chrome-btn-secondary:hover {
    background: rgb(var(--color-primary-500));
  }

  html:not(.dark) .artifact-chrome-btn-secondary:hover {
    background: rgb(var(--color-primary-500));
  }

  .artifact-chrome-body {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
    padding: 0.625rem 0.75rem 0.75rem;
    background: transparent;
  }

  .artifact-chrome-bar-leading-close {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.5rem;
  }

  .artifact-chrome-bar-leading-close .artifact-chrome-title {
    grid-column: 2;
  }

  .artifact-chrome-bar-leading-close .artifact-chrome-actions {
    grid-column: 3;
    justify-self: end;
  }

  .artifact-chrome-btn-close-leading {
    grid-column: 1;
    justify-self: start;
  }

  @media (max-width: 640px) {
    .artifact-chrome-bar {
      padding-top: max(0.5rem, env(safe-area-inset-top, 0px));
      padding-right: max(0.875rem, env(safe-area-inset-right, 0px));
      padding-left: max(0.875rem, env(safe-area-inset-left, 0px));
      min-height: calc(3rem + env(safe-area-inset-top, 0px));
      height: auto;
    }

    .artifact-chrome-btn {
      min-height: 2.75rem;
      padding: 0.5rem 0.8rem;
      font-size: 0.75rem;
    }

    .artifact-chrome-body {
      padding-bottom: max(0.75rem, env(safe-area-inset-bottom, 0px));
    }

    .artifact-fullscreen-backdrop {
      padding: 0;
    }

    .artifact-fullscreen-stage {
      width: 100%;
      max-height: 100dvh;
    }
  }

  .artifact-shell-toolbar {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-surface-600) 40%, transparent);
    background: rgb(var(--color-surface-950) / 0.72);
    backdrop-filter: blur(10px) saturate(1.1);
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.18);
  }

  html:not(.dark) .artifact-shell-toolbar {
    background: rgb(var(--color-surface-50) / 0.9);
    border-color: rgb(var(--color-surface-300) / 0.85);
    box-shadow: 0 8px 20px rgb(0 0 0 / 0.08);
  }

  .artifact-shell-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: 0;
    border-radius: 999px;
    color: rgb(var(--color-surface-300));
    background: transparent;
    cursor: pointer;
    transition:
      color 140ms ease,
      background 140ms ease;
  }

  .artifact-shell-icon-btn:hover {
    color: rgb(var(--color-surface-100));
    background: color-mix(in srgb, var(--color-surface-700) 35%, transparent);
  }

  .vault-note-chat-session-menu {
    @apply z-[86] flex max-h-[min(420px,60vh)] flex-col overflow-hidden rounded-2xl border border-surface-500/45 bg-surface-900 shadow-2xl;
  }

  .vault-note-chat-session-menu-fab {
    @apply pointer-events-auto absolute bottom-[4.25rem] right-0 w-[18rem];
  }

  .vault-note-chat-session-menu-workshop {
    @apply absolute right-0 top-[calc(100%+0.35rem)] w-[17rem];
  }

  .vault-note-chat-session-menu-heading {
    @apply border-b border-surface-500/35 px-3 py-2 text-[11px] font-semibold uppercase tracking-wide text-surface-400;
  }

  .vault-note-chat-session-menu-subheading {
    @apply px-3 pb-1 pt-2 text-[10px] font-semibold uppercase tracking-wide text-surface-500;
  }

  .vault-note-chat-session-list {
    @apply min-h-0 flex-1 overflow-y-auto px-1.5 pb-2;
  }

  .vault-note-chat-session-item {
    @apply flex w-full items-center gap-2 rounded-lg px-2.5 py-2 text-sm text-surface-200 transition hover:bg-surface-800/80;
  }

  .vault-note-chat-session-item-new {
    @apply mx-1.5 my-2 border border-primary-500/25 bg-primary-500/10 text-primary-100 hover:bg-primary-500/15;
  }

  .vault-note-chat-session-item-active {
    @apply bg-surface-800/90 ring-1 ring-primary-500/30;
  }

  .vault-note-chat-session-empty {
    @apply px-3 pb-3 text-xs text-surface-500;
  }

  .vault-find-bar {
    @apply pointer-events-auto absolute right-3 top-2.5 z-[90] flex max-w-[min(100%-1.5rem,24rem)] flex-col gap-1 rounded-md border border-surface-500/35 py-0.5 pl-2 pr-0.5 shadow-lg;
    background-color: rgb(var(--color-surface-900) / 0.94);
    backdrop-filter: blur(8px);
  }

  .vault-find-bar--replace {
    @apply max-w-[min(100%-1.5rem,26rem)];
  }

  .vault-find-bar-row {
    @apply flex items-center;
  }

  .vault-find-bar-row--replace {
    @apply border-t border-surface-500/25 pt-0.5;
  }

  .vault-find-input {
    @apply min-w-[6.5rem] flex-1 border-0 bg-transparent py-1 text-[13px] text-surface-100 placeholder:text-surface-500 focus:outline-none focus:ring-0;
  }

  .vault-find-divider {
    @apply mx-0.5 h-3.5 w-px shrink-0 bg-surface-500/35;
  }

  .vault-find-status {
    @apply shrink-0 px-1 text-[11px] tabular-nums text-surface-500;
    min-width: 3.25rem;
    text-align: center;
  }

  .vault-find-nav {
    @apply flex shrink-0 items-center;
  }

  .vault-find-btn {
    @apply inline-flex h-6 w-6 items-center justify-center rounded text-surface-400 transition hover:bg-surface-800/80 hover:text-surface-100 disabled:opacity-30;
  }

  .vault-find-btn--active {
    @apply bg-primary-500/20 text-primary-100;
  }

  .vault-find-text-btn {
    @apply shrink-0 rounded px-1.5 py-0.5 text-[11px] font-medium text-surface-300 transition hover:bg-surface-800/80 hover:text-surface-50 disabled:opacity-30;
  }

  /* Find-in-note: translucent highlighter wash (not opaque bars) */
  ::highlight(medousa-vault-find) {
    background-color: rgb(250 204 21 / 0.38);
    color: inherit;
  }

  ::highlight(medousa-vault-find-active) {
    background-color: rgb(250 204 21 / 0.62);
    color: inherit;
  }

  html:not(.dark) ::highlight(medousa-vault-find) {
    background-color: rgb(254 240 138 / 0.72);
    color: rgb(66 32 6);
  }

  html:not(.dark) ::highlight(medousa-vault-find-active) {
    background-color: rgb(253 224 71 / 0.92);
    color: rgb(66 32 6);
  }

  .vault-find-editor-shell {
    @apply relative min-h-0;
  }

  .vault-find-editor-backdrop {
    @apply pointer-events-none absolute inset-0 z-0 overflow-auto whitespace-pre-wrap break-words text-surface-100;
  }

  .vault-find-editor-backdrop mark.vault-find-mark {
    @apply rounded-[2px];
    color: inherit;
    background-color: rgb(250 204 21 / 0.38);
  }

  .vault-find-editor-backdrop mark.vault-find-mark-active {
    color: inherit;
    background-color: rgb(250 204 21 / 0.62);
    box-shadow: inset 0 -1.5px 0 0 rgb(234 179 8 / 0.85);
  }

  html:not(.dark) .vault-find-editor-backdrop mark.vault-find-mark {
    color: rgb(66 32 6);
    background-color: rgb(254 240 138 / 0.72);
  }

  html:not(.dark) .vault-find-editor-backdrop mark.vault-find-mark-active {
    color: rgb(66 32 6);
    background-color: rgb(253 224 71 / 0.92);
    box-shadow: inset 0 -1.5px 0 0 rgb(202 138 4 / 0.7);
  }

  .vault-find-editor-input--active {
    color: transparent !important;
    caret-color: rgb(var(--color-surface-100));
    background-color: transparent !important;
  }

  .vault-find-editor-input--active::selection {
    background-color: rgb(250 204 21 / 0.45);
    color: transparent;
  }

  html:not(.dark) .vault-find-editor-input--active::selection {
    background-color: rgb(253 224 71 / 0.55);
  }

  .vault-find-mark {
    @apply rounded-sm;
    color: inherit;
    background-color: rgb(250 204 21 / 0.38);
  }

  .vault-find-mark-active {
    color: inherit;
    background-color: rgb(250 204 21 / 0.62);
    box-shadow: inset 0 -1.5px 0 0 rgb(234 179 8 / 0.85);
  }

  html:not(.dark) .vault-find-mark {
    color: rgb(66 32 6);
    background-color: rgb(254 240 138 / 0.72);
  }

  html:not(.dark) .vault-find-mark-active {
    color: rgb(66 32 6);
    background-color: rgb(253 224 71 / 0.92);
    box-shadow: inset 0 -1.5px 0 0 rgb(202 138 4 / 0.7);
  }

  .profiles-panel {
    @apply min-h-0;
    background-color: rgb(var(--color-surface-950));
  }

  .profiles-panel-embedded {
    @apply min-h-0;
  }

  .profiles-teach-dock {
    @apply shrink-0 border-t border-surface-500/35 px-4 py-3;
    background-color: rgb(var(--color-surface-950) / 0.92);
    backdrop-filter: blur(8px);
  }

  .profiles-quick-chip {
    @apply inline-flex items-center gap-1.5 rounded-full border border-surface-500/40 bg-surface-900/50 px-3 py-1.5 text-xs text-surface-300 transition hover:border-primary-400/40 hover:text-surface-100 disabled:opacity-50;
  }

  .profiles-field-view {
    @apply relative flex h-full min-h-0 flex-col;
  }

  .profiles-field-whisper {
    @apply pointer-events-none absolute left-4 top-3 z-10 text-[11px] text-surface-500;
  }

  .profiles-field-viewport {
    @apply relative h-full min-h-0 flex-1 cursor-grab overflow-hidden;
    background:
      radial-gradient(ellipse 80% 60% at 50% 45%, rgb(var(--color-primary-500) / 0.06), transparent 70%),
      rgb(var(--color-surface-950));
  }

  .profiles-field-viewport-dragging {
    @apply cursor-grabbing;
  }

  .profiles-field-loading {
    @apply flex h-full items-center justify-center text-sm text-surface-500;
  }

  .profiles-field-svg {
    @apply absolute left-0 top-0 touch-none;
  }

  .profiles-field-labels {
    @apply pointer-events-none absolute left-0 top-0;
  }

  .profiles-field-label {
    @apply pointer-events-auto absolute -translate-x-1/2 -translate-y-1/2 text-center;
  }

  .profiles-field-label-center {
    @apply max-w-[10rem];
  }

  .profiles-field-label-name {
    @apply text-sm font-semibold text-surface-50 drop-shadow-sm;
  }

  .profiles-field-label-person {
    @apply rounded-full border border-surface-500/30 px-2.5 py-1 text-xs font-medium text-surface-100 backdrop-blur-sm transition hover:border-primary-400/50;
    background-color: rgb(var(--color-surface-950) / 0.7);
  }

  .profiles-field-label-active {
    @apply border-primary-400/60 bg-primary-500/20 text-primary-100;
  }

  .profiles-field-blob-selected {
    filter: brightness(1.15);
  }

  .profiles-focus-card {
    @apply pointer-events-none absolute inset-x-0 bottom-4 z-20 flex justify-center px-4;
  }

  .profiles-focus-card-inner {
    @apply pointer-events-auto w-full max-w-md rounded-2xl border border-surface-500/40 px-4 py-4 shadow-xl;
    background-color: rgb(var(--color-surface-900) / 0.94);
    backdrop-filter: blur(12px);
  }

  .profiles-focus-close {
    @apply absolute right-3 top-3;
  }

  .profiles-focus-kicker {
    @apply text-[11px] font-medium uppercase tracking-[0.12em] text-primary-300/80;
  }

  .profiles-focus-title {
    @apply mt-1 text-lg font-semibold text-surface-50;
  }

  .profiles-focus-voice {
    @apply mt-2 text-sm leading-relaxed text-surface-300;
  }

  .profiles-focus-actions {
    @apply mt-4 flex flex-wrap gap-2;
  }
}
