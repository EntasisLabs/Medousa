/* Chart series tokens — map onto Skeleton palette so theme switches work. */
@layer base {
  html {
    --chart-1: var(--color-primary-400);
    --chart-2: var(--color-tertiary-400);
    --chart-3: var(--color-secondary-400);
    --chart-4: var(--color-success-400);
    --chart-5: var(--color-warning-400);
  }
}
