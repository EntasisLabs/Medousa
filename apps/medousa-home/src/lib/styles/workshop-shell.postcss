@layer components {
  .workshop-app-root {
    background-color: rgb(var(--shell-canvas-bg));
  }

  /* Primary shell regions */
  .workshop-nav {
    border-right: 1px solid rgb(var(--shell-border) / var(--shell-border-strong));
    background-color: rgb(var(--shell-chrome-bg));
    box-shadow: var(--shell-chrome-shadow);
  }

  .workshop-main {
    background-color: rgb(var(--shell-canvas-bg));
  }

  .workshop-rail {
    border-left: 2px solid rgb(var(--shell-border) / var(--shell-border-strong));
    background-color: rgb(var(--shell-chrome-bg));
    box-shadow: var(--shell-rail-shadow);
  }

  .workshop-status {
    border-top: 1px solid rgb(var(--shell-border) / var(--shell-rail-edge));
    background-color: rgb(var(--shell-chrome-bg) / 0.96);
    color: rgb(var(--shell-whisper));
  }

  .workshop-header {
    border-bottom: 1px solid rgb(var(--shell-border) / var(--shell-border-soft));
    background-color: rgb(var(--shell-header-bg) / 0.88);
    @apply px-4 py-2.5;
  }

  .workshop-header-line {
    @apply text-xs;
    color: rgb(var(--shell-whisper));
  }

  .workshop-list-pane {
    background-color: rgb(var(--shell-pane-bg) / 0.78);
  }

  .workshop-detail-pane {
    background-color: rgb(var(--shell-pane-muted-bg) / 0.42);
  }

  .workshop-icon-rail {
    @apply flex h-full w-full min-h-0 shrink-0 flex-col items-center py-1;
    border-right: 1px solid rgb(var(--shell-border) / var(--shell-rail-edge));
    background-color: rgb(var(--shell-chrome-bg));
    box-shadow: var(--shell-nav-inset), var(--shell-nav-shadow);
  }

  .workshop-icon-rail-expanded {
    @apply items-stretch px-1.5 pt-0.5;
  }

  .workshop-icon-rail-view {
    @apply px-[0.35rem];
  }

  .workshop-icon-rail-expanded .workshop-icon-rail-items {
    @apply items-stretch;
  }

  .workshop-icon-rail-expanded .workshop-rail-tier-divider {
    @apply w-auto mx-2;
  }

  .workshop-rail-btn {
    @apply flex h-9 w-9 items-center justify-center rounded-md transition;
    color: rgb(var(--shell-icon));
  }

  .workshop-icon-rail-expanded .workshop-rail-btn {
    @apply h-9 w-full justify-start gap-2.5 px-2;
  }

  .workshop-icon-rail-expanded .workshop-rail-btn-tier-utility {
    @apply h-8 w-full;
  }

  .workshop-rail-btn-icon {
    @apply relative inline-flex h-[1.125rem] w-[1.125rem] shrink-0 items-center justify-center;
  }

  .workshop-rail-workshop-btn .workshop-rail-btn-icon {
    @apply h-5 w-5;
  }

  .workshop-rail-btn-label {
    @apply min-w-0 flex-1 truncate text-left text-[12px] font-medium tracking-[-0.01em];
    color: inherit;
  }

  /*
   * Life-orbit tree: one continuous list (Cursor Agents).
   * Parents ≈ children in type size; selection is a quiet surface pill, not purple chrome.
   */
  .workshop-rail-tree {
    gap: 0.45rem;
    padding: 0 0.15rem 0.35rem 0.2rem;
  }

  .workshop-rail-tree-jobs {
    gap: 0.55rem;
  }

  .workshop-rail-primary,
  .workshop-rail-custom {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: 1px;
  }

  /* Soft mode break — talk vs do — no taxonomy label. */
  .workshop-rail-breath {
    height: 0.55rem;
    margin: 0.1rem 0.55rem 0.05rem;
    border-top: 1px solid rgb(var(--shell-border) / 0.14);
  }

  .workshop-rail-dest-hero .workshop-rail-dest-btn {
    min-height: 2.15rem;
  }

  .workshop-icon-rail-expanded .workshop-rail-tree .workshop-rail-dest-hero .workshop-rail-dest-btn {
    height: 2.15rem;
  }

  .workshop-rail-dest-hero .workshop-rail-btn-label {
    font-size: 0.9375rem;
    font-weight: 650;
    letter-spacing: -0.025em;
  }

  .workshop-rail-dest-hero .workshop-rail-btn-icon {
    color: rgb(var(--color-surface-50) / 0.96);
  }

  .workshop-rail-dest-hero {
    margin-bottom: 0.15rem;
  }

  .workshop-rail-library-btn .workshop-rail-btn-label {
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .workshop-rail-dock-you {
    width: 100%;
  }

  /* Bottom chrome — same inset / row metrics as the life-orbit tree. */
  .workshop-rail-dock {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-top: auto;
    padding: 0.45rem 0.35rem 0.35rem 0.2rem;
    border-top: 1px solid rgb(var(--shell-border) / 0.16);
  }

  .workshop-icon-rail-expanded .workshop-rail-dock .workshop-rail-dock-btn,
  .workshop-icon-rail-expanded .workshop-rail-tree .workshop-rail-tree-row {
    height: 1.75rem;
    width: 100%;
    justify-content: flex-start;
    gap: 0.65rem;
    padding-inline: 0.65rem 0.5rem;
    border-radius: 0.4rem;
  }

  .workshop-icon-rail-expanded .workshop-rail-dock .workshop-rail-dock-btn .workshop-rail-btn-icon,
  .workshop-icon-rail-expanded .workshop-rail-tree .workshop-rail-tree-row .workshop-rail-btn-icon {
    color: rgb(var(--color-surface-400));
  }

  .workshop-icon-rail-expanded .workshop-rail-dock .workshop-rail-dock-btn .workshop-rail-btn-label,
  .workshop-icon-rail-expanded .workshop-rail-tree .workshop-rail-tree-row .workshop-rail-btn-label {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.012em;
    color: rgb(var(--color-surface-200) / 0.96);
  }

  .workshop-icon-rail-expanded
    .workshop-rail-dock
    .workshop-rail-dock-btn.workshop-rail-btn-active-quiet
    .workshop-rail-btn-label,
  .workshop-icon-rail-expanded
    .workshop-rail-tree
    .workshop-rail-tree-row.workshop-rail-btn-active-quiet
    .workshop-rail-btn-label {
    color: rgb(var(--color-surface-50));
  }

  .workshop-icon-rail-expanded .workshop-rail-dock .workshop-rail-workshop-btn {
    margin-top: 0;
  }

  .workshop-rail-dest {
    display: flex;
    width: 100%;
    flex-direction: column;
  }

  .workshop-rail-dest-has-nest {
    margin-bottom: 0.2rem;
  }

  .workshop-rail-dest-row {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 0.15rem;
    padding-inline: 0.25rem 0.15rem;
  }

  .workshop-rail-dest-btn {
    min-width: 0;
    flex: 1;
  }

  .workshop-icon-rail-expanded .workshop-rail-tree .workshop-rail-dest-btn {
    height: 1.75rem;
    gap: 0.45rem;
    padding-inline: 0.3rem 0.45rem;
    border-radius: 0.4rem;
  }

  .workshop-rail-dest-twist,
  .workshop-rail-dest-twist-btn {
    display: inline-flex;
    width: 1rem;
    height: 1.35rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
  }

  .workshop-rail-dest-twist-btn {
    border-radius: 0.25rem;
    color: rgb(var(--color-surface-500));
  }

  .workshop-rail-dest-twist-btn:hover {
    color: rgb(var(--color-surface-200));
    background-color: rgb(var(--color-surface-800) / 0.45);
  }

  .workshop-rail-dest-chevron {
    display: block;
    transition: transform 120ms ease;
  }

  .workshop-rail-dest-chevron-open {
    transform: rotate(90deg);
  }

  .workshop-icon-rail-expanded .workshop-rail-tree .workshop-rail-dest-btn .workshop-rail-btn-icon {
    width: 0.875rem;
    height: 0.875rem;
    color: rgb(var(--color-surface-400));
  }

  .workshop-icon-rail-expanded .workshop-rail-tree .workshop-rail-dest-btn .workshop-rail-btn-label {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.012em;
    color: rgb(var(--color-surface-200) / 0.96);
  }

  .workshop-icon-rail-expanded
    .workshop-rail-tree
    .workshop-rail-dest-btn.workshop-rail-btn-active-quiet
    .workshop-rail-btn-label {
    color: rgb(var(--color-surface-50));
  }

  .workshop-icon-rail-expanded
    .workshop-rail-tree
    .workshop-rail-dest-btn.workshop-rail-btn-active-quiet
    .workshop-rail-btn-icon {
    color: rgb(var(--color-surface-100));
  }

  /* Leaf owns selection — parent stays present but not “selected chrome”. */
  .workshop-rail-dest-btn-dimmed.workshop-rail-btn-active-quiet {
    background-color: transparent !important;
    box-shadow: none !important;
  }

  .workshop-rail-dest-btn-dimmed .workshop-rail-btn-label {
    color: rgb(var(--color-surface-300) / 0.92) !important;
  }

  .workshop-rail-btn-active-quiet {
    background-color: rgb(var(--color-surface-800) / 0.55);
    color: rgb(var(--color-surface-50));
  }

  .workshop-rail-btn-active-quiet:hover {
    background-color: rgb(var(--color-surface-800) / 0.7);
  }

  .workshop-rail-nest {
    display: flex;
    list-style: none;
    flex-direction: column;
    gap: 1px;
    margin: 0;
    /* Align under parent label column. */
    padding: 0 0.35rem 0.1rem 2.45rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .workshop-rail-dest-chevron {
      transition: none;
    }
  }

  .workshop-rail-nest-btn {
    display: flex;
    width: 100%;
    min-height: 1.65rem;
    align-items: center;
    gap: 0.4rem;
    border-radius: 0.4rem;
    padding: 0.2rem 0.4rem 0.2rem 0.45rem;
    text-align: left;
    transition:
      color 110ms ease,
      background 110ms ease;
  }

  .workshop-rail-nest-btn:hover {
    background-color: rgb(var(--color-surface-800) / 0.35);
  }

  .workshop-rail-nest-btn:focus-visible {
    outline: none;
    box-shadow: inset 0 0 0 1px rgb(var(--color-surface-500) / 0.35);
  }

  .workshop-rail-nest-btn-active {
    background-color: rgb(var(--color-surface-800) / 0.72);
  }

  .workshop-rail-nest-btn-active:hover {
    background-color: rgb(var(--color-surface-800) / 0.82);
  }

  .workshop-rail-nest-dot {
    width: 0.35rem;
    height: 0.35rem;
    flex-shrink: 0;
    border-radius: 999px;
    background-color: rgb(234 179 8 / 0.92);
  }

  .workshop-rail-nest-icon {
    display: inline-flex;
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    color: rgb(var(--color-surface-500));
  }

  .workshop-rail-nest-btn:hover .workshop-rail-nest-icon {
    color: rgb(var(--color-surface-300));
  }

  .workshop-rail-nest-btn-active .workshop-rail-nest-icon {
    color: rgb(var(--color-surface-200));
  }

  .workshop-rail-nest-label {
    min-width: 0;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.8125rem;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.011em;
    color: rgb(var(--color-surface-300) / 0.9);
  }

  .workshop-rail-nest-btn:hover .workshop-rail-nest-label {
    color: rgb(var(--color-surface-100) / 0.92);
  }

  .workshop-rail-nest-btn-active .workshop-rail-nest-label {
    color: rgb(var(--color-surface-50));
  }

  .workshop-rail-nest-btn-accent .workshop-rail-nest-label {
    color: rgb(var(--color-surface-200));
  }

  .workshop-rail-nest-meta {
    max-width: 2.5rem;
    flex-shrink: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    font-variant-numeric: tabular-nums;
    color: rgb(var(--color-surface-500));
  }

  .workshop-rail-nest-btn-active .workshop-rail-nest-meta {
    color: rgb(var(--color-surface-400));
  }

  .workshop-rail-nest-more {
    display: block;
    width: 100%;
    border-radius: 0.4rem;
    padding: 0.15rem 0.45rem 0.25rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: rgb(var(--color-surface-500));
    transition: color 110ms ease;
  }

  .workshop-rail-nest-more:hover {
    color: rgb(var(--color-surface-200));
  }

  /* Chrome control that owns the rail — sits under the workshop mark, above destinations. */
  .workshop-rail-nav-toggle {
    @apply mb-2.5;
    color: rgb(var(--shell-icon) / 0.62);
  }

  .workshop-rail-nav-toggle:hover {
    color: rgb(var(--shell-icon-hover) / 0.9);
  }

  .workshop-icon-rail-expanded .workshop-rail-nav-toggle {
    @apply mb-3;
  }

  .workshop-icon-rail:not(.workshop-icon-rail-expanded) .workshop-rail-nav-toggle {
    @apply mb-3;
  }

  .workshop-rail-btn:hover {
    background-color: rgb(var(--shell-pane-muted-bg) / 0.5);
    color: rgb(var(--shell-icon-hover));
  }

  .workshop-rail-btn:focus-visible {
    outline: none;
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.35);
  }

  .workshop-rail-workshop-btn {
    @apply text-[10px] font-semibold text-surface-50 ring-1 ring-inset ring-primary-500/40;
    background-color: rgb(var(--color-primary-500) / 0.22);
  }

  .workshop-rail-workshop-btn:hover {
    @apply text-surface-50;
    background-color: rgb(var(--color-primary-500) / 0.32);
  }

  .workshop-rail-workshop-btn[style*="--workshop-brand"] {
    background-color: color-mix(in srgb, var(--workshop-brand) 24%, transparent);
    --tw-ring-color: color-mix(in srgb, var(--workshop-brand) 42%, transparent);
  }

  .workshop-rail-workshop-btn[style*="--workshop-brand"]:hover {
    background-color: color-mix(in srgb, var(--workshop-brand) 34%, transparent);
  }

  .workshop-rail-workshop-monogram {
    @apply block max-w-[2ch] truncate text-center tracking-tight;
  }

  .workshop-rail-btn-active {
    background-color: rgb(var(--color-primary-500) / 0.28);
    color: rgb(var(--shell-icon-active));
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.1),
      inset 0 -1px 0 rgb(0 0 0 / 0.18);
  }

  .workshop-rail-btn-active:hover {
    background-color: rgb(var(--color-primary-500) / 0.34);
    color: rgb(var(--shell-icon-active));
  }

  .workshop-rail-btn-active:focus-visible {
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.1),
      inset 0 -1px 0 rgb(0 0 0 / 0.18),
      inset 0 0 0 1px rgb(var(--color-primary-500) / 0.35);
  }

  .workshop-rail-tier-divider {
    @apply my-2.5 h-px w-7 shrink-0;
    background-color: rgb(var(--shell-border) / 0.32);
  }

  .workshop-rail-btn-tier-life {
    color: rgb(var(--shell-icon-hover) / 0.9);
  }

  .workshop-rail-btn-tier-utility {
    @apply h-8 w-8;
    color: rgb(var(--shell-icon) / 0.78);
  }

  .workshop-rail-btn-tier-utility:hover {
    color: rgb(var(--shell-icon-hover) / 0.95);
  }

  .workshop-rail-badge {
    @apply pointer-events-none absolute -right-0.5 -top-0.5 h-2 w-2 rounded-full bg-primary-400;
    box-shadow: 0 0 0 2px rgb(var(--shell-chrome-bg));
  }

  .workshop-rail-count-badge {
    @apply pointer-events-none absolute -right-1 -top-1 flex h-4 min-w-4 items-center justify-center rounded-full bg-primary-500 px-1 text-[9px] font-bold leading-none text-primary-50;
    box-shadow: 0 0 0 2px rgb(var(--shell-chrome-bg));
  }

  .workshop-rail-feed-badge {
    @apply pointer-events-none absolute -bottom-0.5 -right-0.5 h-1.5 w-1.5 rounded-full;
    box-shadow: 0 0 0 2px rgb(var(--shell-chrome-bg));
  }

  .workshop-rail-feed-badge-live {
    @apply bg-success-400;
  }

  .workshop-rail-feed-badge-stale {
    @apply bg-warning-400;
  }

  /* Vault paper sits on canvas */
  .vault-editor-textarea {
    background-color: rgb(var(--shell-canvas-bg)) !important;
  }

  .vault-markdown-preview {
    background-color: rgb(var(--shell-pane-bg) / 0.55);
  }

  .vault-editor-header {
    border-bottom-color: rgb(var(--shell-border) / var(--shell-border-soft));
    background-color: rgb(var(--shell-header-bg) / 0.55);
  }

  /* Light shell — forms / cards follow pane paper, not washed chrome */
  html:not(.dark) .workshop-inset {
    border-color: rgb(var(--shell-border) / var(--shell-border-soft));
    background-color: rgb(var(--shell-pane-bg));
  }

  html:not(.dark) .workshop-tabs {
    border-color: rgb(var(--shell-border) / var(--shell-border-soft));
  }

  html:not(.dark) .workshop-kanban-card {
    border-color: rgb(var(--shell-border) / var(--shell-border-soft));
    background-color: rgb(var(--shell-pane-bg));
  }

  html:not(.dark) .workshop-kanban-card:hover {
    background-color: rgb(var(--shell-pane-muted-bg) / 0.85);
  }

  html:not(.dark) .card {
    border-color: rgb(var(--shell-border) / var(--shell-border-soft));
    background-color: rgb(var(--shell-pane-bg));
  }

  html:not(.dark) :is(.input, .textarea, .select) {
    border-color: rgb(var(--shell-border) / var(--shell-border-strong));
    background-color: rgb(var(--shell-pane-bg));
    color: rgb(var(--color-surface-50));
  }

  html:not(.dark) :is(.input, .textarea, .select)::placeholder {
    color: rgb(var(--color-surface-400));
  }

  html:not(.dark) .composer-bar {
    border-color: rgb(var(--shell-border) / var(--shell-border-strong));
    background-color: rgb(var(--shell-pane-bg));
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.85),
      0 1px 2px rgb(0 0 0 / 0.04);
  }

  html:not(.dark) .composer-bar-mobile {
    border-color: rgb(var(--shell-border) / var(--shell-border-strong));
    background-color: rgb(var(--shell-pane-bg));
  }

  html:not(.dark) .theme-option {
    border-color: rgb(var(--shell-border) / var(--shell-border-soft));
    background-color: rgb(var(--shell-pane-bg));
  }

  html:not(.dark) .theme-option:hover {
    border-color: rgb(var(--shell-border) / var(--shell-border-strong));
    background-color: rgb(var(--shell-pane-muted-bg) / 0.75);
  }

  html:not(.dark) .mobile-shell {
    background-color: rgb(var(--shell-canvas-bg));
    color: rgb(var(--color-surface-50));
  }

  html:not(.dark) .mobile-top-bar {
    border-color: rgb(var(--shell-border) / var(--shell-border-soft));
    background-color: rgb(var(--shell-chrome-bg) / 0.96);
  }

  html:not(.dark) .mobile-bottom-chrome {
    background-color: rgb(var(--shell-chrome-bg) / 0.97);
    border-top-color: rgb(var(--shell-border) / var(--shell-border-soft));
  }

  /* Voice hierarchy — breadcrumbs, labels, muted copy */
  .workshop-faint {
    @apply text-xs;
    color: rgb(var(--shell-whisper));
  }

  .workshop-section-title {
    @apply text-xs font-semibold uppercase tracking-wide;
    color: rgb(var(--shell-label));
  }

  .workshop-label {
    @apply text-xs;
    color: rgb(var(--shell-label));
  }

  .workshop-muted {
    @apply text-sm;
    color: rgb(var(--shell-muted));
  }

  .workshop-text-action {
    @apply text-xs transition;
    color: rgb(var(--shell-muted));
  }

  .workshop-text-action:hover {
    color: rgb(var(--color-primary-300));
  }

  .workshop-tabs {
    border-bottom-color: rgb(var(--shell-border) / var(--shell-border-soft));
  }

  .workshop-tab {
    color: rgb(var(--shell-muted));
  }

  .workshop-tab:hover {
    color: rgb(var(--shell-whisper));
  }

  .workshop-tab-active {
    border-bottom-color: rgb(var(--color-primary-400));
    color: rgb(var(--shell-icon-active));
    font-weight: 600;
  }

  /* Split / soft-primary toggles — intentional, not pastel ghosts */
  .btn.variant-soft-primary {
    background-color: rgb(var(--color-primary-500) / 0.2);
    color: rgb(var(--shell-icon-active));
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.42);
  }

  .btn.variant-soft-primary:hover {
    background-color: rgb(var(--color-primary-500) / 0.28);
  }

  html:not(.dark) .btn.variant-soft-primary {
    background-color: rgb(var(--color-primary-500) / 0.16);
    color: rgb(var(--color-primary-700, var(--shell-label)));
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-500) / 0.32);
  }

  html:not(.dark) .btn.variant-soft-primary:hover {
    background-color: rgb(var(--color-primary-500) / 0.24);
    color: rgb(var(--color-primary-800, var(--shell-whisper)));
  }

  /* Soft/surface buttons — Skeleton defaults wash out in light mode */
  .btn.variant-soft-surface,
  .btn.variant-soft {
    background-color: rgb(var(--shell-pane-muted-bg) / 0.95);
    color: rgb(var(--shell-label));
    box-shadow: inset 0 0 0 1px rgb(var(--shell-border) / 0.4);
  }

  .btn.variant-soft-surface:hover,
  .btn.variant-soft:hover {
    background-color: rgb(var(--shell-pane-muted-bg));
    color: rgb(var(--shell-whisper));
  }

  .btn.variant-ghost-surface {
    color: rgb(var(--shell-label));
  }

  .btn.variant-ghost-surface:hover {
    color: rgb(var(--shell-whisper));
    background-color: rgb(var(--shell-pane-muted-bg) / 0.65);
  }

  html:not(.dark) .btn.variant-soft-surface,
  html:not(.dark) .btn.variant-soft {
    background-color: rgb(var(--shell-pane-muted-bg));
    color: rgb(var(--shell-whisper));
    box-shadow: inset 0 0 0 1px rgb(var(--shell-border) / 0.35);
  }

  html:not(.dark) .btn.variant-soft-surface:hover,
  html:not(.dark) .btn.variant-soft:hover {
    color: rgb(var(--shell-label));
    background-color: color-mix(in srgb, rgb(var(--shell-pane-muted-bg)) 80%, rgb(var(--shell-label)) 8%);
  }

  html:not(.dark) .btn.variant-ghost-surface {
    color: rgb(var(--shell-whisper));
  }

  html:not(.dark) .workshop-text-action {
    color: rgb(var(--shell-whisper));
  }

  html:not(.dark) .workshop-text-action:hover {
    color: rgb(var(--color-primary-600));
  }

  .composer-bar:focus-within {
    border-color: rgb(var(--color-primary-500) / 0.42);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.07),
      0 0 0 3px rgb(var(--color-primary-500) / 0.14),
      0 2px 10px rgb(0 0 0 / 0.18);
  }

  .markdown-content th {
    color: rgb(var(--shell-label));
  }

  .markdown-content td:first-child {
    color: rgb(var(--shell-muted));
  }
}
