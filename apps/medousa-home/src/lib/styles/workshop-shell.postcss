    --shell-header-bg: 236 228 218;
    --shell-canvas-bg: 246 242 236;
    --shell-pane-bg: 255 252 248;
    --shell-pane-muted-bg: 240 234 226;
    --shell-border: 176 160 144;
    --shell-border-strong: 0.5;
    --shell-icon-active: var(--color-primary-600);
