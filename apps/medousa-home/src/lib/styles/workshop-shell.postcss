  }

  /* Dracula */
  html.dark[data-theme="dracula"] {
    --shell-chrome-bg: 40 42 54;
    --shell-header-bg: 52 55 70;
    --shell-canvas-bg: 26 27 36;
    --shell-pane-bg: 40 42 54;
    --shell-pane-muted-bg: 52 55 70;
    --shell-border-strong: 0.55;
    --shell-whisper: 220 220 214;
    --shell-label: 232 232 226;
    --shell-muted: 180 180 174;
  }

  html:not(.dark)[data-theme="dracula-light"] {
    --shell-chrome-bg: 234 235 240;
    --shell-header-bg: 240 241 246;
    --shell-canvas-bg: 248 248 250;
    --shell-pane-bg: 255 255 255;
    --shell-pane-muted-bg: 240 241 246;
    --shell-border-strong: 0.5;
    --shell-whisper: 88 91 110;
    --shell-label: 68 71 90;
    --shell-muted: 118 121 140;
    --shell-icon-active: var(--color-primary-600);
  }

  /* Nord */
  html.dark[data-theme="nord"] {
    --shell-chrome-bg: 46 52 64;
    --shell-header-bg: 59 66 82;
    --shell-canvas-bg: 32 36 46;
    --shell-pane-bg: 46 52 64;
    --shell-pane-muted-bg: 59 66 82;
    --shell-border-strong: 0.55;
    --shell-whisper: 196 204 216;
    --shell-label: 216 222 233;
    --shell-muted: 163 176 194;
  }

  html:not(.dark)[data-theme="nord-light"] {
    --shell-chrome-bg: 226 228 232;
    --shell-header-bg: 236 239 244;
    --shell-canvas-bg: 236 239 244;
    --shell-pane-bg: 255 255 255;
    --shell-pane-muted-bg: 240 242 245;
    --shell-border: 178 183 190;
    --shell-border-strong: 0.5;
