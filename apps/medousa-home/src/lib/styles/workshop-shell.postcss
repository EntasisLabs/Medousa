/**
 * Workshop app shell — chrome vs canvas elevation.
 *
 * Extracted from app.postcss so shell polish lives here instead of the god file.
 * Tokens are RGB triples (no `rgb()` wrapper) matching Skeleton surface vars.
 */

@layer base {
  /* Dark defaults: ink canvas, slightly raised chrome frame */
  html.dark {
    --shell-chrome-bg: var(--color-surface-900);
    --shell-header-bg: var(--color-surface-800);
    --shell-canvas-bg: var(--color-surface-950);
    --shell-pane-bg: var(--color-surface-900);
    --shell-pane-muted-bg: var(--color-surface-800);
    --shell-border: var(--color-surface-500);
    --shell-border-strong: 0.58;
    --shell-border-soft: 0.4;
    --shell-rail-edge: 0.24;
    --shell-icon: var(--color-surface-400);
    --shell-icon-hover: var(--color-surface-200);
    --shell-icon-active: var(--color-primary-300);
    --shell-status-fg: var(--color-surface-300);
    /* Voice — secondary text hierarchy (Wave 2) */
    --shell-whisper: var(--color-surface-300);
    --shell-label: var(--color-surface-300);
    --shell-muted: var(--color-surface-400);
    --shell-chrome-shadow: 2px 0 18px rgb(0 0 0 / 0.32);
    --shell-rail-shadow: -6px 0 20px rgb(0 0 0 / 0.24);
    --shell-nav-shadow: 3px 0 16px rgb(0 0 0 / 0.22);
    --shell-nav-inset: inset 1px 0 0 rgb(255 255 255 / 0.045);
  }

  /* Light defaults: denser cool chrome over brighter paper */
  html:not(.dark) {
    --shell-chrome-bg: var(--color-surface-800);
    --shell-header-bg: var(--color-surface-800);
    --shell-canvas-bg: var(--color-surface-950);
    --shell-pane-bg: var(--color-surface-900);
    --shell-pane-muted-bg: var(--color-surface-800);
    --shell-border: var(--color-surface-500);
    --shell-border-strong: 0.55;
    --shell-border-soft: 0.38;
    --shell-rail-edge: 0.26;
    --shell-icon: var(--color-surface-300);
    --shell-icon-hover: var(--color-surface-100);
    --shell-icon-active: var(--color-primary-600);
    --shell-status-fg: var(--color-surface-200);
    --shell-whisper: var(--color-surface-200);
    --shell-label: var(--color-surface-200);
    --shell-muted: var(--color-surface-300);
    --shell-chrome-shadow: 2px 0 14px rgb(0 0 0 / 0.06);
    --shell-rail-shadow: -4px 0 14px rgb(0 0 0 / 0.05);
    --shell-nav-shadow: 2px 0 12px rgb(0 0 0 / 0.06);
    --shell-nav-inset: inset 1px 0 0 rgb(255 255 255 / 0.12);
  }

  /* Obsidian dark — deepen the void under the frame */
  html.dark[data-theme="medousa"] {
    --shell-chrome-bg: 28 28 40;
    --shell-header-bg: 36 36 50;
    --shell-canvas-bg: 14 14 22;
    --shell-pane-bg: 24 24 34;
    --shell-pane-muted-bg: 32 32 44;
    --shell-border-strong: 0.62;
    --shell-whisper: 175 175 198;
    --shell-label: 188 188 210;
    --shell-muted: 148 148 172;
  }

  /* Black Lily dark — plum frame, deeper void canvas */
  html.dark[data-theme="black-lily"] {
    --shell-chrome-bg: 24 16 30;
    --shell-header-bg: 34 22 44;
    --shell-canvas-bg: 10 8 14;
    --shell-pane-bg: 18 12 24;
    --shell-pane-muted-bg: 28 18 36;
    --shell-border-strong: 0.65;
    --shell-whisper: 200 185 218;
    --shell-label: 210 195 226;
    --shell-muted: 168 148 192;
  }

  /* Caduceus dark — serpentine ink, soft jade */
  html.dark[data-theme="caduceus-dark"] {
    --shell-chrome-bg: 24 32 28;
    --shell-header-bg: 34 44 38;
    --shell-canvas-bg: 10 14 12;
    --shell-pane-bg: 16 22 18;
    --shell-pane-muted-bg: 24 32 28;
    --shell-border-strong: 0.58;
    --shell-whisper: 168 186 172;
    --shell-label: 186 202 188;
    --shell-muted: 132 152 138;
  }

  /* Ember dark — cool ash, rose-copper glow */
  html.dark[data-theme="ember-dark"] {
    --shell-chrome-bg: 30 24 24;
    --shell-header-bg: 42 34 32;
    --shell-canvas-bg: 12 10 10;
    --shell-pane-bg: 20 16 16;
    --shell-pane-muted-bg: 30 24 24;
    --shell-border-strong: 0.58;
    --shell-whisper: 190 164 152;
    --shell-label: 210 186 174;
    --shell-muted: 156 128 118;
  }

  /* Hearth dark — evening cocoa */
  html.dark[data-theme="hearth-dark"] {
    --shell-chrome-bg: 32 26 22;
    --shell-header-bg: 44 36 30;
    --shell-canvas-bg: 14 12 10;
    --shell-pane-bg: 22 18 16;
    --shell-pane-muted-bg: 32 26 22;
    --shell-border-strong: 0.58;
    --shell-whisper: 190 172 156;
    --shell-label: 210 192 176;
    --shell-muted: 156 136 118;
  }

  /* Graphite dark */
  html.dark[data-theme="graphite-dark"] {
    --shell-chrome-bg: 36 36 38;
    --shell-header-bg: 44 44 46;
    --shell-canvas-bg: 0 0 0;
    --shell-pane-bg: 28 28 30;
    --shell-pane-muted-bg: 44 44 46;
    --shell-border: 110 110 115;
    --shell-border-strong: 0.55;
    --shell-whisper: 174 174 178;
    --shell-label: 199 199 204;
    --shell-muted: 142 142 147;
    --shell-icon-active: var(--color-surface-100);
  }

  /* Cupertino dark — navy-cool chrome over black canvas */
  html.dark[data-theme="cupertino-dark"] {
    --shell-chrome-bg: 36 36 38;
    --shell-header-bg: 44 44 46;
    --shell-canvas-bg: 0 0 0;
    --shell-pane-bg: 28 28 30;
    --shell-pane-muted-bg: 44 44 46;
    --shell-border-strong: 0.55;
    --shell-whisper: 174 174 178;
    --shell-label: 199 199 204;
    --shell-muted: 142 142 147;
  }

  /* Midnight dark — deep navy frame */
  html.dark[data-theme="midnight-dark"] {
    --shell-chrome-bg: 18 24 42;
    --shell-header-bg: 26 34 56;
    --shell-canvas-bg: 6 10 18;
    --shell-pane-bg: 15 20 35;
    --shell-pane-muted-bg: 22 28 48;
    --shell-border-strong: 0.58;
    --shell-whisper: 160 172 205;
    --shell-label: 178 188 220;
    --shell-muted: 120 132 168;
  }

  /* Graphite light — honest mono elevation (quality bar for light) */
  html:not(.dark)[data-theme="graphite-light"] {
    --shell-chrome-bg: 226 226 230;
    --shell-header-bg: 232 232 236;
    --shell-canvas-bg: 242 242 247;
    --shell-pane-bg: 255 255 255;
    --shell-pane-muted-bg: 236 236 240;
    --shell-border: 142 142 147;
    --shell-border-strong: 0.5;
    --shell-icon-active: var(--color-surface-100);
    --shell-whisper: 72 72 74;
    --shell-label: 58 58 60;
    --shell-muted: 99 99 102;
  }

  /* Cupertino light */
  html:not(.dark)[data-theme="cupertino-light"] {
    --shell-chrome-bg: 226 226 230;
    --shell-header-bg: 232 232 236;
    --shell-canvas-bg: 242 242 247;
    --shell-pane-bg: 255 255 255;
    --shell-pane-muted-bg: 236 236 240;
    --shell-border: 142 142 147;
    --shell-border-strong: 0.5;
    --shell-whisper: 72 72 74;
    --shell-label: 58 58 60;
    --shell-muted: 99 99 102;
    --shell-icon-active: var(--color-primary-600);
  }

  /* Midnight light */
  html:not(.dark)[data-theme="midnight-light"] {
    --shell-chrome-bg: 220 224 238;
    --shell-header-bg: 228 232 244;
    --shell-canvas-bg: 240 242 250;
    --shell-pane-bg: 255 255 255;
    --shell-pane-muted-bg: 232 235 245;
    --shell-border: 142 152 178;
    --shell-border-strong: 0.5;
    --shell-whisper: 58 68 96;
    --shell-label: 48 58 86;
    --shell-muted: 88 98 128;
    --shell-icon-active: var(--color-primary-600);
  }

  /* Obsidian light — cool chrome, clean paper */
  html:not(.dark)[data-theme="medousa-light"] {
    --shell-chrome-bg: 218 218 228;
    --shell-header-bg: 226 226 234;
    --shell-canvas-bg: 244 244 248;
    --shell-pane-bg: 255 255 255;
    --shell-pane-muted-bg: 232 232 240;
    --shell-border-strong: 0.52;
    --shell-icon-active: var(--color-primary-600);
    --shell-whisper: 68 68 84;
    --shell-label: 56 56 72;
    --shell-muted: 98 98 118;
  }

  /* Black Lily light — blush chrome, bright paper */
  html:not(.dark)[data-theme="black-lily-light"] {
    --shell-chrome-bg: 228 216 232;
    --shell-header-bg: 236 226 240;
    --shell-canvas-bg: 246 240 248;
    --shell-pane-bg: 255 252 255;
    --shell-pane-muted-bg: 238 228 242;
    --shell-border-strong: 0.5;
    --shell-icon-active: var(--color-primary-600);
    --shell-whisper: 86 70 96;
    --shell-label: 72 56 86;
    --shell-muted: 116 96 126;
  }

  /* Caduceus light — soft mint paper, botanical chrome */
  html:not(.dark)[data-theme="caduceus-light"] {
    --shell-chrome-bg: 210 222 210;
    --shell-header-bg: 220 230 220;
    --shell-canvas-bg: 242 248 242;
    --shell-pane-bg: 255 255 255;
    --shell-pane-muted-bg: 228 236 228;
    --shell-border: 118 140 122;
    --shell-border-strong: 0.5;
