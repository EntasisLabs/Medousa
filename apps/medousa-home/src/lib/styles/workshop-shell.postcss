  html:not(.dark)[data-theme="github-light"] {
    --shell-chrome-bg: 225 228 232;
    --shell-header-bg: 234 236 240;
    --shell-canvas-bg: 246 248 250;
    --shell-pane-bg: 255 255 255;
    --shell-pane-muted-bg: 234 236 240;
    --shell-border: 175 181 188;
    --shell-border-strong: 0.52;
    --shell-whisper: 55 62 70;
    --shell-label: 36 41 47;
    --shell-muted: 87 96 106;
