{
  "name": "medousa-home",
  "version": "0.1.1",
  "description": "Medousa — Life Manageable",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "prepare:sidecar": "bash scripts/prepare-engine-sidecar.sh",
    "tauri:build": "npm run prepare:sidecar && tauri build",
    "build:desktop": "npm run tauri:build",
    "build:full": "bash scripts/build-full-package.sh",
    "build:full:ios": "bash scripts/build-full-package.sh --ios",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "icons:generate": "tauri icon app-icon.json -o src-tauri/icons --ios-color \"#0a0a0b\" && cp src-tauri/icons/128x128.png static/favicon.png",
    "tauri:ios:init": "tauri ios init",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:ios:build": "tauri ios build",
    "tauri:ios:clean": "bash scripts/ios-clean.sh",
    "tauri:ios:build:testflight": "bash scripts/ios-testflight-build.sh"
  },
  "license": "MIT",
  "dependencies": {
    "@lucide/svelte": "^1.17.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "dompurify": "^3.4.8",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "xlsx": "^0.18.5",
    "html2pdf.js": "^0.10.2"
  },
  "devDependencies": {
    "@skeletonlabs/skeleton": "^2.10.3",
    "@skeletonlabs/tw-plugin": "^0.4.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tauri-apps/cli": "^2",
    "@types/dompurify": "^3.0.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
