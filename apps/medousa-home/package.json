{
  "name": "medousa-home",
  "version": "0.1.0",
  "description": "Medousa — Life Manageable",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "prepare:sidecar": "node scripts/prepare-engine-sidecar-runner.mjs",
    "tauri:build": "npm run prepare:sidecar && node scripts/tauri-build-runner.mjs",
    "build:desktop": "npm run tauri:build",
    "build:full": "node scripts/build-full-package-runner.mjs",
    "build:full:ios": "node scripts/build-full-package-runner.mjs -- --ios",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "icons:generate": "tauri icon app-icon.json -o src-tauri/icons --ios-color \"#0a0a0b\" && cp src-tauri/icons/128x128.png static/favicon.png",
    "tauri:ios:init": "tauri ios init && npm run ios:prepare",
    "ios:prepare": "bash scripts/ios-prepare.sh",
    "tauri:ios:dev": "npm run ios:prepare && MEDOUSA_LIVE_ACTIVITY=1 tauri ios dev",
    "tauri:ios:dev:sim": "npm run ios:prepare && MEDOUSA_LIVE_ACTIVITY=1 tauri ios dev \"iPhone 16 Pro\"",
    "tauri:ios:build": "npm run ios:prepare && MEDOUSA_LIVE_ACTIVITY=1 tauri ios build",
    "tauri:ios:clean": "bash scripts/ios-clean.sh",
    "tauri:ios:build:testflight": "bash scripts/ios-testflight-build.sh"
  },
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/lsp-client": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@lucide/svelte": "^1.17.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "codemirror": "^6.0.2",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "dompurify": "^3.4.8",
    "highlight.js": "^11.11.1",
    "html2pdf.js": "^0.10.2",
    "layercake": "^10.0.3",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "tauri-plugin-mobile-push-api": "^0.1.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@skeletonlabs/skeleton": "^2.10.3",
    "@skeletonlabs/tw-plugin": "^0.4.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tauri-apps/cli": "^2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^26.1.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
