{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medousa.dev/schemas/installer-bootstrap.json",
  "title": "MedousaInstallerBootstrap",
  "type": "object",
  "required": ["schemaVersion", "product", "version", "publishedAt", "platforms"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "product": { "type": "string", "const": "medousa-installer" },
    "version": { "type": "string" },
    "channel": { "type": "string" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "manifestUrl": { "type": "string", "format": "uri" },
    "platforms": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["platform", "version", "fileName", "url", "sha256", "sizeBytes"],
        "properties": {
          "platform": { "type": "string" },
          "version": { "type": "string" },
          "fileName": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "sha256": { "type": "string" },
          "sizeBytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
